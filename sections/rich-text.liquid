<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-rich-text.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}</noscript>

{%- liquid
  assign playful_style = section.settings.playful_style | default: 'sunshine'
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Cheerful kids banner — scoped, no harsh “editorial” bar */
  .kids-banner-{{ section.id }} {
    --k-text: #2d2a26;
    --k-muted: #5e5a52;
    --k-bg: #fffbf5;
    --k-bg-2: #fff5eb;
    --k-border: rgba(255, 138, 107, 0.22);
    --k-shadow: 0 12px 40px rgba(45, 42, 38, 0.07);
    --k-accent: #ff8a6b;
    --k-accent-2: #ffd93d;
    --k-dot: rgba(255, 138, 107, 0.12);
    --k-btn-primary-bg: #ff8a6b;
    --k-btn-primary-fg: #ffffff;
    --k-btn-secondary-bg: #ffffff;
    --k-btn-secondary-fg: #2d2a26;
    --k-btn-secondary-border: rgba(45, 42, 38, 0.2);
  }

  .kids-banner-{{ section.id }}.kids-banner--bubblegum {
    --k-text: #3d2f3a;
    --k-muted: #6b5a63;
    --k-bg: #fff5fb;
    --k-bg-2: #fce8f4;
    --k-border: rgba(232, 121, 169, 0.28);
    --k-shadow: 0 12px 40px rgba(120, 60, 100, 0.08);
    --k-accent: #e879a9;
    --k-accent-2: #c4a5ff;
    --k-dot: rgba(232, 121, 169, 0.12);
    --k-btn-primary-bg: #e879a9;
    --k-btn-primary-fg: #ffffff;
    --k-btn-secondary-bg: #ffffff;
    --k-btn-secondary-fg: #3d2f3a;
    --k-btn-secondary-border: rgba(61, 47, 58, 0.2);
  }

  .kids-banner-{{ section.id }}.kids-banner--mint {
    --k-text: #1e3d38;
    --k-muted: #4a6560;
    --k-bg: #f4fffc;
    --k-bg-2: #e6faf5;
    --k-border: rgba(62, 203, 182, 0.28);
    --k-shadow: 0 12px 40px rgba(30, 90, 80, 0.07);
    --k-accent: #3ecbb6;
    --k-accent-2: #7dd3fc;
    --k-dot: rgba(62, 203, 182, 0.12);
    --k-btn-primary-bg: #2eb8a3;
    --k-btn-primary-fg: #ffffff;
    --k-btn-secondary-bg: #ffffff;
    --k-btn-secondary-fg: #1e3d38;
    --k-btn-secondary-border: rgba(30, 61, 56, 0.2);
  }

  .kids-banner-{{ section.id }}.kids-banner--soft_mono {
    --k-text: #252525;
    --k-muted: #5a5a5a;
    --k-bg: #fafafa;
    --k-bg-2: #f0f0f0;
    --k-border: rgba(0, 0, 0, 0.08);
    --k-shadow: 0 12px 36px rgba(0, 0, 0, 0.06);
    --k-accent: #404040;
    --k-accent-2: #9ca3af;
    --k-dot: rgba(0, 0, 0, 0.05);
    --k-btn-primary-bg: #252525;
    --k-btn-primary-fg: #ffffff;
    --k-btn-secondary-bg: #ffffff;
    --k-btn-secondary-fg: #252525;
    --k-btn-secondary-border: rgba(0, 0, 0, 0.15);
  }

  .kids-banner-{{ section.id }} .rich-text.content-container {
    position: relative;
    overflow: hidden;
    border-radius: clamp(1.25rem, 4vw, 2rem) !important;
    border: 1px solid var(--k-border) !important;
    box-shadow: var(--k-shadow) !important;
    background: linear-gradient(155deg, var(--k-bg) 0%, var(--k-bg-2) 55%, var(--k-bg) 100%) !important;
    color: var(--k-text);
  }

  .kids-banner-{{ section.id }} .rich-text.content-container::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: radial-gradient(var(--k-dot) 1.2px, transparent 1.2px);
    background-size: 20px 20px;
    pointer-events: none;
    opacity: 0.85;
  }

  .kids-banner-{{ section.id }} .kids-banner__frame {
    position: relative;
    z-index: 1;
    max-width: 70rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.75rem);
  }

  .kids-banner-{{ section.id }} .kids-banner__frame::before,
  .kids-banner-{{ section.id }} .kids-banner__frame::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .kids-banner-{{ section.id }} .kids-banner__frame::before {
    width: min(140px, 28vw);
    height: min(140px, 28vw);
    background: var(--k-accent-2);
    opacity: 0.18;
    top: -2rem;
    right: -1.5rem;
  }

  .kids-banner-{{ section.id }} .kids-banner__frame::after {
    width: min(100px, 22vw);
    height: min(100px, 22vw);
    background: var(--k-accent);
    opacity: 0.14;
    bottom: 0;
    left: -1rem;
  }

  .kids-banner-{{ section.id }} .rich-text__blocks {
    position: relative;
    z-index: 1;
    padding-inline: 0;
  }

  .kids-banner-{{ section.id }} .rich-text__heading,
  .kids-banner-{{ section.id }} .rich-text__heading * {
    color: var(--k-text) !important;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.18;
    margin-top: 0;
  }

  .kids-banner-{{ section.id }} .rich-text__caption {
    color: var(--k-accent) !important;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    font-size: clamp(0.9rem, 2.5vw, 1rem);
    margin-bottom: 0.35rem;
  }

  .kids-banner-{{ section.id }} .rich-text__text,
  .kids-banner-{{ section.id }} .rich-text__text.rte,
  .kids-banner-{{ section.id }} .rich-text__text p {
    color: var(--k-muted);
    line-height: 1.75;
    font-size: 1.05rem;
    max-width: 44rem;
  }

  .kids-banner-{{ section.id }} .rich-text__text.left,
  .kids-banner-{{ section.id }} .rich-text__blocks.left .rich-text__text {
    margin-inline: 0;
  }

  .kids-banner-{{ section.id }} .rich-text__text.center,
  .kids-banner-{{ section.id }} .rich-text__blocks.center .rich-text__text {
    margin-inline: auto;
  }

  .kids-banner-{{ section.id }} .rich-text__text.right,
  .kids-banner-{{ section.id }} .rich-text__blocks.right .rich-text__text {
    margin-inline: 0 0 0 auto;
  }

  .kids-banner-{{ section.id }} .rich-text__buttons {
    gap: 0.85rem 1rem;
    margin-top: 0.65rem;
    flex-wrap: wrap;
  }

  .kids-banner-{{ section.id }} .rich-text__buttons .button.button--primary {
    background: var(--k-btn-primary-bg) !important;
    color: var(--k-btn-primary-fg) !important;
    border: 2px solid rgba(0, 0, 0, 0.1) !important;
    border-radius: 9999px !important;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 1rem;
    padding: 0.9em 1.75em;
    box-shadow: 0 4px 0 rgba(0, 0, 0, 0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .kids-banner-{{ section.id }} .rich-text__buttons .button.button--secondary {
    background: var(--k-btn-secondary-bg) !important;
    color: var(--k-btn-secondary-fg) !important;
    border: 2px solid var(--k-btn-secondary-border) !important;
    border-radius: 9999px !important;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
    font-size: 1rem;
    padding: 0.9em 1.75em;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .kids-banner-{{ section.id }} .rich-text__buttons .button.button--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 rgba(0, 0, 0, 0.14);
  }

  .kids-banner-{{ section.id }} .rich-text__buttons .button.button--secondary:hover {
    transform: translateY(-2px);
    background: #fffef8 !important;
    border-color: var(--k-accent) !important;
  }

  .kids-banner-{{ section.id }} .rich-text__buttons .button[aria-disabled='true'] {
    opacity: 0.5;
    transform: none;
    box-shadow: none;
    cursor: not-allowed;
  }

  .kids-banner-{{ section.id }} .kids-banner__divider-dots {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    justify-content: center;
    margin: 1rem 0 0.25rem;
  }

  .kids-banner-{{ section.id }} .kids-banner__divider-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--k-accent);
    opacity: 0.75;
  }

  .kids-banner-{{ section.id }} .kids-banner__divider-dots span:nth-child(2) {
    background: var(--k-accent-2);
    transform: scale(1.15);
  }

  .kids-banner-{{ section.id }} .kids-banner__divider-dots span:nth-child(3) {
    background: var(--k-accent);
    opacity: 0.55;
  }

  .kids-banner-{{ section.id }} .rich-text__blocks.left .kids-banner__divider-dots {
    justify-content: flex-start;
  }

  .kids-banner-{{ section.id }} .rich-text__blocks.right .kids-banner__divider-dots {
    justify-content: flex-end;
  }
{%- endstyle -%}

<div class="isolate kids-banner-{{ section.id }} kids-banner--{{ playful_style }}{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="rich-text content-container color-{{ section.settings.color_scheme }} gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding">
    <div class="rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}{% if section.settings.full_width %} page-width{% endif %}">
      <div class="kids-banner__frame">
        <div class="rich-text__blocks {{ section.settings.content_alignment }}">
          {%- assign heading_seen = false -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                {%- if heading_seen -%}
                  <div class="kids-banner__divider-spacer" aria-hidden="true">
                    <div class="kids-banner__divider-dots"><span></span><span></span><span></span></div>
                  </div>
                {%- endif -%}
                {%- assign heading_seen = true -%}
                <h2 class="rich-text__heading rte {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {{ block.settings.heading | replace: 'p>', 'span>' }}
                </h2>
              {%- when 'caption' -%}
                <p class="rich-text__caption {{ block.settings.text_style }} {{ block.settings.text_style }}--{{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                  {{ block.settings.caption | escape }}
                </p>
              {%- when 'text' -%}
                <div class="rich-text__text rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                <div class="rich-text__buttons{% if block.settings.button_label != blank and block.settings.button_label_2 != blank %} rich-text__buttons--multiple{% endif %}" {{ block.shopify_attributes }}>
                  {%- if block.settings.button_label != blank -%}
                    <a{% if block.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link }}"{% endif %} class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}">{{ block.settings.button_label | escape }}</a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank -%}
                    <a{% if block.settings.button_link_2 == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link_2 }}"{% endif %} class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}">{{ block.settings.button_label_2 | escape }}</a>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.rich-text.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "playful_style",
      "label": "Mood & colors",
      "options": [
        {
          "value": "sunshine",
          "label": "Sunshine (warm peach & yellow)"
        },
        {
          "value": "bubblegum",
          "label": "Bubblegum (pink & lavender)"
        },
        {
          "value": "mint",
          "label": "Mint & sky (fresh)"
        },
        {
          "value": "soft_mono",
          "label": "Soft monochrome (minimal)"
        }
      ],
      "default": "sunshine",
      "info": "Cheerful palettes for kids — headings and buttons pick up accent colors automatically."
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.rich-text.settings.desktop_content_position.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.rich-text.settings.desktop_content_position.label",
      "info": "t:sections.rich-text.settings.desktop_content_position.info"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.rich-text.settings.content_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.rich-text.settings.content_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.rich-text.settings.content_alignment.options__3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.rich-text.settings.content_alignment.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.colors.inverse.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label",
      "info": "Fallback theme colors; this section uses the Mood & colors palette above for the card look."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.rich-text.settings.full_width.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 3,
      "settings": [
        {
          "type": "richtext",
          "id": "heading",
          "default": "<p>Talk about your brand</p>",
          "label": "t:sections.rich-text.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            },
            {
              "value": "hxl",
              "label": "t:sections.all.heading_size.options__4.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        }
      ]
    },
    {
      "type": "caption",
      "name": "t:sections.rich-text.blocks.caption.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "default": "Add a tagline",
          "label": "t:sections.rich-text.blocks.caption.settings.text.label"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "subtitle",
              "label": "t:sections.rich-text.blocks.caption.settings.text_style.options__1.label"
            },
            {
              "value": "caption-with-letter-spacing",
              "label": "t:sections.rich-text.blocks.caption.settings.text_style.options__2.label"
            }
          ],
          "default": "caption-with-letter-spacing",
          "label": "t:sections.rich-text.blocks.caption.settings.text_style.label"
        },
        {
          "type": "select",
          "id": "text_size",
          "options": [
            {
              "value": "small",
              "label": "t:sections.rich-text.blocks.caption.settings.caption_size.options__1.label"
            },
            {
              "value": "medium",
              "label": "t:sections.rich-text.blocks.caption.settings.caption_size.options__2.label"
            },
            {
              "value": "large",
              "label": "t:sections.rich-text.blocks.caption.settings.caption_size.options__3.label"
            }
          ],
          "default": "medium",
          "label": "t:sections.rich-text.blocks.caption.settings.caption_size.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.rich-text.blocks.text.name",
      "limit": 3,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
          "label": "t:sections.rich-text.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.rich-text.blocks.buttons.name",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "t:sections.rich-text.blocks.buttons.settings.button_label_1.label",
          "info": "t:sections.rich-text.blocks.buttons.settings.button_label_1.info"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.rich-text.blocks.buttons.settings.button_link_1.label"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "default": false,
          "label": "t:sections.rich-text.blocks.buttons.settings.button_style_secondary_1.label"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "t:sections.rich-text.blocks.buttons.settings.button_label_2.label",
          "info": "t:sections.rich-text.blocks.buttons.settings.button_label_2.info"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "t:sections.rich-text.blocks.buttons.settings.button_link_2.label"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "default": false,
          "label": "t:sections.rich-text.blocks.buttons.settings.button_style_secondary_2.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich-text.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
