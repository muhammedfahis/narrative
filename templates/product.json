\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" role=\"button\" tabindex=\"0\" aria-label=\"Close\">\n        <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n        <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n      </svg>\n    </div>\n    <div class=\"ai-size-chart-inner-{{ ai_gen_id }}\">\n\n      <div class=\"ai-size-chart-guide-{{ ai_gen_id }}\">\n        <p class=\"ai-size-chart-guide-title-{{ ai_gen_id }}\">How to measure</p>\n        <ul class=\"ai-size-chart-guide-list-{{ ai_gen_id }}\">\n          <li><strong>Height</strong> — Measure barefoot, back straight, head to floor.</li>\n          <li><strong>Chest</strong> — Tape around fullest part of chest, under the arms.</li>\n          <li><strong>Garment length</strong> — Shoulder seam down to hem.</li>\n        </ul>\n        <div class=\"ai-size-chart-diagram-{{ ai_gen_id }}\" aria-hidden=\"true\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 200 270\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <g font-family=\"system-ui, sans-serif\" font-size=\"9\" fill=\"currentColor\" stroke=\"none\">\n              <text x=\"14\" y=\"138\" text-anchor=\"middle\" transform=\"rotate(-90 14 138)\">Height</text>\n              <text x=\"118\" y=\"118\" text-anchor=\"start\">Chest</text>\n              <text x=\"152\" y=\"168\" text-anchor=\"start\">Length</text>\n            </g>\n            <line x1=\"28\" y1=\"20\" x2=\"28\" y2=\"252\" stroke-dasharray=\"4 3\"/>\n            <line x1=\"28\" y1=\"20\" x2=\"34\" y2=\"20\"/>\n            <line x1=\"28\" y1=\"252\" x2=\"34\" y2=\"252\"/>\n            <ellipse cx=\"100\" cy=\"42\" rx=\"20\" ry=\"22\"/>\n            <path d=\"M100 64v26M82 118l-10 48M118 118l10 48M90 90h20\"/>\n            <path d=\"M90 90c-6 14-12 30-16 46M110 90c6 14 12 30 16 46\"/>\n            <path d=\"M94 198v44h-8M106 198v44h8\"/>\n            <ellipse cx=\"100\" cy=\"108\" rx=\"26\" ry=\"14\"/>\n            <line x1=\"66\" y1=\"108\" x2=\"134\" y2=\"108\"/>\n            <line x1=\"66\" y1=\"102\" x2=\"66\" y2=\"114\"/>\n            <line x1=\"134\" y1=\"102\" x2=\"134\" y2=\"114\"/>\n            <path d=\"M108 78 L108 178\"/>\n            <line x1=\"108\" y1=\"78\" x2=\"114\" y2=\"78\"/>\n            <line x1=\"108\" y1=\"178\" x2=\"114\" y2=\"178\"/>\n          </svg>\n          <p class=\"ai-size-chart-diagram-caption-{{ ai_gen_id }}\">Height · Chest · Length</p>\n        </div>\n      </div>\n\n      <div class=\"ai-size-chart-toolbar-{{ ai_gen_id }}\">\n        <span class=\"ai-size-chart-toolbar-label-{{ ai_gen_id }}\">Measurements</span>\n        <div class=\"ai-size-chart-unit-toggle-{{ ai_gen_id }}\" role=\"group\" aria-label=\"Unit toggle\">\n          <button type=\"button\" class=\"ai-size-chart-unit-btn-{{ ai_gen_id }}\" data-unit=\"in\" aria-pressed=\"true\">Inches</button>\n          <button type=\"button\" class=\"ai-size-chart-unit-btn-{{ ai_gen_id }}\" data-unit=\"cm\" aria-pressed=\"false\">CM</button>\n        </div>\n      </div>\n\n      <div class=\"ai-size-chart-table-wrap-{{ ai_gen_id }}\" id=\"kidsmire-table-wrap\" data-unit=\"in\">\n        {% if product.tags contains 'imported' %}\n        <table class=\"ai-size-chart-table-{{ ai_gen_id }}\">\n          <thead><tr><th>Age</th><th>CN</th><th>Height</th><th>Chest</th><th>Garment length</th></tr></thead>\n          <tbody>\n            <tr><td>0–6 mo</td><td>66</td><td><span class=\"sc-in\">23–27\"</span><span class=\"sc-cm\">59–68 cm</span></td><td><span class=\"sc-in\">16–17\"</span><span class=\"sc-cm\">40–44 cm</span></td><td><span class=\"sc-in\">11–13\"</span><span class=\"sc-cm\">28–32 cm</span></td></tr>\n            <tr><td>6–12 mo</td><td>73</td><td><span class=\"sc-in\">27–30\"</span><span class=\"sc-cm\">68–76 cm</span></td><td><span class=\"sc-in\">17–19\"</span><span class=\"