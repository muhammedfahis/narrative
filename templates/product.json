cm\">134–140 cm</span></td><td><span class=\"sc-in\">26–27\"</span><span class=\"sc-cm\">66–68 cm</span></td><td><span class=\"sc-in\">24–26\"</span><span class=\"sc-cm\">62–66 cm</span></td></tr>\n            <tr><td>11–12 yr</td><td>160</td><td><span class=\"sc-in\">57–60\"</span><span class=\"sc-cm\">146–152 cm</span></td><td><span class=\"sc-in\">28–29\"</span><span class=\"sc-cm\">70–74 cm</span></td><td><span class=\"sc-in\">26–28\"</span><span class=\"sc-cm\">66–70 cm</span></td></tr>\n          </tbody>\n        </table>\n        {% else %}\n        <table class=\"ai-size-chart-table-{{ ai_gen_id }}\">\n          <thead><tr><th>Size</th><th>Age</th><th>Height</th><th>Chest</th><th>Garment length</th></tr></thead>\n          <tbody>\n            <tr><td>S</td><td>6 months</td><td><span class=\"sc-in\">25–28\"</span><span class=\"sc-cm\">64–71 cm</span></td><td><span class=\"sc-in\">17–18\"</span><span class=\"sc-cm\">43–45 cm</span></td><td><span class=\"sc-in\">12–13\"</span><span class=\"sc-cm\">30–34 cm</span></td></tr>\n            <tr><td>M</td><td>12 months</td><td><span class=\"sc-in\">28–30\"</span><span class=\"sc-cm\">71–77 cm</span></td><td><span class=\"sc-in\">18–19\"</span><span class=\"sc-cm\">46–48 cm</span></td><td><span class=\"sc-in\">13–15\"</span><span class=\"sc-cm\">34–38 cm</span></td></tr>\n            <tr><td>L</td><td>18 months</td><td><span class=\"sc-in\">31–33\"</span><span class=\"sc-cm\">78–83 cm</span></td><td><span class=\"sc-in\">19–20\"</span><span class=\"sc-cm\">49–51 cm</span></td><td><span class=\"sc-in\">15–16\"</span><span class=\"sc-cm\">38–40 cm</span></td></tr>\n            <tr><td>XL</td><td>2 years</td><td><span class=\"sc-in\">34–36\"</span><span class=\"sc-cm\">86–92 cm</span></td><td><span class=\"sc-in\">20–21\"</span><span class=\"sc-cm\">51–53 cm</span></td><td><span class=\"sc-in\">16–17\"</span><span class=\"sc-cm\">40–44 cm</span></td></tr>\n            <tr><td>2XL</td><td>3–4 years</td><td><span class=\"sc-in\">39–43\"</span><span class=\"sc-cm\">98–110 cm</span></td><td><span class=\"sc-in\">21–23\"</span><span class=\"sc-cm\">54–58 cm</span></td><td><span class=\"sc-in\">18–20\"</span><span class=\"sc-cm\">46–52 cm</span></td></tr>\n            <tr><td>3XL</td><td>5–6 years</td><td><span class=\"sc-in\">43–46\"</span><span class=\"sc-cm\">110–116 cm</span></td><td><span class=\"sc-in\">23–24\"</span><span class=\"sc-cm\">58–60 cm</span></td><td><span class=\"sc-in\">21–23\"</span><span class=\"sc-cm\">54–58 cm</span></td></tr>\n          </tbody>\n        </table>\n        {% endif %}\n        <div class=\"ai-size-chart-note-{{ ai_gen_id }}\">\n          Indian kids often run bigger than the age label. When between sizes, always order one size up — our cuts have a relaxed fit.\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  var modal = document.getElementById('kidsmire-size-modal');\n  var openBtn = document.getElementById('kidsmire-size-open');\n  var closeBtn = document.getElementById('kidsmire-size-close');\n  var tableWrap = document.getElementById('kidsmire-table-wrap');\n  var unitBtns = document.querySelectorAll('.ai-size-chart-unit-btn-kidsmire_sizechart');\n\n  function openModal() {\n    modal.classList.add('active');\n    document.body.style.overflow = 'hidden';\n  }\n  function closeModal() {\n    modal.classList.remove('active');\n    document.body.style.overflow = '';\n  }\n\n  if (openBtn) openBtn.addEventListener('click', openModal);\n  if (closeBtn) {\n    closeBtn.addEventListener('click', closeModal);\n    closeBtn.addEventListener('keydown', function(e) {\n      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); closeModal(); }\n    });\n  }\n  if (modal) {\n    modal.addEventListener('click', function(e) {\n      if (e.target === modal) closeModal();\n    });\n  }\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape' && modal && modal.classList.contains('active')) closeModal();\n  });\n\n  unitBtns.forEach(function(btn) {\n    btn.addEventListener('click', function() {\n      var unit = btn.getAttribute('data-unit');\n      if (tableWrap) tableWrap.setAttribute('data-unit', unit);\n      unitBtns.forEach(function(b) {\n        b.setAttribute('aria-pressed', b.getAttribute('data-unit') === unit ? 'true' : 'false');\n      });\n    });\n  });\n})();\n</script>"
