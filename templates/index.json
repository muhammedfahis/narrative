    "custom_liquid_iaafhb": {
      "type": "custom-liquid",
      "name": "shop by collection",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .kmcol {\n    background: #f5f2ee;\n    padding: 80px 48px;\n    margin: 0 !important;\n  }\n\n  .kmcol-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 48px;\n  }\n\n  .kmcol-label {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .kmcol-label-line {\n    width: 28px;\n    height: 1px;\n    background: #c8b89a;\n  }\n\n  .kmcol-label-text {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: rgba(0,0,0,0.35);\n  }\n\n  .kmcol-view-all {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(0,0,0,0.4);\n    text-decoration: none;\n    border-bottom: 0.5px solid rgba(0,0,0,0.2);\n    padding-bottom: 2px;\n  }\n\n  /* Grid: 1 big left + 2 stacked right */\n  .kmcol-grid {\n    display: grid;\n    grid-template-columns: 1.4fr 1fr 1fr;\n    grid-template-rows: 1fr 1fr;\n    gap: 8px;\n    height: 600px;\n  }\n\n  .kmcol-card {\n    position: relative;\n    overflow: hidden;\n    cursor: pointer;\n    background: #e0dbd3;\n    text-decoration: none;\n    display: block;\n  }\n\n  /* Featured card spans both rows */\n  .kmcol-card--featured {\n    grid-row: 1 / 3;\n  }\n\n  .kmcol-card img {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center top;\n    display: block;\n    transition: transform 0.7s ease;\n  }\n\n  .kmcol-card:hover img {\n    transform: scale(1.04);\n  }\n\n  /* Dark gradient at bottom of each card */\n  .kmcol-card::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.1) 45%, transparent 100%);\n    z-index: 1;\n    transition: opacity 0.3s ease;\n  }\n\n  .kmcol-card-info {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    padding: 28px 28px;\n    z-index: 2;\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n  }\n\n  .kmcol-card-name {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 28px;\n    font-weight: 300;\n    color: #f5f2ee;\n    line-height: 1;\n    letter-spacing: -0.3px;\n  }\n\n  .kmcol-card--featured .kmcol-card-name {\n    font-size: 38px;\n  }\n\n  .kmcol-card-count {\n    font-family: 'Inter', sans-serif;\n    font-size: 9px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.45);\n    margin-top: 5px;\n    display: block;\n  }\n\n  .kmcol-card-arrow {\n    width: 36px;\n    height: 36px;\n    border: 0.5px solid rgba(255,255,255,0.25);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n    transition: background 0.2s, border-color 0.2s;\n  }\n\n  .kmcol-card:hover .kmcol-card-arrow {\n    background: rgba(255,255,255,0.15);\n    border-color: rgba(255,255,255,0.5);\n  }\n\n  .kmcol-card-arrow svg {\n    width: 14px;\n    height: 14px;\n    stroke: rgba(255,255,255,0.7);\n    fill: none;\n    stroke-width: 1.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* Placeholder when no image */\n  .kmcol-placeholder {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #d8d3cb;\n  }\n\n  .kmcol-placeholder span {\n    font-family: 'Inter', sans-serif;\n    font-size: 9px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(0,0,0,0.2);\n  }\n\n  @media (max-width: 900px) {\n    .kmcol { padding: 60px 24px; }\n    .kmcol-grid {\n      grid-template-columns: 1fr 1fr;\n      grid-template-rows: auto;\n      height: auto;\n    }\n    .kmcol-card--featured {\n      grid-column: 1 / 3;\n      grid-row: auto;\n      min-height: 320px;\n    }\n    .kmcol-card { min-height: 220px; }\n    .kmcol-card--featured .kmcol-card-name { font-size: 32px; }\n  }\n\n  @media (max-width: 540px) {\n    .kmcol-grid {\n      grid-template-columns: 1fr;\n    }\n    .kmcol-card--featured { grid-column: auto; min-height: 280px; }\n    .kmcol-header { flex-direction: column; align-items: flex-start; gap: 16px; }\n  }\n</style>\n\n<section class=\"kmcol\">\n\n  <div class=\"kmcol-header\">\n    <div class=\"kmcol-label\">\n      <div class=\"kmcol-label-line\"></div>\n      <span class=\"kmcol-label-text\">Shop by collection</span>\n    </div>\n    <a href=\"/collections/all\" class=\"kmcol-view-all\">View all &rarr;</a>\n  </div>\n\n  <div class=\"kmcol-grid\">\n\n    <!-- CARD 1: Girls — featured (spans full height) -->\n    <a href=\"/collections/girls\" class=\"kmcol-card kmcol-card--featured\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0757/6528/5029/files/ChatGPT_Image_Jun_4_2026_10_30_43_AM.png?v=1780553674\"\n        alt=\"Girls collection\"\n        width=\"800\"\n        height=\"1200\"\n        loading=\"lazy\"\n      >\n      <div class=\"kmcol-card-info\">\n        <div>\n          <span class=\"kmcol-card-name\">Girls</span>\n          <span class=\"kmcol-card-count\">21 styles</span>\n        </div>\n        <div class=\"kmcol-card-arrow\">\n          <svg viewBox=\"0 0 24 24\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>\n        </div>\n      </div>\n    </a>\n\n    <!-- CARD 2: Boys -->\n    <a href=\"/collections/boys\" class=\"kmcol-card\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0757/6528/5029/files/ChatGPT_Image_Jun_4_2026_11_09_40_AM_2ada2d1e-e832-40c7-a8d