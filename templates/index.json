        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .kmig {\n    background: #0e0e0e;\n    padding: 80px 48px;\n    margin: 0 !important;\n  }\n\n  .kmig-header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    margin-bottom: 40px;\n  }\n\n  .kmig-label {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .kmig-label-line {\n    width: 28px;\n    height: 1px;\n    background: #c8b89a;\n  }\n\n  .kmig-label-text {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.3);\n  }\n\n  .kmig-title {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 36px;\n    font-weight: 300;\n    color: #f0ece4;\n    margin: 12px 0 0 44px;\n    letter-spacing: -0.3px;\n  }\n\n  .kmig-title em {\n    font-style: italic;\n    color: #c8b89a;\n  }\n\n  .kmig-ig-link {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.35);\n    text-decoration: none;\n    border-bottom: 0.5px solid rgba(255,255,255,0.15);\n    padding-bottom: 2px;\n    white-space: nowrap;\n  }\n\n  /* Masonry-style grid: 5 columns, varying heights */\n  .kmig-grid {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    grid-template-rows: 280px 200px;\n    gap: 6px;\n  }\n\n  /* Photo 1: tall, spans 2 rows */\n  .kmig-item:nth-child(1) {\n    grid-column: 1;\n    grid-row: 1 / 3;\n  }\n\n  /* Photo 2: normal */\n  .kmig-item:nth-child(2) {\n    grid-column: 2;\n    grid-row: 1;\n  }\n\n  /* Photo 3: normal */\n  .kmig-item:nth-child(3) {\n    grid-column: 3;\n    grid-row: 1;\n  }\n\n  /* Photo 4: wide, spans 2 cols bottom */\n  .kmig-item:nth-child(4) {\n    grid-column: 2 / 4;\n    grid-row: 2;\n  }\n\n  /* Photo 5: tall, spans 2 rows right */\n  .kmig-item:nth-child(5) {\n    grid-column: 4 / 6;\n    grid-row: 1 / 3;\n  }\n\n  .kmig-item {\n    position: relative;\n    overflow: hidden;\n    background: #1a1a1a;\n    display: block;\n    text-decoration: none;\n  }\n\n  .kmig-item img {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center;\n    display: block;\n    transition: transform 0.6s ease;\n  }\n\n  .kmig-item:hover img {\n    transform: scale(1.05);\n  }\n\n  /* Hover overlay */\n  .kmig-item-overlay {\n    position: absolute;\n    inset: 0;\n    background: rgba(0,0,0,0);\n    z-index: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.3s ease;\n  }\n\n  .kmig-item:hover .kmig-item-overlay {\n    background: rgba(0,0,0,0.35);\n  }\n\n  .kmig-item-overlay svg {\n    opacity: 0;\n    transform: scale(0.8);\n    transition: opacity 0.3s ease, transform 0.3s ease;\n    width: 28px;\n    height: 28px;\n    stroke: #fff;\n    fill: none;\n    stroke-width: 1.2;\n  }\n\n  .kmig-item:hover .kmig-item-overlay svg {\n    opacity: 1;\n    transform: scale(1);\n  }\n\n  /* Bottom CTA */\n  .kmig-footer {\n    margin-top: 36px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n  }\n\n  .kmig-footer-line {\n    flex: 1;\n    height: 0.5px;\n    background: rgba(255,255,255,0.08);\n  }\n\n  .kmig-follow {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.3);\n    text-decoration: none;\n    padding: 12px 28px;\n    border: 0.5px solid rgba(255,255,255,0.12);\n    transition: border-color 0.2s, color 0.2s;\n    white-space: nowrap;\n  }\n\n  .kmig-follow:hover {\n    border-color: rgba(255,255,255,0.3);\n    color: rgba(255,255,255,0.6);\n  }\n\n  @media (max-width: 900px) {\n    .kmig { padding: 60px 24px; }\n    .kmig-grid {\n      grid-template-columns: repeat(3, 1fr);\n      grid-template-rows: 200px 160px 200px;\n    }\n    .kmig-item:nth-child(1) { grid-column: 1; grid-row: 1 / 3; }\n    .kmig-item:nth-child(2) { grid-column: 2; grid-row: 1; }\n    .kmig-item:nth-child(3) { grid-column: 3; grid-row: 1; }\n    .kmig-item:nth-child(4) { grid-column: 2 / 4; grid-row: 2; }\n    .kmig-item:nth-child(5) { grid-column: 1 / 4; grid-row: 3; }\n    .kmig-title { font-size: 28px; }\n  }\n\n  @media (max-width: 540px) {\n    .kmig-grid {\n      grid-template-columns: 1fr 1fr;\n      grid-template-rows: 180px 180px 180px;\n    }\n    .kmig-item:nth-child(1) { grid-column: 1; grid-row: 1; }\n    .kmig-item:nth-child(2) { grid-column: 2; grid-row: 1; }\n    .kmig-item:nth-child(3) { grid-column: 1; grid-row: 2; }\n    .kmig-item:nth-child(4) { grid-column: 2; grid-row: 2; }\n    .kmig-item:nth-child(5) { grid-column: 1 / 3; grid-row: 3; }\n    .kmig-header { flex-direction: column; align-items: flex-start; gap: 20px; }\n    .kmig-title { margin-left: 44px; font-size: 26px; }\n  }\n</style>\n\n<section class=\"kmig\">\n\n  <div class=\"kmig-header\">\n    <div>\n      <div class=\"kmig-label\">\n        <div class=\"kmig-label-line\"></div>\n        <span class=\"kmig-label-text\">Real life styles</span>\n      </div>\n      <h2 class=\"kmig-title\">Styled by <em>real parents.</em></h2>\n    </div>\n    <a href=\"https://www.instagram.com/kidsmire.official\" target=\"_blank\" class=\"kmig-ig-link\">@kidsmire.official &rarr;</a>\n  </div>\n\n  <div class=\"kmig-grid\">\n\n    <a href=\"https://www.instagram.com/kidsmire.official\" target=\"_blank\" class=\"kmig-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0757/6528/5029/files/IMG_6422.webp?v=1780771389\" alt=\"KIDSMIRE real style\" width=\"600\" 