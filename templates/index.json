        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .kmv5 {\n    position: relative;\n    width: 100%;\n    min-height: 100vh;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    background: #0e0e0e;\n    margin: 0 !important;\n  }\n\n  /* LEFT: image column */\n  .kmv5-img {\n    position: relative;\n    overflow: hidden;\n    min-height: 100vh;\n  }\n\n  .kmv5-img img {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center top;\n    display: block;\n  }\n\n  /* soft right-edge fade into dark */\n  .kmv5-img::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(to right, transparent 50%, #0e0e0e 100%);\n    z-index: 1;\n  }\n\n  /* RIGHT: solid dark content column */\n  .kmv5-content {\n    background: #0e0e0e;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 80px 60px 80px 48px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .kmv5-line {\n    width: 28px;\n    height: 1px;\n    background: #c8b89a;\n    margin-bottom: 28px;\n  }\n\n  .kmv5-eyebrow {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.4);\n    margin: 0 0 20px;\n    display: block;\n  }\n\n  .kmv5-headline {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 56px;\n    font-weight: 300;\n    line-height: 1.05;\n    color: #f0ece4;\n    margin: 0 0 24px;\n    letter-spacing: -0.5px;\n  }\n\n  .kmv5-headline em {\n    font-style: italic;\n    color: #c8b89a;\n    font-weight: 300;\n  }\n\n  .kmv5-sub {\n    font-family: 'Inter', sans-serif;\n    font-size: 13px;\n    font-weight: 300;\n    color: rgba(255,255,255,0.4);\n    line-height: 1.9;\n    max-width: 280px;\n    margin: 0 0 48px;\n    display: block;\n  }\n\n  .kmv5-ctas {\n    display: flex;\n    align-items: center;\n    gap: 28px;\n    margin-bottom: 56px;\n    flex-wrap: wrap;\n  }\n\n  .kmv5-btn-p {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    padding: 16px 40px;\n    background: #f0ece4;\n    color: #111 !important;\n    text-decoration: none !important;\n    display: inline-block;\n  }\n\n  .kmv5-btn-s {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.45) !important;\n    text-decoration: none !important;\n    display: inline-block;\n    border-bottom: 0.5px solid rgba(255,255,255,0.2);\n    padding-bottom: 3px;\n  }\n\n  .kmv5-stats {\n    display: flex;\n    border-top: 0.5px solid rgba(255,255,255,0.08);\n    padding-top: 36px;\n  }\n\n  .kmv5-stat {\n    flex: 1;\n    padding-right: 20px;\n    border-right: 0.5px solid rgba(255,255,255,0.07);\n    margin-right: 20px;\n  }\n\n  .kmv5-stat:last-child {\n    border-right: none;\n    margin-right: 0;\n    padding-right: 0;\n  }\n\n  .kmv5-stat-n {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 28px;\n    font-weight: 300;\n    color: #c8b89a;\n    line-height: 1;\n    display: block;\n    margin-bottom: 6px;\n  }\n\n  .kmv5-stat-l {\n    font-family: 'Inter', sans-serif;\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.22);\n    display: block;\n  }\n\n  /* Marquee */\n  .kmv5-mq {\n    width: 100%;\n    background: #c8b89a;\n    padding: 12px 0;\n    overflow: hidden;\n    white-space: nowrap;\n  }\n\n  .kmv5-mq-inner {\n    display: inline-block;\n    animation: kmv5scroll 24s linear infinite;\n  }\n\n  .kmv5-mq s