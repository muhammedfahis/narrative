troke=\"none\"/></svg>\n      </div>\n    </a>\n\n    <a href=\"https://www.instagram.com/kidsmire.official\" target=\"_blank\" class=\"kmig-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0757/6528/5029/files/656294914_18036866087610685_8695682730135637243_n.jpg?v=1775661055\" alt=\"KIDSMIRE real style\" width=\"800\" height=\"1000\" loading=\"lazy\">\n      <div class=\"kmig-item-overlay\">\n        <svg viewBox=\"0 0 24 24\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\"/><circle cx=\"12\" cy=\"12\" r=\"5\"/><circle cx=\"17.5\" cy=\"6.5\" r=\"1\" fill=\"white\" stroke=\"none\"/></svg>\n      </div>\n    </a>\n\n  </div>\n\n  <div class=\"kmig-footer\">\n    <div class=\"kmig-footer-line\"></div>\n    <a href=\"https://www.instagram.com/kidsmire.official\" target=\"_blank\" class=\"kmig-follow\">Follow on Instagram</a>\n    <div class=\"kmig-footer-line\"></div>\n  </div>\n\n</section>\n\n<script>\n  document.querySelector('.kmig').closest('.shopify-section').style.cssText='margin:0!important;padding:0!important;';\n</script>",
