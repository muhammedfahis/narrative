    "custom_liquid_jFGr9B": {
      "type": "custom-liquid",
      "name": "why parents",
      "settings": {
        "custom_liquid": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .kmwy {\n    background: #f5f2ee;\n    padding: 80px 48px;\n    margin: 0 !important;\n  }\n\n  .kmwy-header {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    margin-bottom: 56px;\n  }\n\n  .kmwy-header-line {\n    width: 28px;\n    height: 1px;\n    background: #c8b89a;\n    flex-shrink: 0;\n  }\n\n  .kmwy-header-inner {\n    display: flex;\n    align-items: baseline;\n    gap: 20px;\n    flex-wrap: wrap;\n  }\n\n  .kmwy-label {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: rgba(0,0,0,0.35);\n  }\n\n  .kmwy-title {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 36px;\n    font-weight: 300;\n    color: #1a1a1a;\n    letter-spacing: -0.3px;\n    margin: 0;\n    line-height: 1;\n  }\n\n  .kmwy-title em {\n    font-style: italic;\n    color: #c8b89a;\n  }\n\n  /* 4-column grid */\n  .kmwy-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 1px;\n    background: rgba(0,0,0,0.08);\n    border: 1px solid rgba(0,0,0,0.08);\n  }\n\n  .kmwy-card {\n    background: #f5f2ee;\n    padding: 44px 36px 44px;\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n    transition: background 0.25s ease;\n  }\n\n  .kmwy-card:hover {\n    background: #ede9e1;\n  }\n\n  .kmwy-icon {\n    width: 44px;\n    height: 44px;\n    border: 0.5px solid rgba(0,0,0,0.12);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 28px;\n    flex-shrink: 0;\n  }\n\n  .kmwy-icon svg {\n    width: 20px;\n    height: 20px;\n    stroke: #1a1a1a;\n    fill: none;\n    stroke-width: 1.2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    opacity: 0.6;\n  }\n\n  .kmwy-card-num {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 11px;\n    font-weight: 300;\n    color: #c8b89a;\n    letter-spacing: 3px;\n    margin-bottom: 14px;\n    display: block;\n  }\n\n  .kmwy-card-title {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 22px;\n    font-weight: 300;\n    color: #1a1a1a;\n    margin: 0 0 12px;\n    line-height: 1.2;\n    letter-spacing: -0.2px;\n  }\n\n  .kmwy-card-desc {\n    font-family: 'Inter', sans-serif;\n    font-size: 12px;\n    font-weight: 300;\n    color: rgba(0,0,0,0.45);\n    line-height: 1.8;\n    margin: 0;\n  }\n\n  .kmwy-card-desc em {\n    font-style: normal;\n    color: rgba(0,0,0,0.65);\n    font-weight: 400;\n  }\n\n  /* Bottom promise strip */\n  .kmwy-strip {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 0;\n    margin-top: 40px;\n    border-top: 0.5px solid rgba(0,0,0,0.08);\n    padding-top: 36px;\n  }\n\n  .kmwy-promise {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding-right: 24px;\n    border-right: 0.5px solid rgba(0,0,0,0.08);\n    margin-right: 24px;\n  }\n\n  .kmwy-promise:last-child {\n    border-right: none;\n    margin-right: 0;\n    padding-right: 0;\n  }\n\n  .kmwy-promise svg {\n    width: 16px;\n    height: 16px;\n    stroke: #c8b89a;\n    fill: none;\n    stroke-width: 1.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    flex-shrink: 0;\n  }\n\n  .kmwy-promise-text {\n    font-family: 'Inter', sans-serif;\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: rgba(0,0,0,0.38);\n  }\n\n  @media (max-width: 900px) {\n    .kmwy { padding: 60px 24px; }\n    .kmwy-grid { grid-template-columns: 1fr 1fr; }\n    .kmwy-strip { grid-template-columns: 1fr 1fr; gap: 20px; }\n    .kmwy-promise { border-right: none; margin-right: 0; padding-right: 0; }\n  }\n\n  @media (max-width: 540px) {\n    .kmwy-grid { grid-template-columns: 1fr; }\n    .kmwy-strip { grid-template-columns: 1fr; }\n    .kmwy-title { font-size: 28px; }\n  }\n</style>\n\n<section class=\"kmwy\">\n\n  <div class=\"kmwy-header\">\n    <div class=\"kmwy-header-line\"></div>\n    <div class=\"kmwy-header-inner\">\n      <span class=\"kmwy-label\">Why parents choose us</span>\n      <h2 class=\"kmwy-title\">Built for <em>real life.</em></h2>\n    </div>\n  </div>\n\n  <div class=\"kmwy-grid\">\n\n    <!-- 01 Soft Fabrics -->\n    <div class=\"kmwy-card\">\n      <div class=\"kmwy-icon\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z\"/>\n          <path d=\"M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4-4-1.79-4-4z\"/>\n        </svg>\n      </div>\n      <span class=\"kmwy-card-num\">01</span>\n      <h3 class=\"kmwy-card-title\">Super soft fabrics</h3>\n      <p class=\"kmwy-card-desc\">100% cotton & denim — <em>no synthetics, ever.</em> Gentle on sensitive skin, tough enough for every adventure.</p>\n    </div>\n\n    <!-- 02 Styles -->\n    <div class=\"kmwy-card\">\n      <div class=\"kmwy-icon\">\n        <svg viewBox=\"0 0 24 24\">\n          <polyline points=\"21 8 21 21 3 21 3 8\"/>\n          <rect x=\"1\" y=\"3\" width=\"22\" height=\"5\"/>\n          <line x1=\"10\" y1=\"12\" x2=\"14\" y2=\"12\"/>\n        </svg>\n      </div>\n      <span class=\"kmwy-card-num\">02</span>\n      <h3 class=\"kmwy-card-title\">Styles for every moment</h3>\n      <p class=\"kmwy-card-desc\">From <em>birthday parties</em> to lazy Sundays — one wardrobe that works for every occasion, no compromise.</p>\n    </div>\n\n    <!-- 03 Pricing -->\n    <div class=\"kmwy-card\">\n      <div class=\"kmwy-icon\">\n        <svg viewBox=\"0 0 24 24\">\n          <line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"23\"/>\n          <path d=\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"/>\n        </svg>\n      </div>\n      <span class=\"kmwy-card-num\">03</span>\n      <h3 class=\"kmwy-card-title\">Starting at ₹330</h3>\n      <p class=\"kmwy-card-desc\">Premium quality shouldn't cost a fortune. <em>Great style is for every family</em> — not just a few.</p>\n    </div>\n\n    <!-- 04 Age Range -->\n    <div class=\"kmwy-card\">\n      <div class=\"kmwy-icon\">\n        <svg viewBox=\"0 0 24 24\">\n          <circle cx=\"12\" cy=\"7\" r=\"4\"/>\n          <path d=\"M5.5 21a7.5 7.5 0 0 1 13 0\"/>\n          <line x1=\"4\" y1=\"11\" x2=\"4\" y2=\"21\"/>\n          <line x1=\"20\" y1=\"11\" x2=\"20\" y2=\"21\"/>\n        </svg>\n      </div>\n      <span class=\"kmwy-card-num\">04</span>\n      <h3 class=\"kmwy-card-title\">6 months to 6 years</h3>\n      <p class=\"kmwy-card-desc\">Every size, every stage. <em>Growing with your little one</em>, every step of the way from newborn to school-ready.</p>\n    </div>\n\n  </div>\n\n  <!-- Promise strip -->\n  <div class=\"kmwy-strip\">\n    <div class=\"kmwy-promise\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M5 12l5 5L20 7\"/></svg>\n      <span class=\"kmwy-promise-text\">7-day easy returns</span>\n    </div>\n    <div class=\"kmwy-promise\">\n      <svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"/><polygon points=\"16 8 20 8 23 11 23 16 16 16 16 8\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>\n      <span class=\"kmwy-promise-text\">Free shipping above ₹999</span>\n    </div>\n    <div class=\"kmwy-promise\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n      <span class=\"kmwy-promise-text\">Quality guaranteed</span>\n    </div>\n    <div class=\"kmwy-promise\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>\n      <span class=\"kmwy-promise-text\">COD available pan-India</span>\n    </div>\n  </div>\n\n</section>\n\n<script>\n  document.querySelector('.kmwy').closest('.shopify-section').style.cssText='margin:0!important;padding:0!important;';\n</script>",
