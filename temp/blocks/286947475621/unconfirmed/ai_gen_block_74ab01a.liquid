{% doc %}
  @prompt
    Create a "Fabric & Material Details" section for the product page that displays fabric/material composition information. It should include: a section heading (e.g., "Fabric & Care"), an icon or visual indicator, a text block for fabric composition (e.g., "100% Organic Cotton"), and optionally care instructions. The design should match a premium kids' boutique aesthetic — clean, minimal, and parent-friendly. It should be customizable via theme editor settings so the merchant can fill in fabric details per product using metafields or static text.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fabric-care-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-fabric-care-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.inner_padding }}px;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-fabric-care-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ block.settings.spacing_after_heading }}px;
  }

  .ai-fabric-care-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
  }

  .ai-fabric-care-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-fabric-care-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.3;
  }

  .ai-fabric-care-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-fabric-care-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-fabric-care-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-fabric-care-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-fabric-care-list-{{ ai_gen_id }} {
    margin: 0;
    padding-left: 20px;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.8;
    color: {{ block.settings.text_color }};
  }

  .ai-fabric-care-list-{{ ai_gen_id }} li {
    margin-bottom: 6px;
  }

  .ai-fabric-care-list-{{ ai_gen_id }} li:last-child {
    margin-bottom: 0;
  }

  .ai-fabric-care-divider-{{ ai_gen_id }} {
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_spacing }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-fabric-care-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-fabric-care-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.9);
    }

    .ai-fabric-care-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }
  }
{% endstyle %}

<fabric-care-{{ ai_gen_id }} class="ai-fabric-care-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fabric-care-container-{{ ai_gen_id }}">
    <div class="ai-fabric-care-header-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <div class="ai-fabric-care-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'fabric' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          {% elsif block.settings.icon_style == 'tag' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
          {% elsif block.settings.icon_style == 'heart' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          {% elsif block.settings.icon_style == 'leaf' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
              <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
            </svg>
          {% elsif block.settings.icon_style == 'sparkles' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
              <path d="M5 3v4"/>
              <path d="M19 17v4"/>
              <path d="M3 5h4"/>
              <path d="M17 19h4"/>
            </svg>
          {% endif %}
        </div>
      {% endif %}
      <h3 class="ai-fabric-care-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    </div>

    <div class="ai-fabric-care-content-{{ ai_gen_id }}">
      {% if block.settings.fabric_composition != blank %}
        <div class="ai-fabric-care-section-{{ ai_gen_id }}">
          {% if block.settings.show_composition_label %}
            <div class="ai-fabric-care-label-{{ ai_gen_id }}">{{ block.settings.composition_label }}</div>
          {% endif %}
          <div class="ai-fabric-care-text-{{ ai_gen_id }}">{{ block.settings.fabric_composition }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_divider and block.settings.fabric_composition != blank and block.settings.care_instructions != blank %}
        <div class="ai-fabric-care-divider-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.care_instructions != blank %}
        <div class="ai-fabric-care-section-{{ ai_gen_id }}">
          {% if block.settings.show_care_label %}
            <div class="ai-fabric-care-label-{{ ai_gen_id }}">{{ block.settings.care_label }}</div>
          {% endif %}
          <div class="ai-fabric-care-text-{{ ai_gen_id }}">{{ block.settings.care_instructions }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_care_symbols %}
        <div class="ai-fabric-care-section-{{ ai_gen_id }}">
          {% if block.settings.show_symbols_label %}
            <div class="ai-fabric-care-label-{{ ai_gen_id }}">{{ block.settings.symbols_label }}</div>
          {% endif %}
          <ul class="ai-fabric-care-list-{{ ai_gen_id }}">
            {% if block.settings.care_symbol_1 != blank %}
              <li>{{ block.settings.care_symbol_1 }}</li>
            {% endif %}
            {% if block.settings.care_symbol_2 != blank %}
              <li>{{ block.settings.care_symbol_2 }}</li>
            {% endif %}
            {% if block.settings.care_symbol_3 != blank %}
              <li>{{ block.settings.care_symbol_3 }}</li>
            {% endif %}
            {% if block.settings.care_symbol_4 != blank %}
              <li>{{ block.settings.care_symbol_4 }}</li>
            {% endif %}
            {% if block.settings.care_symbol_5 != blank %}
              <li>{{ block.settings.care_symbol_5 }}</li>
            {% endif %}
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
</fabric-care-{{ ai_gen_id }}>

<script>
  (function() {
    class FabricCare{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setAttribute('role', 'region');
        this.setAttribute('aria-label', 'Fabric and care information');
      }
    }

    customElements.define('fabric-care-{{ ai_gen_id }}', FabricCare{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fabric & care",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fabric & Care"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "spacing_after_heading",
      "label": "Space after heading",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "fabric",
          "label": "Fabric layers"
        },
        {
          "value": "tag",
          "label": "Tag"
        },
        {
          "value": "heart",
          "label": "Heart"
        },
        {
          "value": "leaf",
          "label": "Leaf (eco)"
        },
        {
          "value": "sparkles",
          "label": "Sparkles (premium)"
        }
      ],
      "default": "fabric"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#334fb4"
    },
    {
      "type": "header",
      "content": "Fabric composition"
    },
    {
      "type": "checkbox",
      "id": "show_composition_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "composition_label",
      "label": "Label",
      "default": "Material"
    },
    {
      "type": "textarea",
      "id": "fabric_composition",
      "label": "Fabric composition",
      "default": "100% Organic Cotton",
      "info": "Enter fabric details or use product metafields"
    },
    {
      "type": "header",
      "content": "Care instructions"
    },
    {
      "type": "checkbox",
      "id": "show_care_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "care_label",
      "label": "Label",
      "default": "Care"
    },
    {
      "type": "textarea",
      "id": "care_instructions",
      "label": "Care instructions",
      "default": "Machine wash cold with like colors. Tumble dry low. Do not bleach.",
      "info": "General care instructions for this product"
    },
    {
      "type": "header",
      "content": "Care symbols"
    },
    {
      "type": "checkbox",
      "id": "show_care_symbols",
      "label": "Show care symbols list",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_symbols_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "symbols_label",
      "label": "Label",
      "default": "Care symbols"
    },
    {
      "type": "text",
      "id": "care_symbol_1",
      "label": "Symbol 1",
      "default": "Machine wash cold (30°C)"
    },
    {
      "type": "text",
      "id": "care_symbol_2",
      "label": "Symbol 2",
      "default": "Do not bleach"
    },
    {
      "type": "text",
      "id": "care_symbol_3",
      "label": "Symbol 3",
      "default": "Tumble dry low"
    },
    {
      "type": "text",
      "id": "care_symbol_4",
      "label": "Symbol 4",
      "default": "Iron on low heat"
    },
    {
      "type": "text",
      "id": "care_symbol_5",
      "label": "Symbol 5"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "inner_padding",
      "label": "Inner padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Content spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "label": "Divider spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8e8e8"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Fabric & care"
    }
  ]
}
{% endschema %}
