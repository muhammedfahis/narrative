{% doc %}
  @prompt
    Create a collapsible "Material & Fabric" section block for the product page that dynamically reads from the product metafield custom.material (multi-line text type). It should display as an accordion/collapsible row with a heading "Material & Fabric" that expands to show the fabric composition details stored in the metafield. If the metafield is empty, hide the section entirely. Design should be clean, minimal, and premium — matching a kids' boutique brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if product.metafields.custom.material != blank %}
  {% style %}
    .ai-material-accordion-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      border-top: 1px solid rgba(18, 18, 18, 0.1);
    }

    .ai-material-accordion__button-{{ ai_gen_id }} {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: {{ block.settings.padding_vertical }}px 0;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
      font-weight: {{ block.settings.heading_font.weight }};
      font-size: {{ block.settings.heading_size }}px;
      color: {{ block.settings.heading_color }};
      transition: opacity 0.2s ease;
    }

    .ai-material-accordion__button-{{ ai_gen_id }}:hover {
      opacity: 0.7;
    }

    .ai-material-accordion__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size }}px;
      height: {{ block.settings.icon_size }}px;
      flex-shrink: 0;
      transition: transform 0.3s ease;
      color: {{ block.settings.icon_color }};
    }

    .ai-material-accordion__button-{{ ai_gen_id }}[aria-expanded="true"] .ai-material-accordion__icon-{{ ai_gen_id }} {
      transform: rotate(180deg);
    }

    .ai-material-accordion__content-{{ ai_gen_id }} {
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      transition: max-height 0.4s ease, opacity 0.3s ease, padding 0.3s ease;
    }

    .ai-material-accordion__content-{{ ai_gen_id }}.active {
      max-height: 500px;
      opacity: 1;
      padding-bottom: {{ block.settings.padding_vertical }}px;
    }

    .ai-material-accordion__text-{{ ai_gen_id }} {
      font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
      font-weight: {{ block.settings.text_font.weight }};
      font-size: {{ block.settings.text_size }}px;
      line-height: 1.6;
      color: {{ block.settings.text_color }};
      white-space: pre-line;
    }
  {% endstyle %}

  <material-accordion-{{ ai_gen_id }}
    class="ai-material-accordion-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <button
      class="ai-material-accordion__button-{{ ai_gen_id }}"
      aria-expanded="false"
      aria-controls="ai-material-content-{{ ai_gen_id }}"
    >
      <span>{{ block.settings.heading_text }}</span>
      <svg
        class="ai-material-accordion__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>

    <div
      id="ai-material-content-{{ ai_gen_id }}"
      class="ai-material-accordion__content-{{ ai_gen_id }}"
      role="region"
    >
      <div class="ai-material-accordion__text-{{ ai_gen_id }}">
        {{ product.metafields.custom.material }}
      </div>
    </div>
  </material-accordion-{{ ai_gen_id }}>

  <script>
    (function() {
      class MaterialAccordion{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.button = this.querySelector('.ai-material-accordion__button-{{ ai_gen_id }}');
          this.content = this.querySelector('.ai-material-accordion__content-{{ ai_gen_id }}');

          if (this.button && this.content) {
            this.button.addEventListener('click', () => this.toggle());
          }
        }

        toggle() {
          const isExpanded = this.button.getAttribute('aria-expanded') === 'true';

          this.button.setAttribute('aria-expanded', !isExpanded);
          this.content.classList.toggle('active');
        }
      }

      customElements.define('material-accordion-{{ ai_gen_id }}', MaterialAccordion{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Material & fabric",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays fabric composition from product.metafields.custom.material. Hidden if metafield is empty."
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Material & Fabric"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Material & fabric"
    }
  ]
}
{% endschema %}
