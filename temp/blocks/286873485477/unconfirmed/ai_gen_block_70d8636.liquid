{% doc %}
  @prompt
    Redesign the existing discount promotional section on the homepage to be smaller, more compact, and visually attractive. It should display "🎉 Extra 10% off your first order! Use code FIRST10 at checkout" in an elegant, eye-catching style that suits a premium kids' boutique brand (KIDSMIRE). Use a subtle background color, refined typography, a small badge or pill-style code highlight for "FIRST10", and elegant spacing. Keep it minimal and premium — not loud or flashy. Should look great on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-promo-banner__content-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    max-width: 100%;
  }

  .ai-promo-banner__emoji-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1;
  }

  .ai-promo-banner__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    letter-spacing: 0.3px;
    line-height: 1.4;
  }

  .ai-promo-banner__code-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 12px;
    background-color: {{ block.settings.code_bg_color }};
    color: {{ block.settings.code_text_color }};
    font-size: {{ block.settings.code_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.code_radius }}px;
    letter-spacing: 0.5px;
    font-family: monospace;
  }

  @media screen and (max-width: 749px) {
    .ai-promo-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.8 }}px {{ block.settings.horizontal_padding | times: 0.7 }}px;
    }

    .ai-promo-banner__content-{{ ai_gen_id }} {
      gap: 6px;
    }

    .ai-promo-banner__emoji-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-promo-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-promo-banner__code-{{ ai_gen_id }} {
      font-size: {{ block.settings.code_size | times: 0.9 }}px;
      padding: 3px 10px;
    }
  }
{% endstyle %}

<div class="ai-promo-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-banner__content-{{ ai_gen_id }}">
    {% if block.settings.show_emoji %}
      <span class="ai-promo-banner__emoji-{{ ai_gen_id }}">{{ block.settings.emoji }}</span>
    {% endif %}
    <span class="ai-promo-banner__text-{{ ai_gen_id }}">
      {{ block.settings.promo_text_before }}
    </span>
    <span class="ai-promo-banner__code-{{ ai_gen_id }}">{{ block.settings.promo_code }}</span>
    <span class="ai-promo-banner__text-{{ ai_gen_id }}">
      {{ block.settings.promo_text_after }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_emoji",
      "label": "Show emoji",
      "default": true
    },
    {
      "type": "text",
      "id": "emoji",
      "label": "Emoji",
      "default": "🎉"
    },
    {
      "type": "text",
      "id": "promo_text_before",
      "label": "Text before code",
      "default": "Extra 10% off your first order! Use code"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code",
      "default": "FIRST10"
    },
    {
      "type": "text",
      "id": "promo_text_after",
      "label": "Text after code",
      "default": "at checkout"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fef9f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Code badge"
    },
    {
      "type": "color",
      "id": "code_bg_color",
      "label": "Background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "code_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "code_size",
      "label": "Code size",
      "min": 11,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "code_radius",
      "label": "Code border radius",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Promo banner"
    }
  ]
}
{% endschema %}
