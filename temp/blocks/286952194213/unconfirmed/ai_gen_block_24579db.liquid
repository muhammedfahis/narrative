{% doc %}
  @prompt
    Create a mobile-first "Category Bubbles" section for a premium kids' wear store. The section should display circular image bubbles in a horizontally scrollable row (on mobile) and a centered grid (on desktop). Each bubble should have a circular cropped image on top and a short category label below (e.g., Boys, Girls, New Arrivals, Sale). The bubbles should link to their respective collections. Style should be clean and boutique — soft shadows, subtle hover effects, and a playful but premium feel. The section should be fully customizable in the theme editor, allowing merchants to add/remove bubbles, change images, labels, and collection links. Aim for 4–6 bubbles by default.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-bubbles-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_mobile }}px 0;
  }

  .ai-category-bubbles__container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .ai-category-bubbles__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size_mobile }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
  }

  .ai-category-bubbles__scroll-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-category-bubbles__scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-category-bubbles__grid-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.bubble_spacing_mobile }}px;
    padding: 8px 0;
  }

  .ai-category-bubbles__item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.bubble_size_mobile }}px;
    text-align: center;
  }

  .ai-category-bubbles__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-category-bubbles__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.bubble_size_mobile }}px;
    height: {{ block.settings.bubble_size_mobile }}px;
    margin: 0 auto {{ block.settings.label_spacing }}px;
    border-radius: 50%;
    overflow: hidden;
    background-color: {{ block.settings.bubble_background }};
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-category-bubbles__link-{{ ai_gen_id }}:hover .ai-category-bubbles__image-wrapper-{{ ai_gen_id }} {
    transform: translateY(-4px);
    box-shadow: 0 {{ block.settings.shadow_vertical | plus: 4 }}px {{ block.settings.shadow_blur | plus: 4 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.2 | at_most: 0.3 }});
  }

  .ai-category-bubbles__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-bubbles__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-category-bubbles__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-bubbles__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size_mobile }}px;
    color: {{ block.settings.label_color }};
    font-weight: 500;
    line-height: 1.3;
    word-wrap: break-word;
    transition: color 0.3s ease;
  }

  .ai-category-bubbles__link-{{ ai_gen_id }}:hover .ai-category-bubbles__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_hover_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-category-bubbles-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 0;
    }

    .ai-category-bubbles__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }

    .ai-category-bubbles__scroll-wrapper-{{ ai_gen_id }} {
      overflow: visible;
    }

    .ai-category-bubbles__grid-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax({{ block.settings.bubble_size_desktop }}px, 1fr));
      justify-items: center;
      gap: {{ block.settings.bubble_spacing_desktop }}px;
      max-width: {{ block.settings.max_bubbles_per_row | times: block.settings.bubble_size_desktop | plus: block.settings.bubble_spacing_desktop | times: block.settings.max_bubbles_per_row | minus: block.settings.bubble_spacing_desktop }}px;
      margin: 0 auto;
    }

    .ai-category-bubbles__item-{{ ai_gen_id }} {
      width: {{ block.settings.bubble_size_desktop }}px;
    }

    .ai-category-bubbles__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.bubble_size_desktop }}px;
      height: {{ block.settings.bubble_size_desktop }}px;
    }

    .ai-category-bubbles__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size_desktop }}px;
    }
  }
{% endstyle %}

<category-bubbles-{{ ai_gen_id }} class="ai-category-bubbles-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-category-bubbles__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-category-bubbles__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-category-bubbles__scroll-wrapper-{{ ai_gen_id }}">
      <div class="ai-category-bubbles__grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign label_key = 'label_' | append: i
            assign image_key = 'image_' | append: i
            assign enabled_key = 'enable_bubble_' | append: i

            assign collection = block.settings[collection_key]
            assign label = block.settings[label_key]
            assign image = block.settings[image_key]
            assign enabled = block.settings[enabled_key]
          %}

          {% if enabled %}
            <div class="ai-category-bubbles__item-{{ ai_gen_id }}">
              {% if collection != blank %}
                <a href="{{ collection.url }}" class="ai-category-bubbles__link-{{ ai_gen_id }}">
              {% else %}
                <div class="ai-category-bubbles__link-{{ ai_gen_id }}">
              {% endif %}
                
                <div class="ai-category-bubbles__image-wrapper-{{ ai_gen_id }}">
                  {% if image != blank %}
                    <img
                      src="{{ image | image_url: width: 400 }}"
                      alt="{{ label | escape }}"
                      class="ai-category-bubbles__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {% elsif collection != blank and collection.featured_image %}
                    <img
                      src="{{ collection.featured_image | image_url: width: 400 }}"
                      alt="{{ label | default: collection.title | escape }}"
                      class="ai-category-bubbles__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {% else %}
                    <div class="ai-category-bubbles__placeholder-{{ ai_gen_id }}">
                      {{ 'collection-apparel-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-category-bubbles__label-{{ ai_gen_id }}">
                  {% if label != blank %}
                    {{ label }}
                  {% elsif collection != blank %}
                    {{ collection.title }}
                  {% else %}
                    Category {{ i }}
                  {% endif %}
                </div>

              {% if collection != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</category-bubbles-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryBubbles{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        const scrollWrapper = this.querySelector('.ai-category-bubbles__scroll-wrapper-{{ ai_gen_id }}');
        
        if (!scrollWrapper) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        scrollWrapper.addEventListener('mousedown', (e) => {
          if (window.innerWidth >= 750) return;
          isDown = true;
          scrollWrapper.style.cursor = 'grabbing';
          startX = e.pageX - scrollWrapper.offsetLeft;
          scrollLeft = scrollWrapper.scrollLeft;
        });

        scrollWrapper.addEventListener('mouseleave', () => {
          isDown = false;
          scrollWrapper.style.cursor = 'grab';
        });

        scrollWrapper.addEventListener('mouseup', () => {
          isDown = false;
          scrollWrapper.style.cursor = 'grab';
        });

        scrollWrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - scrollWrapper.offsetLeft;
          const walk = (x - startX) * 2;
          scrollWrapper.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('category-bubbles-{{ ai_gen_id }}', CategoryBubbles{{ ai_gen_id }});
  })();
</script>

