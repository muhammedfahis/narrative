{% doc %}
  @prompt
    Create a product page size chart popup block for a kids clothing store (Kidsmire). It should work as follows:
    
    1. A small clickable link/button that says "📏 Find My Size" placed just above the size selector buttons on the product page. It should be subtle — not a full button, more like a text link with the tape measure emoji.
    
    2. Clicking it opens a clean modal/popup overlay (no page navigation) with:
       - A heading "Find the Perfect Fit"
       - A size chart TABLE with these columns: Size | Age | Height (inches) | Height (cm) | Chest (inches) | Chest (cm) | Garment Length (inches)
       - Rows for: 6-12M | 6-12 months | 26-29" | 66-74cm | 17-18" | 43-46cm | 11" / 12-18M | 12-18 months | 29-31" | 74-79cm | 18-19" | 46-48cm | 12" / 18-24M | 18-24 months | 31-33" | 79-84cm | 19-20" | 48-51cm | 13" / 2-3Y | 2-3 years | 33-37" | 84-94cm | 20-21" | 51-53cm | 14" / 3-4Y | 3-4 years | 37-40" | 94-102cm | 21-22" | 53-56cm | 15" / 4-5Y | 4-5 years | 40-43" | 102-109cm | 22-23" | 56-58cm | 16" / 5-6Y | 5-6 years | 43-47" | 109-119cm | 23-24" | 58-61cm | 17"
       - A "How to Measure" section below the table with a simple SVG child silhouette showing 3 measurement points: (1) Height: top of head to floor, (2) Chest: fullest part of chest, (3) Garment Length: shoulder seam to hem.
       - A tip note at the bottom: "💡 Tip: If your child is between sizes, we recommend sizing up for a comfortable, room-to-grow fit."
       - A close button (X) at the top right of the popup.
    
    3. The popup should have a clean white background, soft rounded corners, subtle shadow, and be fully mobile responsive (full screen on mobile, centered modal on desktop).
    
    4. The table should have alternating row colors (very light pastel) and be horizontally scrollable on mobile.
    
    Make it a standalone Shopify theme block that can be added to the product page template.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-chart-trigger-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    padding: 0;
    margin: 0 0 12px 0;
    font-size: 14px;
    color: {{ block.settings.link_color }};
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
  }

  .ai-size-chart-trigger-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-size-chart-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow-y: auto;
  }

  .ai-size-chart-overlay-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-size-chart-modal-{{ ai_gen_id }} {
    background-color: {{ block.settings.modal_bg_color }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    max-width: 900px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    padding: 40px;
  }

  .ai-size-chart-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .ai-size-chart-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-size-chart-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .ai-size-chart-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-size-chart-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 32px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    color: {{ block.settings.table_header_text }};
    padding: 12px 8px;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }

  .ai-size-chart-table-{{ ai_gen_id }} td {
    padding: 12px 8px;
    border-bottom: 1px solid {{ block.settings.table_border_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} tr:nth-child(even) {
    background-color: {{ block.settings.table_row_alt_bg }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} tr:nth-child(odd) {
    background-color: {{ block.settings.modal_bg_color }};
  }

  .ai-size-chart-how-to-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-size-chart-how-to-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
  }

  .ai-size-chart-diagram-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-size-chart-svg-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-size-chart-svg-{{ ai_gen_id }} svg {
    width: 200px;
    height: auto;
  }

  .ai-size-chart-instructions-{{ ai_gen_id }} {
    flex: 1;
    min-width: 250px;
  }

  .ai-size-chart-instruction-{{ ai_gen_id }} {
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.5;
  }

  .ai-size-chart-instruction-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-size-chart-tip-{{ ai_gen_id }} {
    background-color: {{ block.settings.tip_bg_color }};
    border-left: 4px solid {{ block.settings.tip_border_color }};
    padding: 16px;
    border-radius: 4px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-size-chart-modal-{{ ai_gen_id }} {
      padding: 24px;
      max-height: 100vh;
      border-radius: 0;
    }

    .ai-size-chart-title-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-size-chart-table-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .ai-size-chart-table-{{ ai_gen_id }} th,
    .ai-size-chart-table-{{ ai_gen_id }} td {
      padding: 8px 6px;
    }

    .ai-size-chart-svg-{{ ai_gen_id }} svg {
      width: 150px;
    }
  }
{% endstyle %}

<size-chart-{{ ai_gen_id }} {{ block.shopify_attributes }}>
  <button
    class="ai-size-chart-trigger-{{ ai_gen_id }}"
    aria-label="Open size chart"
  >
    <span>{{ block.settings.trigger_text }}</span>
  </button>

  <div class="ai-size-chart-overlay-{{ ai_gen_id }}">
    <div class="ai-size-chart-modal-{{ ai_gen_id }}">
      <div class="ai-size-chart-header-{{ ai_gen_id }}">
        <h2 class="ai-size-chart-title-{{ ai_gen_id }}">{{ block.settings.modal_heading }}</h2>
        <button
          class="ai-size-chart-close-{{ ai_gen_id }}"
          aria-label="Close size chart"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <div class="ai-size-chart-table-wrapper-{{ ai_gen_id }}">
        <table class="ai-size-chart-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>Size</th>
              <th>Age</th>
              <th>Height (in)</th>
              <th>Height (cm)</th>
              <th>Chest (in)</th>
              <th>Chest (cm)</th>
              <th>Garment Length (in)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>6-12M</td>
              <td>6-12 months</td>
              <td>26-29"</td>
              <td>66-74cm</td>
              <td>17-18"</td>
              <td>43-46cm</td>
              <td>11"</td>
            </tr>
            <tr>
              <td>12-18M</td>
              <td>12-18 months</td>
              <td>29-31"</td>
              <td>74-79cm</td>
              <td>18-19"</td>
              <td>46-48cm</td>
              <td>12"</td>
            </tr>
            <tr>
              <td>18-24M</td>
              <td>18-24 months</td>
              <td>31-33"</td>
              <td>79-84cm</td>
              <td>19-20"</td>
              <td>48-51cm</td>
              <td>13"</td>
            </tr>
            <tr>
              <td>2-3Y</td>
              <td>2-3 years</td>
              <td>33-37"</td>
              <td>84-94cm</td>
              <td>20-21"</td>
              <td>51-53cm</td>
              <td>14"</td>
            </tr>
            <tr>
              <td>3-4Y</td>
              <td>3-4 years</td>
              <td>37-40"</td>
              <td>94-102cm</td>
              <td>21-22"</td>
              <td>53-56cm</td>
              <td>15"</td>
            </tr>
            <tr>
              <td>4-5Y</td>
              <td>4-5 years</td>
              <td>40-43"</td>
              <td>102-109cm</td>
              <td>22-23"</td>
              <td>56-58cm</td>
              <td>16"</td>
            </tr>
            <tr>
              <td>5-6Y</td>
              <td>5-6 years</td>
              <td>43-47"</td>
              <td>109-119cm</td>
              <td>23-24"</td>
              <td>58-61cm</td>
              <td>17"</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="ai-size-chart-how-to-{{ ai_gen_id }}">
        <h3 class="ai-size-chart-how-to-title-{{ ai_gen_id }}">How to Measure</h3>
        <div class="ai-size-chart-diagram-{{ ai_gen_id }}">
          <div class="ai-size-chart-svg-{{ ai_gen_id }}">
            <svg viewBox="0 0 200 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="100" cy="30" r="20" fill="#FFE5E5" stroke="#FF6B5B" stroke-width="2"/>
              <line x1="100" y1="50" x2="100" y2="120" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="100" y1="70" x2="70" y2="100" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="100" y1="70" x2="130" y2="100" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="100" y1="120" x2="80" y2="180" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="100" y1="120" x2="120" y2="180" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="80" y1="180" x2="80" y2="240" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="120" y1="180" x2="120" y2="240" stroke="#FF6B5B" stroke-width="3"/>
              <line x1="10" y1="10" x2="10" y2="250" stroke="#121212" stroke-width="1" stroke-dasharray="3 3"/>
              <line x1="5" y1="10" x2="15" y2="10" stroke="#121212" stroke-width="2"/>
              <line x1="5" y1="250" x2="15" y2="250" stroke="#121212" stroke-width="2"/>
              <text x="20" y="130" font-size="12" fill="#121212" font-weight="600">1</text>
              <line x1="60" y1="75" x2="140" y2="75" stroke="#334FB4" stroke-width="1" stroke-dasharray="3 3"/>
              <line x1="60" y1="70" x2="60" y2="80" stroke="#334FB4" stroke-width="2"/>
              <line x1="140" y1="70" x2="140" y2="80" stroke="#334FB4" stroke-width="2"/>
              <text x="145" y="80" font-size="12" fill="#334FB4" font-weight="600">2</text>
              <line x1="150" y1="50" x2="150" y2="120" stroke="#FF9F40" stroke-width="1" stroke-dasharray="3 3"/>
              <line x1="145" y1="50" x2="155" y2="50" stroke="#FF9F40" stroke-width="2"/>
              <line x1="145" y1="120" x2="155" y2="120" stroke="#FF9F40" stroke-width="2"/>
              <text x="160" y="90" font-size="12" fill="#FF9F40" font-weight="600">3</text>
            </svg>
          </div>
          <div class="ai-size-chart-instructions-{{ ai_gen_id }}">
            <div class="ai-size-chart-instruction-{{ ai_gen_id }}">
              <strong>1. Height:</strong> Measure from the top of the head to the floor with your child standing straight.
            </div>
            <div class="ai-size-chart-instruction-{{ ai_gen_id }}">
              <strong>2. Chest:</strong> Measure around the fullest part of the chest, keeping the tape measure level.
            </div>
            <div class="ai-size-chart-instruction-{{ ai_gen_id }}">
              <strong>3. Garment Length:</strong> Measure from the shoulder seam to the desired hem length.
            </div>
          </div>
        </div>
      </div>

      <div class="ai-size-chart-tip-{{ ai_gen_id }}">
        {{ block.settings.tip_text }}
      </div>
    </div>
  </div>
</size-chart-{{ ai_gen_id }}>

<script>
  (function() {
    class SizeChart{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.trigger = this.querySelector('.ai-size-chart-trigger-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-size-chart-overlay-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-size-chart-close-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.trigger.addEventListener('click', this.openModal.bind(this));
        this.closeButton.addEventListener('click', this.closeModal.bind(this));
        this.overlay.addEventListener('click', this.handleOverlayClick.bind(this));
        document.addEventListener('keydown', this.handleEscape.bind(this));
      }

      openModal() {
        this.overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closeModal() {
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      handleOverlayClick(event) {
        if (event.target === this.overlay) {
          this.closeModal();
        }
      }

      handleEscape(event) {
        if (event.key === 'Escape' && this.overlay.classList.contains('active')) {
          this.closeModal();
        }
      }

      disconnectedCallback() {
        document.removeEventListener('keydown', this.handleEscape.bind(this));
      }
    }

    customElements.define('size-chart-{{ ai_gen_id }}', SizeChart{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Size chart popup",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Trigger button"
    },
    {
      "type": "text",
      "id": "trigger_text",
      "label": "Button text",
      "default": "📏 Find My Size"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Heading",
      "default": "Find the Perfect Fit"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "modal_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "modal_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Table"
    },
    {
      "type": "color",
      "id": "table_header_bg",
      "label": "Header background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "table_header_text",
      "label": "Header text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "table_row_alt_bg",
      "label": "Alternate row background",
      "default": "#FFF5F5"
    },
    {
      "type": "color",
      "id": "table_border_color",
      "label": "Border color",
      "default": "#F3F3F3"
    },
    {
      "type": "header",
      "content": "Tip section"
    },
    {
      "type": "text",
      "id": "tip_text",
      "label": "Tip text",
      "default": "💡 Tip: If your child is between sizes, we recommend sizing up for a comfortable, room-to-grow fit."
    },
    {
      "type": "color",
      "id": "tip_bg_color",
      "label": "Background color",
      "default": "#FFF9E6"
    },
    {
      "type": "color",
      "id": "tip_border_color",
      "label": "Border color",
      "default": "#FFD740"
    }
  ],
  "presets": [
    {
      "name": "Size chart popup"
    }
  ]
}
{% endschema %}