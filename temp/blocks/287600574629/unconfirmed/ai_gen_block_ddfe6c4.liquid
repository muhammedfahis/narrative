{% doc %}
  @prompt
    Redesign the "Why Parents Choose KIDSMIRE" rich text section into a cheerful, playful, kid-friendly design. Replace the plain text layout with a visually engaging section that feels warm and fun — not a standard fashion brand. Use the following content: Heading: "Why Parents Love KIDSMIRE 💛". Below the heading, display the 4 key selling points as individual feature cards in a 2x2 or 4-column grid (on desktop), each with a large playful emoji icon, a short bold title, and a one-line description. The 4 cards are: 1) 🧸 "Super Soft Fabrics" - Gentle on sensitive skin, tough enough for playtime. 2) 👗 "Styles for Every Moment" - From birthday parties to lazy Sundays. 3) 💰 "Starting at just ₹330" - Because great style shouldn't cost a fortune. 4) 📏 "6 Months to 6 Years" - Growing with your little one, every step of the way. Below the cards, add a warm closing line: "Whether it's playtime, parties, or everyday adventures — KIDSMIRE makes dressing up the fun part. 🎉". Use a white or very light pastel background. Cards should have soft rounded corners, a subtle pastel-colored background each (e.g. soft pink, soft yellow, soft blue, soft green), and a gentle box shadow. Typography should be friendly and rounded. Fully responsive for mobile — cards stack to 2 columns then 1 column on small screens., it got completely for kids. but our customers are parents not kids itself. so a little bit being starndard will make it better
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-kidsmire-features-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-kidsmire-features__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-kidsmire-features__heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .ai-kidsmire-features__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.closing_spacing }}px;
  }

  .ai-kidsmire-features__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .ai-kidsmire-features__card-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 1.5 }});
    border-color: {{ block.settings.card_border_hover_color }};
  }

  .ai-kidsmire-features__icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: block;
    opacity: 0.9;
  }

  .ai-kidsmire-features__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
    line-height: 1.4;
  }

  .ai-kidsmire-features__card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-kidsmire-features__closing-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.closing_size }}px;
    color: {{ block.settings.closing_color }};
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
    font-weight: 400;
  }

  @media screen and (max-width: 989px) {
    .ai-kidsmire-features__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-kidsmire-features__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-kidsmire-features__icon-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.icon_size }}px * 0.9);
    }

    .ai-kidsmire-features__card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.95);
    }
  }

  @media screen and (max-width: 589px) {
    .ai-kidsmire-features__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }

    .ai-kidsmire-features__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.75);
    }

    .ai-kidsmire-features__card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.85 }}px;
    }

    .ai-kidsmire-features__closing-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.closing_size }}px * 0.95);
    }
  }
{% endstyle %}

<kidsmire-features-{{ ai_gen_id }} class="ai-kidsmire-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-kidsmire-features__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-kidsmire-features__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-kidsmire-features__grid-{{ ai_gen_id }}">
      <div class="ai-kidsmire-features__card-{{ ai_gen_id }}">
        <span class="ai-kidsmire-features__icon-{{ ai_gen_id }}">{{ block.settings.card_1_icon }}</span>
        <h3 class="ai-kidsmire-features__card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-kidsmire-features__card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</p>
      </div>

      <div class="ai-kidsmire-features__card-{{ ai_gen_id }}">
        <span class="ai-kidsmire-features__icon-{{ ai_gen_id }}">{{ block.settings.card_2_icon }}</span>
        <h3 class="ai-kidsmire-features__card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-kidsmire-features__card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</p>
      </div>

      <div class="ai-kidsmire-features__card-{{ ai_gen_id }}">
        <span class="ai-kidsmire-features__icon-{{ ai_gen_id }}">{{ block.settings.card_3_icon }}</span>
        <h3 class="ai-kidsmire-features__card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-kidsmire-features__card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</p>
      </div>

      <div class="ai-kidsmire-features__card-{{ ai_gen_id }}">
        <span class="ai-kidsmire-features__icon-{{ ai_gen_id }}">{{ block.settings.card_4_icon }}</span>
        <h3 class="ai-kidsmire-features__card-title-{{ ai_gen_id }}">{{ block.settings.card_4_title }}</h3>
        <p class="ai-kidsmire-features__card-description-{{ ai_gen_id }}">{{ block.settings.card_4_description }}</p>
      </div>
    </div>

    {% if block.settings.closing_text != blank %}
      <p class="ai-kidsmire-features__closing-{{ ai_gen_id }}">
        {{ block.settings.closing_text }}
      </p>
    {% endif %}
  </div>
</kidsmire-features-{{ ai_gen_id }}>

<script>
  (function() {
    class KidsmireFeatures{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-kidsmire-features__card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('kidsmire-features-{{ ai_gen_id }}', KidsmireFeatures{{ ai_gen_id }});
  })();
</script>

