{% doc %}
  @prompt
    Create an Instagram showcase section that is pixel-identical to this design: A section with a heading "Explore more real-life styles & customer moments" centered at the top. Below the heading, show an Instagram profile row with a circular profile picture (using the store logo), the handle "@kidsmire.official" in bold next to it, and a subtitle "Discover real community stories and detailed fabric reviews." in smaller gray text. Below that, display a 5-column grid of Instagram-style photos (2 rows = 10 photos total) with small Instagram username tags (like "@sneha.k.123", "@kaxya.mom") overlaid in the bottom-left corner of select images, styled like Instagram photo tags with a semi-transparent dark background and white text. At the bottom, centered text that reads "explore more detailed looks and community content at instagram.com/kidsmire.official" where "instagram.com/kidsmire.official" is a clickable link. The section should have a white background and clean, minimal styling. The photo grid should accept images via merchant-replaceable image picker blocks with an optional Instagram username field per image. Make it fully responsive for mobile., add a round highlighted like instagram when we add a story around profile pic, can't see the story ring
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-instagram-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-instagram-showcase__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-instagram-showcase__heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.3;
  }

  .ai-instagram-showcase__profile-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: {{ block.settings.profile_spacing }}px;
  }

  .ai-instagram-showcase__profile-pic-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex-shrink: 0;
    padding: {{ block.settings.story_ring_width }}px;
    background: linear-gradient(45deg, 
      {{ block.settings.story_gradient_color_1 }} 0%, 
      {{ block.settings.story_gradient_color_2 }} 50%, 
      {{ block.settings.story_gradient_color_3 }} 100%
    );
    border-radius: 50%;
  }

  .ai-instagram-showcase__profile-pic-{{ ai_gen_id }} {
    width: {{ block.settings.profile_pic_size }}px;
    height: {{ block.settings.profile_pic_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f4f4f4;
    border: 3px solid {{ block.settings.background_color }};
    position: relative;
  }

  .ai-instagram-showcase__profile-pic-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-instagram-showcase__profile-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-instagram-showcase__handle-{{ ai_gen_id }} {
    font-size: {{ block.settings.handle_size }}px;
    font-weight: 700;
    color: {{ block.settings.handle_color }};
    margin: 0;
  }

  .ai-instagram-showcase__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-instagram-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_spacing }}px;
  }

  .ai-instagram-showcase__photo-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-instagram-showcase__photo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-instagram-showcase__photo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-instagram-showcase__photo-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-instagram-showcase__username-tag-{{ ai_gen_id }} {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 500;
    pointer-events: none;
  }

  .ai-instagram-showcase__footer-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.footer_size }}px;
    color: {{ block.settings.footer_color }};
  }

  .ai-instagram-showcase__footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.footer_link_color }};
    text-decoration: none;
    font-weight: 500;
  }

  .ai-instagram-showcase__footer-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-instagram-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-instagram-showcase__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-instagram-showcase__profile-pic-{{ ai_gen_id }} {
      width: calc({{ block.settings.profile_pic_size }}px * 0.85);
      height: calc({{ block.settings.profile_pic_size }}px * 0.85);
    }

    .ai-instagram-showcase__handle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.handle_size }}px * 0.9);
    }

    .ai-instagram-showcase__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-instagram-showcase__footer-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.footer_size }}px * 0.9);
    }
  }
{% endstyle %}

<instagram-showcase-{{ ai_gen_id }} class="ai-instagram-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-instagram-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-instagram-showcase__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-instagram-showcase__profile-{{ ai_gen_id }}">
      {% if block.settings.show_story_ring %}
        <div class="ai-instagram-showcase__profile-pic-wrapper-{{ ai_gen_id }}">
          <div class="ai-instagram-showcase__profile-pic-{{ ai_gen_id }}">
            {% if block.settings.profile_image %}
              <img
                src="{{ block.settings.profile_image | image_url: width: 200 }}"
                alt="{{ block.settings.instagram_handle }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-instagram-showcase__photo-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="ai-instagram-showcase__profile-pic-{{ ai_gen_id }}" style="border: none;">
          {% if block.settings.profile_image %}
            <img
              src="{{ block.settings.profile_image | image_url: width: 200 }}"
              alt="{{ block.settings.instagram_handle }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-instagram-showcase__photo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endif %}
      <div class="ai-instagram-showcase__profile-info-{{ ai_gen_id }}">
        {% if block.settings.instagram_handle != blank %}
          <div class="ai-instagram-showcase__handle-{{ ai_gen_id }}">
            {{ block.settings.instagram_handle }}
          </div>
        {% endif %}
        {% if block.settings.profile_subtitle != blank %}
          <div class="ai-instagram-showcase__subtitle-{{ ai_gen_id }}">
            {{ block.settings.profile_subtitle }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-instagram-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign image_key = 'photo_' | append: i
          assign username_key = 'username_' | append: i
          assign photo = block.settings[image_key]
          assign username = block.settings[username_key]
        %}
        <div class="ai-instagram-showcase__photo-{{ ai_gen_id }}">
          {% if photo %}
            <img
              src="{{ photo | image_url: width: 600 }}"
              alt="{{ username | default: 'Instagram photo' }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {% else %}
            <div class="ai-instagram-showcase__photo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if username != blank %}
            <div class="ai-instagram-showcase__username-tag-{{ ai_gen_id }}">
              {{ username }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.footer_text != blank %}
      <div class="ai-instagram-showcase__footer-{{ ai_gen_id }}">
        {{ block.settings.footer_text }}
        {% if block.settings.footer_link != blank %}
          <a
            href="{{ block.settings.footer_link }}"
            class="ai-instagram-showcase__footer-link-{{ ai_gen_id }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            {{ block.settings.footer_link_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</instagram-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class InstagramShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const photos = this.querySelectorAll('.ai-instagram-showcase__photo-{{ ai_gen_id }}');
        photos.forEach((photo) => {
          photo.setAttribute('role', 'img');
        });
      }
    }

    customElements.define('instagram-showcase-{{ ai_gen_id }}', InstagramShowcase{{ ai_gen_id }});
  })();
</script>

