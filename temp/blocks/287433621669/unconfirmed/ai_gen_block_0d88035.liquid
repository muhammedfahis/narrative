{% doc %}
  @prompt
    Add infinite scroll to the collection product grid. When the customer scrolls to the bottom of the product listing, the next page of products should automatically load and append to the existing grid without a full page reload. Use JavaScript to detect scroll position, fetch the next page via AJAX, and inject the new product cards into the grid. Should work seamlessly with the existing product grid layout and feel smooth and performant.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-infinite-scroll-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-infinite-scroll__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  @media screen and (max-width: 749px) {
    .ai-infinite-scroll__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-infinite-scroll__loader-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.loader_color }};
  }

  .ai-infinite-scroll__loader-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-infinite-scroll__spinner-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.loader_size }}px;
    height: {{ block.settings.loader_size }}px;
    border: 3px solid rgba({{ block.settings.loader_color | color_extract: 'red' }}, {{ block.settings.loader_color | color_extract: 'green' }}, {{ block.settings.loader_color | color_extract: 'blue' }}, 0.2);
    border-top-color: {{ block.settings.loader_color }};
    border-radius: 50%;
    animation: ai-infinite-scroll-spin-{{ ai_gen_id }} 0.8s linear infinite;
  }

  @keyframes ai-infinite-scroll-spin-{{ ai_gen_id }} {
    to {
      transform: rotate(360deg);
    }
  }

  .ai-infinite-scroll__end-message-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.end_message_color }};
    font-size: {{ block.settings.end_message_size }}px;
  }

  .ai-infinite-scroll__end-message-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-infinite-scroll__product-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-infinite-scroll__product-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-infinite-scroll__product-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-infinite-scroll__product-card-{{ ai_gen_id }}:hover .ai-infinite-scroll__product-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-infinite-scroll__product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-infinite-scroll__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    color: {{ block.settings.product_title_color }};
    text-decoration: none;
    margin: 0;
    line-height: 1.3;
  }

  .ai-infinite-scroll__product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.product_title_hover_color }};
  }

  .ai-infinite-scroll__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
  }

  .ai-infinite-scroll__product-price-{{ ai_gen_id }} .price--on-sale {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-infinite-scroll__product-price-{{ ai_gen_id }} .price--compare {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
    font-size: 0.9em;
  }

  .ai-infinite-scroll__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    z-index: 1;
  }
{% endstyle %}

<infinite-scroll-{{ ai_gen_id }}
  class="ai-infinite-scroll-{{ ai_gen_id }}"
  data-collection-url="{{ collection.url }}"
  data-current-page="1"
  data-total-pages="{{ paginate.pages }}"
  data-threshold="{{ block.settings.scroll_threshold }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-infinite-scroll__grid-{{ ai_gen_id }}" id="ai-product-grid-{{ ai_gen_id }}">
    {% for product in collection.products limit: block.settings.products_per_page %}
      <div class="ai-infinite-scroll__product-card-{{ ai_gen_id }}">
        <a href="{{ product.url }}" class="ai-infinite-scroll__product-image-{{ ai_gen_id }}">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {% else %}
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if product.compare_at_price > product.price %}
            <span class="ai-infinite-scroll__badge-{{ ai_gen_id }}">Sale</span>
          {% endif %}
        </a>
        <div class="ai-infinite-scroll__product-info-{{ ai_gen_id }}">
          <a href="{{ product.url }}" class="ai-infinite-scroll__product-title-{{ ai_gen_id }}">
            {{ product.title }}
          </a>
          <div class="ai-infinite-scroll__product-price-{{ ai_gen_id }}">
            {% if product.compare_at_price > product.price %}
              <span class="price--on-sale">{{ product.price | money }}</span>
              <span class="price--compare">{{ product.compare_at_price | money }}</span>
            {% else %}
              <span>{{ product.price | money }}</span>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="ai-infinite-scroll__loader-{{ ai_gen_id }}" id="ai-loader-{{ ai_gen_id }}">
    <div class="ai-infinite-scroll__spinner-{{ ai_gen_id }}"></div>
    {% if block.settings.loading_text != blank %}
      <p style="margin-top: 16px;">{{ block.settings.loading_text }}</p>
    {% endif %}
  </div>

  <div class="ai-infinite-scroll__end-message-{{ ai_gen_id }}" id="ai-end-message-{{ ai_gen_id }}">
    {{ block.settings.end_message }}
  </div>
</infinite-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class InfiniteScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage = 1;
        this.totalPages = parseInt(this.dataset.totalPages) || 1;
        this.collectionUrl = this.dataset.collectionUrl;
        this.threshold = parseInt(this.dataset.threshold) || 300;
        this.isLoading = false;
        this.hasMorePages = this.currentPage < this.totalPages;
        
        this.grid = this.querySelector('#ai-product-grid-{{ ai_gen_id }}');
        this.loader = this.querySelector('#ai-loader-{{ ai_gen_id }}');
        this.endMessage = this.querySelector('#ai-end-message-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupScrollListener();
      }

      setupScrollListener() {
        let ticking = false;
        
        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              this.checkScrollPosition();
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      checkScrollPosition() {
        if (this.isLoading || !this.hasMorePages) return;

        const scrollPosition = window.innerHeight + window.scrollY;
        const documentHeight = document.documentElement.scrollHeight;
        const distanceFromBottom = documentHeight - scrollPosition;

        if (distanceFromBottom < this.threshold) {
          this.loadNextPage();
        }
      }

      async loadNextPage() {
        if (this.isLoading || !this.hasMorePages) return;

        this.isLoading = true;
        this.loader.classList.add('active');

        try {
          const nextPage = this.currentPage + 1;
          const url = `${this.collectionUrl}?page=${nextPage}`;
          
          const response = await fetch(url);
          const html = await response.text();
          
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          
          const newProducts = doc.querySelectorAll('.ai-infinite-scroll__product-card-{{ ai_gen_id }}');
          
          if (newProducts.length > 0) {
            newProducts.forEach(product => {
              this.grid.appendChild(product.cloneNode(true));
            });
            
            this.currentPage = nextPage;
            this.hasMorePages = this.currentPage < this.totalPages;
            
            if (!this.hasMorePages) {
              this.endMessage.classList.add('active');
            }
          } else {
            this.hasMorePages = false;
            this.endMessage.classList.add('active');
          }
        } catch (error) {
          console.error('Error loading products:', error);
        } finally {
          this.isLoading = false;
          this.loader.classList.remove('active');
        }
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.checkScrollPosition);
      }
    }

    customElements.define('infinite-scroll-{{ ai_gen_id }}', InfiniteScroll{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Infinite scroll products",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Grid gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 50,
      "step": 2,
      "label": "Products per page",
      "default": 12
    },
    {
      "type": "header",
      "content": "Scroll behavior"
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Load distance from bottom",
      "default": 300
    },
    {
      "type": "header",
      "content": "Product card style"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 4
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "product_title_hover_color",
      "label": "Title hover color",
      "default": "#ff6b5b"
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 16
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Price color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale price color",
      "default": "#ff6b5b"
    },
    {
      "type": "header",
      "content": "Sale badge"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Background color",
      "default": "#ff6b5b"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Loading indicator"
    },
    {
      "type": "range",
      "id": "loader_size",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Loader size",
      "default": 40
    },
    {
      "type": "color",
      "id": "loader_color",
      "label": "Loader color",
      "default": "#121212"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading text",
      "default": "Loading more products..."
    },
    {
      "type": "header",
      "content": "End message"
    },
    {
      "type": "text",
      "id": "end_message",
      "label": "End message",
      "default": "You've viewed all products"
    },
    {
      "type": "range",
      "id": "end_message_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Message size",
      "default": 14
    },
    {
      "type": "color",
      "id": "end_message_color",
      "label": "Message color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Infinite scroll products"
    }
  ]
}
{% endschema %}
