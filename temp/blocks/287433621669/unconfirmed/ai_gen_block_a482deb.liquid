<script>
  (function() {
    class GenderFilterBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.genderButtons = this.querySelectorAll('.ai-gender-button-{{ ai_gen_id }}');
        this.bannerItems = this.querySelectorAll('.ai-banner-item-{{ ai_gen_id }}');
        this.ageFilterBoys = this.querySelector('.ai-age-filter-boys-{{ ai_gen_id }}');
        this.ageFilterGirls = this.querySelector('.ai-age-filter-girls-{{ ai_gen_id }}');
        this.ageButtons = this.querySelectorAll('.ai-age-button-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupGenderToggle();
        this.setupAgeFilters();
        this.checkUrlForActiveAge();
      }

      setupGenderToggle() {
        this.genderButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const gender = button.getAttribute('data-gender');
            this.switchGender(gender);
          });
        });
      }

      switchGender(gender) {
        this.genderButtons.forEach((btn) => {
          const isActive = btn.getAttribute('data-gender') === gender;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', isActive);
        });

        this.bannerItems.forEach((item) => {
          const isActive = item.getAttribute('data-banner') === gender;
          item.classList.toggle('active', isActive);
        });

        if (gender === 'boys') {
          this.ageFilterBoys.style.display = 'flex';
          this.ageFilterGirls.style.display = 'none';
        } else {
          this.ageFilterBoys.style.display = 'none';
          this.ageFilterGirls.style.display = 'flex';
        }

        this.ageButtons.forEach((btn) => {
          btn.classList.remove('active');
        });
      }

      setupAgeFilters() {
        this.ageButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            this.ageButtons.forEach((btn) => {
              btn.classList.remove('active');
            });
            button.classList.add('active');
          });
        });
      }

      checkUrlForActiveAge() {
        const currentUrl = window.location.href;
        this.ageButtons.forEach((button) => {
          const buttonUrl = button.getAttribute('href');
          if (buttonUrl && currentUrl.includes(buttonUrl)) {
            button.classList.add('active');
          }
        });
      }
    }

    customElements.define('gender-filter-banner-{{ ai_gen_id }}', GenderFilterBanner{{ ai_gen_id }});
  })();
</script>

