{% doc %}
  @prompt
    Update the existing AI-generated gender filter banner block (section ID: template--20673556971685__blocks_MM8Chy, block ID: template--20673556971685__blocks_MM8Chy__ai_gen_block_6984537_ixeagT) with these two improvements: 1) "Boys" gender button should be active/selected by default when the page first loads, with the boys banner image and text shown immediately. 2) Add an age filter below the gender toggle that dynamically changes based on the selected gender. When "Boys" is selected, show boys-specific age groups (e.g. 0-2Y, 2-4Y, 4-6Y, 6-8Y, 8-10Y). When "Girls" is selected, show girls-specific age groups (e.g. 0-2Y, 2-4Y, 4-6Y, 6-8Y, 8-10Y) — these should be configurable separately in the theme editor for boys and girls. Clicking an age filter should filter the product grid below to show only products matching that gender and age group using collection URL parameters or tags. The active age filter should be visually highlighted.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gender-filter-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-gender-filter-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-gender-toggle-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .ai-gender-button-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-gender-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-gender-button-{{ ai_gen_id }}.active {
