{% doc %}
  @prompt
    Add a gender filter section above the existing Age Filter Bubbles section on the collections page. The gender filter should display as attractive clickable bubble/pill buttons (similar in style to the age filter bubbles already on the page) with options like "Boys", "Girls", and "Unisex". The bubbles should match the existing website's premium kids' clothing brand aesthetic — use the theme's existing color variables, fonts, and button styles so it blends seamlessly. When a gender bubble is clicked, it should filter the collection by the corresponding gender tag. The selected bubble should have a visually distinct active/selected state (e.g., filled background vs outlined). Make it responsive for both mobile and desktop layouts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gender-filter-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-gender-filter__container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.spacing_grid_horizontal }}px;
  }

  .ai-gender-filter__wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-gender-filter__heading-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
    font-weight: {{ settings.type_header_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-gender-filter__bubbles-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.bubble_gap }}px;
    align-items: center;
  }

  .ai-gender-filter__bubble-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.bubble_padding_vertical }}px {{ block.settings.bubble_padding_horizontal }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-weight: {{ settings.type_body_font.weight }};
    font-size: {{ block.settings.bubble_font_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: {{ settings.variant_pills_radius }}px;
    border: {{ settings.variant_pills_border_thickness }}px solid rgba({{ block.settings.bubble_border_color.red }}, {{ block.settings.bubble_border_color.green }}, {{ block.settings.bubble_border_color.blue }}, calc({{ settings.variant_pills_border_opacity }} / 100.0));
    background-color: {{ block.settings.bubble_bg_color }};
    color: {{ block.settings.bubble_text_color }};
    {% if settings.variant_pills_shadow_opacity > 0 %}
      box-shadow: {{ settings.variant_pills_shadow_horizontal_offset }}px {{ settings.variant_pills_shadow_vertical_offset }}px {{ settings.variant_pills_shadow_blur }}px rgba(0, 0, 0, calc({{ settings.variant_pills_shadow_opacity }} / 100.0));
    {% endif %}
  }

  .ai-gender-filter__bubble-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.bubble_hover_bg_color }};
    color: {{ block.settings.bubble_hover_text_color }};
    border-color: rgba({{ block.settings.bubble_hover_border_color.red }}, {{ block.settings.bubble_hover_border_color.green }}, {{ block.settings.bubble_hover_border_color.blue }}, calc({{ settings.variant_pills_border_opacity }} / 100.0));
    transform: translateY(-2px);
  }

  .ai-gender-filter__bubble-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.bubble_active_bg_color }};
    color: {{ block.settings.bubble_active_text_color }};
    border-color: {{ block.settings.bubble_active_border_color }};
    {% if block.settings.active_shadow_enabled %}
      box-shadow: 0 4px 12px rgba({{ block.settings.bubble_active_bg_color.red }}, {{ block.settings.bubble_active_bg_color.green }}, {{ block.settings.bubble_active_bg_color.blue }}, 0.3);
    {% endif %}
  }

  .ai-gender-filter__bubble-{{ ai_gen_id }}.active:hover {
    background-color: {{ block.settings.bubble_active_bg_color }};
    color: {{ block.settings.bubble_active_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-gender-filter__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-gender-filter__bubble-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.bubble_font_size }}px * 0.9);
      padding: {{ block.settings.bubble_padding_vertical | times: 0.85 }}px {{ block.settings.bubble_padding_horizontal | times: 0.85 }}px;
    }
  }
{% endstyle %}

<gender-filter-{{ ai_gen_id }} class="ai-gender-filter-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gender-filter__container-{{ ai_gen_id }}">
    <div class="ai-gender-filter__wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-gender-filter__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
      {% endif %}

      <div class="ai-gender-filter__bubbles-{{ ai_gen_id }}">
        {% if block.settings.show_all_option %}
          <a
            href="{{ collection.url }}"
            class="ai-gender-filter__bubble-{{ ai_gen_id }} {% unless current_tags %}active{% endunless %}"
            data-gender-filter="all"
          >
            {{ block.settings.all_label }}
          </a>
        {% endif %}

        {% if block.settings.show_boys %}
          {% assign boys_tag = block.settings.boys_tag %}
          {% assign is_active = false %}
          {% for tag in current_tags %}
            {% if tag == boys_tag %}
              {% assign is_active = true %}
            {% endif %}
          {% endfor %}
          <a
            href="{{ collection.url }}/{{ boys_tag | handle }}"
            class="ai-gender-filter__bubble-{{ ai_gen_id }} {% if is_active %}active{% endif %}"
            data-gender-filter="{{ boys_tag | handle }}"
          >
            {{ block.settings.boys_label }}
          </a>
        {% endif %}

        {% if block.settings.show_girls %}
          {% assign girls_tag = block.settings.girls_tag %}
          {% assign is_active = false %}
          {% for tag in current_tags %}
            {% if tag == girls_tag %}
              {% assign is_active = true %}
            {% endif %}
          {% endfor %}
          <a
            href="{{ collection.url }}/{{ girls_tag | handle }}"
            class="ai-gender-filter__bubble-{{ ai_gen_id }} {% if is_active %}active{% endif %}"
            data-gender-filter="{{ girls_tag | handle }}"
          >
            {{ block.settings.girls_label }}
          </a>
        {% endif %}

        {% if block.settings.show_unisex %}
          {% assign unisex_tag = block.settings.unisex_tag %}
          {% assign is_active = false %}
          {% for tag in current_tags %}
            {% if tag == unisex_tag %}
              {% assign is_active = true %}
            {% endif %}
          {% endfor %}
          <a
            href="{{ collection.url }}/{{ unisex_tag | handle }}"
            class="ai-gender-filter__bubble-{{ ai_gen_id }} {% if is_active %}active{% endif %}"
            data-gender-filter="{{ unisex_tag | handle }}"
          >
            {{ block.settings.unisex_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</gender-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class GenderFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.bubbles = this.querySelectorAll('.ai-gender-filter__bubble-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.bubbles.forEach((bubble) => {
          bubble.addEventListener('click', (event) => {
            event.preventDefault();
            const url = bubble.getAttribute('href');
            window.location.href = url;
          });
        });
      }
    }

    customElements.define('gender-filter-{{ ai_gen_id }}', GenderFilter{{ ai_gen_id }});
  })();
</script>

