{% doc %}
  @prompt
    Create a popup banner that appears automatically when a visitor lands on the page. The popup should promote a "Buy 2 @ ₹799" offer. It should appear after a short delay (1-2 seconds), have a visually appealing design matching a premium kids' clothing brand with pastel colors, include a close button, and optionally a CTA button. The popup should only show once per session using sessionStorage so it doesn't appear on every page load.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-promo-popup-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-promo-popup-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    backdrop-filter: blur({{ block.settings.overlay_blur }}px);
  }

  .ai-promo-popup-content-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.popup_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: {{ block.settings.popup_width }}px;
    width: 100%;
    padding: {{ block.settings.padding }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    text-align: center;
    opacity: 0;
    transform: scale(0.9) translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .ai-promo-popup-{{ ai_gen_id }}.active .ai-promo-popup-content-{{ ai_gen_id }} {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .ai-promo-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.close_button_position }}px;
    right: {{ block.settings.close_button_position }}px;
    background: {{ block.settings.close_button_bg }};
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: {{ block.settings.close_button_color }};
    z-index: 10;
  }

  .ai-promo-popup-close-{{ ai_gen_id }}:hover {
    background: {{ block.settings.close_button_hover_bg }};
    transform: rotate(90deg);
  }

  .ai-promo-popup-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-promo-popup-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 20px;
    border-radius: 50px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-promo-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-promo-popup-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-promo-popup-cta-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    padding: 16px 40px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-promo-popup-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  @media screen and (max-width: 749px) {
    .ai-promo-popup-content-{{ ai_gen_id }} {
      max-width: 90%;
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-promo-popup-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.8 }}px;
    }

    .ai-promo-popup-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size | times: 0.9 }}px;
    }

    .ai-promo-popup-cta-{{ ai_gen_id }} {
      padding: 14px 32px;
      font-size: {{ block.settings.cta_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<promo-popup-{{ ai_gen_id }}
  class="ai-promo-popup-{{ ai_gen_id }}"
  data-delay="{{ block.settings.popup_delay }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-promo-popup-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-promo-popup-content-{{ ai_gen_id }}">
    <button
      class="ai-promo-popup-close-{{ ai_gen_id }}"
      aria-label="Close popup"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    {% if block.settings.show_badge and block.settings.badge_text != blank %}
      <div class="ai-promo-popup-badge-{{ ai_gen_id }}">
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-promo-popup-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-promo-popup-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    {% if block.settings.show_cta and block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-promo-popup-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</promo-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.sessionKey = 'ai_promo_popup_shown_{{ ai_gen_id }}';
      }

      connectedCallback() {
        if (this.hasBeenShown()) {
          return;
        }

        const delay = parseInt(this.dataset.delay) || 1500;
        
        setTimeout(() => {
          this.showPopup();
        }, delay);

        this.setupEventListeners();
      }

      hasBeenShown() {
        return sessionStorage.getItem(this.sessionKey) === 'true';
      }

      markAsShown() {
        sessionStorage.setItem(this.sessionKey, 'true');
      }

      showPopup() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      hidePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
        this.markAsShown();
      }

      setupEventListeners() {
        const closeButton = this.querySelector('.ai-promo-popup-close-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-promo-popup-overlay-{{ ai_gen_id }}');
        const ctaButton = this.querySelector('.ai-promo-popup-cta-{{ ai_gen_id }}');

        if (closeButton) {
          closeButton.addEventListener('click', () => {
            this.hidePopup();
          });
        }

        if (overlay) {
          overlay.addEventListener('click', () => {
            this.hidePopup();
          });
        }

        if (ctaButton) {
          ctaButton.addEventListener('click', () => {
            this.markAsShown();
          });
        }

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && this.classList.contains('active')) {
            this.hidePopup();
          }
        });
      }
    }

    customElements.define('promo-popup-{{ ai_gen_id }}', PromoPopup{{ ai_gen_id }});
  })();
</script>

