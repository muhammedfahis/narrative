{% doc %}
  @prompt
    Edit the Hero USP banner block to add a dark semi-transparent overlay (rgba(0,0,0,0.5)) over the background image so that white text is clearly readable. The overlay should sit between the image and the text content.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-usp-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-usp-banner-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-usp-banner-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-usp-banner-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-usp-banner-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-usp-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 2;
  }

  .ai-hero-usp-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 40px 20px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-hero-usp-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-hero-usp-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-hero-usp-banner-usps-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    margin-top: 32px;
  }

  .ai-hero-usp-banner-usp-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.usp_text_color }};
    font-size: {{ block.settings.usp_text_size }}px;
  }

  .ai-hero-usp-banner-usp-icon-{{ ai_gen_id }} {
    width: {{ block.settings.usp_icon_size }}px;
    height: {{ block.settings.usp_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-hero-usp-banner-usp-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.usp_icon_color }};
  }

  .ai-hero-usp-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-hero-usp-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-usp-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height | times: 0.6 }}px;
    }

    .ai-hero-usp-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-usp-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-usp-banner-usps-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 16px;
    }
  }
{% endstyle %}

<div class="ai-hero-usp-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-usp-banner-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-usp-banner-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-usp-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-usp-banner-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-hero-usp-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-hero-usp-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-hero-usp-banner-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}

    <div class="ai-hero-usp-banner-usps-{{ ai_gen_id }}">
      {% if block.settings.usp_1_text != blank %}
        <div class="ai-hero-usp-banner-usp-item-{{ ai_gen_id }}">
          <div class="ai-hero-usp-banner-usp-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span>{{ block.settings.usp_1_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.usp_2_text != blank %}
        <div class="ai-hero-usp-banner-usp-item-{{ ai_gen_id }}">
          <div class="ai-hero-usp-banner-usp-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span>{{ block.settings.usp_2_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.usp_3_text != blank %}
        <div class="ai-hero-usp-banner-usp-item-{{ ai_gen_id }}">
          <div class="ai-hero-usp-banner-usp-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span>{{ block.settings.usp_3_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero USP banner",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Minimum height",
      "default": 500
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 800
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Kids Fashion"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our collection of everyday wear and party outfits"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#334fb4"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "USP points"
    },
    {
      "type": "text",
      "id": "usp_1_text",
      "label": "USP 1",
      "default": "Free shipping on orders over ₹999"
    },
    {
      "type": "text",
      "id": "usp_2_text",
      "label": "USP 2",
      "default": "Cash on delivery available"
    },
    {
      "type": "text",
      "id": "usp_3_text",
      "label": "USP 3",
      "default": "Premium quality guaranteed"
    },
    {
      "type": "range",
      "id": "usp_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "USP text size",
      "default": 14
    },
    {
      "type": "color",
      "id": "usp_text_color",
      "label": "USP text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "usp_icon_size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "USP icon size",
      "default": 20
    },
    {
      "type": "color",
      "id": "usp_icon_color",
      "label": "USP icon color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero USP banner"
    }
  ]
}
{% endschema %}
