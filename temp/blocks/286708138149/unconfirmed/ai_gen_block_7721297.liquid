{% doc %}
  @prompt
    Create a bold, premium hero USP banner section for a kids' fashion and essentials brand called Kidsmire. It should feature:
    1. A punchy main headline like "Curated Essentials for Conscious Parents" in large, bold typography
    2. A supporting subheadline like "Premium Quality Kids' Wear – Loved by Moms Across India"
    3. A trust line below like "✓ Handpicked Styles  ✓ Safe & Tested  ✓ Fast Delivery"
    4. A prominent CTA button "Shop Best Sellers" linking to /collections/best-sellers
    Style it to feel premium and boutique — clean layout, elegant fonts, and colors consistent with the existing theme. Should work beautifully on both mobile and desktop.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-usp-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: center;
  }

  .ai-hero-usp-banner__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-hero-usp-banner__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ai-hero-usp-banner__subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    font-weight: {{ block.settings.subheadline_weight }};
    color: {{ block.settings.subheadline_color }};
    line-height: 1.4;
    margin: 0;
  }

  .ai-hero-usp-banner__trust-line-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.trust_item_spacing }}px;
    font-size: {{ block.settings.trust_line_size }}px;
    color: {{ block.settings.trust_line_color }};
    font-weight: {{ block.settings.trust_line_weight }};
  }

  .ai-hero-usp-banner__trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-hero-usp-banner__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-usp-banner__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-hero-usp-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-hero-usp-banner__container-{{ ai_gen_id }} {
      gap: {{ block.settings.content_spacing | times: 0.7 }}px;
    }

    .ai-hero-usp-banner__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-hero-usp-banner__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.75 }}px;
    }

    .ai-hero-usp-banner__trust-line-{{ ai_gen_id }} {
      font-size: {{ block.settings.trust_line_size | times: 0.85 }}px;
      gap: {{ block.settings.trust_item_spacing | times: 0.7 }}px;
    }

    .ai-hero-usp-banner__cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.85 }}px {{ block.settings.button_padding_horizontal | times: 0.85 }}px;
    }
  }
{% endstyle %}

<hero-usp-banner-{{ ai_gen_id }} class="ai-hero-usp-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-usp-banner__container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-usp-banner__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-usp-banner__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </p>
    {% endif %}

    {% if block.settings.show_trust_line %}
      <div class="ai-hero-usp-banner__trust-line-{{ ai_gen_id }}">
        {% if block.settings.trust_item_1 != blank %}
          <span class="ai-hero-usp-banner__trust-item-{{ ai_gen_id }}">
            <span>{{ block.settings.trust_icon }}</span>
            <span>{{ block.settings.trust_item_1 }}</span>
          </span>
        {% endif %}

        {% if block.settings.trust_item_2 != blank %}
          <span class="ai-hero-usp-banner__trust-item-{{ ai_gen_id }}">
            <span>{{ block.settings.trust_icon }}</span>
            <span>{{ block.settings.trust_item_2 }}</span>
          </span>
        {% endif %}

        {% if block.settings.trust_item_3 != blank %}
          <span class="ai-hero-usp-banner__trust-item-{{ ai_gen_id }}">
            <span>{{ block.settings.trust_icon }}</span>
            <span>{{ block.settings.trust_item_3 }}</span>
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_cta and block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-hero-usp-banner__cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</hero-usp-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroUspBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const ctaButton = this.querySelector('.ai-hero-usp-banner__cta-{{ ai_gen_id }}');
        if (ctaButton) {
          ctaButton.setAttribute('role', 'button');
        }
      }
    }

    customElements.define('hero-usp-banner-{{ ai_gen_id }}', HeroUspBanner{{ ai_gen_id }});
  })();
</script>

