{% doc %}
  @prompt
    Make the following enhancements to the homepage hero/banner section and announcement bar:
    
    1. **Hero Section - USP Headline**: Update the main banner headline to a punchy, brand-aligned USP such as "Curated Essentials for Conscious Parents" or "Premium Quality Kids' Wear – Loved by Moms." Make the headline bold, prominent, and visually impactful.
    
    2. **Hero CTA Button**: Make the primary CTA button more visually prominent (stronger contrast, larger size, or accent color). Update the button link to point to the best-selling collection instead of a generic "Shop All" page.
    
    3. **Announcement Bar - Rotating Messages**: Convert the static announcement bar into a rotating/cycling announcement bar that cycles through three messages:
       - "Free Shipping on orders above ₹X"
       - "New Arrivals Just Landed 🎉"
       - "COD Available – Shop with Confidence"
       Each message should auto-rotate every 3–4 seconds with a smooth fade or slide transition. Keep the bar styled consistently with the existing theme colors.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rotating-announcement-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding }}px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    width: 100%;
    display: block;
  }

  .ai-rotating-announcement__container-{{ ai_gen_id }} {
    position: relative;
    height: {{ block.settings.text_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-rotating-announcement__message-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.font_weight }};
    white-space: nowrap;
    pointer-events: none;
  }

  .ai-rotating-announcement__message-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-rotating-announcement__message-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-rotating-announcement__message-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rotating-announcement__message-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
      white-space: normal;
    }
  }
{% endstyle %}

<rotating-announcement-{{ ai_gen_id }}
  class="ai-rotating-announcement-{{ ai_gen_id }}"
  data-interval="{{ block.settings.rotation_interval }}"
  data-transition="{{ block.settings.transition_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-rotating-announcement__container-{{ ai_gen_id }}">
    {% if block.settings.message_1 != blank %}
      <div class="ai-rotating-announcement__message-{{ ai_gen_id }}" data-message-index="0">
        {{ block.settings.message_1 }}
      </div>
    {% endif %}

    {% if block.settings.message_2 != blank %}
      <div class="ai-rotating-announcement__message-{{ ai_gen_id }}" data-message-index="1">
        {{ block.settings.message_2 }}
      </div>
    {% endif %}

    {% if block.settings.message_3 != blank %}
      <div class="ai-rotating-announcement__message-{{ ai_gen_id }}" data-message-index="2">
        {{ block.settings.message_3 }}
      </div>
    {% endif %}
  </div>
</rotating-announcement-{{ ai_gen_id }}>

<script>
  (function() {
    class RotatingAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.messages = [];
        this.intervalId = null;
      }

      connectedCallback() {
        this.messages = Array.from(
          this.querySelectorAll('.ai-rotating-announcement__message-{{ ai_gen_id }}')
        );

        if (this.messages.length === 0) return;

        this.interval = parseInt(this.dataset.interval) * 1000 || 4000;
        this.transitionSpeed = parseFloat(this.dataset.transition) * 1000 || 500;

        this.messages[0].classList.add('active');

        if (this.messages.length > 1) {
          this.startRotation();
        }
      }

      startRotation() {
        this.intervalId = setInterval(() => {
          this.rotateMessage();
        }, this.interval);
      }

      rotateMessage() {
        this.messages[this.currentIndex].classList.remove('active');

        this.currentIndex = (this.currentIndex + 1) % this.messages.length;

        this.messages[this.currentIndex].classList.add('active');
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }
    }

    customElements.define('rotating-announcement-{{ ai_gen_id }}', RotatingAnnouncement{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Rotating announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "richtext",
      "id": "message_1",
      "label": "Message 1",
      "default": "<p>Free Shipping on orders above ₹999</p>"
    },
    {
      "type": "richtext",
      "id": "message_2",
      "label": "Message 2",
      "default": "<p>New Arrivals Just Landed 🎉</p>"
    },
    {
      "type": "richtext",
      "id": "message_3",
      "label": "Message 3",
      "default": "<p>COD Available – Shop with Confidence</p>"
    },
    {
      "type": "header",
      "content": "Timing"
    },
    {
      "type": "range",
      "id": "rotation_interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Rotation interval",
      "default": 4
    },
    {
      "type": "range",
      "id": "transition_speed",
      "min": 0.2,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "label": "Transition speed",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Padding",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#cccccc"
    }
  ],
  "presets": [
    {
      "name": "Rotating announcement bar"
    }
  ]
}
{% endschema %}