{% comment %}
  KIDSMIRE — Hero Section v3
  sections/km-hero.liquid
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .km{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
    background: #1a1a1a;
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-img-col {
    position: relative;
    overflow: hidden;
    min-height: 600px;
    background: #2a2a2a;
  }

  .km{{ section.id }}-img-col img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .km{{ section.id }}-img-col .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 55%, rgba(26,26,26,0.5) 100%);
    z-index: 1;
  }

  .km{{ section.id }}-img-col .badge {
    position: absolute;
    top: 28px;
    left: 28px;
    z-index: 2;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    background: rgba(0,0,0,0.4);
    padding: 8px 14px;
    border: 0.5px solid rgba(255,255,255,0.15);
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-placeholder {
    width: 100%;
    height: 100%;
    min-height: 600px;
    background: #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.15);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px 56px;
    background: #1a1a1a;
  }

  .km{{ section.id }}-eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 28px;
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 54px;
    font-weight: 300;
    line-height: 1.08;
    color: #f5f2ee;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
  }

  .km{{ section.id }}-headline em {
    font-style: italic;
    color: #c8b89a;
  }

  .km{{ section.id }}-subtext {
    font-size: 13px;
    color: rgba(255,255,255,0.42);
    line-height: 1.85;
    margin-bottom: 48px;
    font-weight: 300;
    max-width: 320px;
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }

  .km{{ section.id }}-btn-p,
  .km{{ section.id }}-btn-s {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 15px 36px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .km{{ section.id }}-btn-p {
    background: #f5f2ee;
    color: #1a1a1a;
  }

  .km{{ section.id }}-btn-s {
    background: transparent;
    color: rgba(255,255,255,0.55);
    border: 0.5px solid rgba(255,255,255,0.2);
  }

  .km{{ section.id }}-stats {
    display: flex;
    gap: 40px;
    margin-top: 52px;
    padding-top: 36px;
    border-top: 0.5px solid rgba(255,255,255,0.1);
  }

  .km{{ section.id }}-stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 300;
    color: #c8b89a;
    line-height: 1;
    display: block;
  }

  .km{{ section.id }}-stat-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    margin-top: 6px;
    display: block;
    font-family: 'Inter', sans-serif;
  }

  .km{{ section.id }}-marquee {
    background: #c8b89a;
    padding: 13px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .km{{ section.id }}-marquee-inner {
    display: inline-block;
    animation: kmscroll{{ section.id }} 22s linear infinite;
  }

  .km{{ section.id }}-marquee span.t {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0 48px;
  }

  .km{{ section.id }}-marquee span.d {
    color: rgba(0,0,0,0.28);
  }

  @keyframes kmscroll{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .km{{ section.id }} { grid-template-columns: 1fr; }
    .km{{ section.id }}-img-col { min-height: 420px; }
    .km{{ section.id }}-content { padding: 40px 24px 48px; }
    .km{{ section.id }}-headline { font-size: 36px; }
    .km{{ section.id }}-ctas { flex-direction: column; }
    .km{{ section.id }}-btn-p,
    .km{{ section.id }}-btn-s { text-align: center; }
    .km{{ section.id }}-stats { gap: 24px; }
  }
</style>

<div class="km{{ section.id }}">

  <div class="km{{ section.id }}-img-col">
    {%- if section.settings.image != blank -%}
      {%- assign img_w = section.settings.image.width | at_most: 1400 -%}
      {%- assign img_h = section.settings.image.height | times: img_w | divided_by: section.settings.image.width -%}
      <img
        src="{{ section.settings.image | image_url: width: 1400 }}"
        srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1400 }} 1400w"
        sizes="50vw"
        alt="{{ section.settings.image.alt | default: 'KIDSMIRE hero' | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ img_w }}"
        height="{{ img_h }}"
      >
    {%- else -%}
      <div class="km{{ section.id }}-placeholder">Add hero image</div>
    {%- endif -%}
    <div class="overlay"></div>
    {%- if section.settings.image_tag != blank -%}
      <span class="badge">{{ section.settings.image_tag }}</span>
    {%- endif -%}
  </div>

  <div class="km{{ section.id }}-content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="km{{ section.id }}-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.headline != blank -%}
      <h2 class="km{{ section.id }}-headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="km{{ section.id }}-subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="km{{ section.id }}-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/girls' }}" class="km{{ section.id }}-btn-p">
          {{ section.settings.cta_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '/collections/boys' }}" class="km{{ section.id }}-btn-s">
          {{ section.settings.cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="km{{ section.id }}-stats">
      {%- if section.settings.stat_1_num != blank -%}
        <div>
          <span class="km{{ section.id }}-stat-num">{{ section.settings.stat_1_num }}</span>
          <span class="km{{ section.id }}-stat-label">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_num != blank -%}
        <div>
          <span class="km{{ section.id }}-stat-num">{{ section.settings.stat_2_num }}</span>
          <span class="km{{ section.id }}-stat-label">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_num != blank -%}
        <div>
          <span class="km{{ section.id }}-stat-num">{{ section.settings.stat_3_num }}</span>
          <span class="km{{ section.id }}-stat-label">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>

</div>

{%- if section.settings.show_marquee -%}
  <div class="km{{ section.id }}-marquee">
    <div class="km{{ section.id }}-marquee-inner">
      {%- assign items = section.settings.marquee_text | split: '|' -%}
      {%- for item in items -%}<span class="t">{{ item | strip }}</span><span class="d"> · </span>{%- endfor -%}
      {%- for item in items -%}<span class="t">{{ item | strip }}</span><span class="d"> · </span>{%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "KM Hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Portrait orientation, min 800x1000px recommended."
    },
    {
      "type": "text",
      "id": "image_tag",
      "label": "Image badge text",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Dressed to move.<br><em>Built to last.</em></p>",
      "info": "Use <em> tags for italic gold text."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium cotton & denim, sized 6 months to 6 years. Designed for the children who never slow down."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop girls"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "Shop boys"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "87+ reviews"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 number",
      "default": "₹330"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Starts from"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Cotton & denim"
    },
    {
      "type": "header",
      "content": "Marquee strip"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show marquee strip",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items (separate with |)",
      "default": "Free shipping above ₹999 | COD available pan-India | 7-day easy returns | 100% cotton & denim | Delivers in 3–5 days"
    }
  ],
  "presets": [
    {
      "name": "KM Hero"
    }
  ]
}
{% endschema %}
