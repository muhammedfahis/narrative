{% doc %}
  Redesigned KIDSMIRE Hero Section
  - Split layout: image left, text right
  - Dark right panel for full text readability
  - Image anchored to top so face is never cropped
  - Clean minimal aesthetic matching KIDSMIRE theme
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  /* ── ROOT ─────────────────────────────────────────── */
  .km-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 90vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    background: #0e0e0e;
    font-family: 'Assistant', sans-serif;
  }

  /* ── LEFT — IMAGE PANEL ───────────────────────────── */
  .km-hero-img-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    min-height: 90vh;
  }

  .km-hero-img-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .km-hero-img-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 60%,
      #0e0e0e 100%
    );
    pointer-events: none;
  }

  /* ── RIGHT — TEXT PANEL ───────────────────────────── */
  .km-hero-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 56px 60px 40px;
    background: #0e0e0e;
    position: relative;
    z-index: 2;
  }

  .km-hero-tag-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c2a96e;
    margin-bottom: 28px;
  }

  .km-hero-tag-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    width: 28px;
    height: 1.5px;
    background: #c2a96e;
  }

  .km-hero-h1-{{ ai_gen_id }} {
    font-family: 'Assistant', sans-serif;
    font-size: 52px;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0 0 20px;
  }

  .km-hero-h1-{{ ai_gen_id }} em {
    font-style: normal;
    color: #c2a96e;
  }

  .km-hero-sub-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin: 0 0 36px;
    max-width: 380px;
  }

  .km-hero-badges-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 44px;
  }

  .km-hero-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }

  .km-hero-badge-dot-{{ ai_gen_id }} {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(194,169,110,0.15);
    border: 1.5px solid rgba(194,169,110,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .km-hero-badge-dot-{{ ai_gen_id }} svg {
    width: 11px;
    height: 11px;
  }

  .km-hero-divider-{{ ai_gen_id }} {
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,0.12);
    margin-bottom: 44px;
  }

  .km-hero-cta-row-{{ ai_gen_id }} {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .km-hero-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 15px 32px;
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.22s ease;
    cursor: pointer;
  }

  .km-hero-btn-boys-{{ ai_gen_id }} {
    background: #ffffff;
    color: #0e0e0e;
  }

  .km-hero-btn-boys-{{ ai_gen_id }}:hover {
    background: #c2a96e;
    color: #0e0e0e;
    transform: translateY(-2px);
  }

  .km-hero-btn-girls-{{ ai_gen_id }} {
    background: transparent;
    color: #ffffff;
    border: 1.5px solid rgba(255,255,255,0.3);
  }

  .km-hero-btn-girls-{{ ai_gen_id }}:hover {
    border-color: #c2a96e;
    color: #c2a96e;
    transform: translateY(-2px);
  }

  .km-hero-btn-arrow-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .km-hero-btn-{{ ai_gen_id }}:hover .km-hero-btn-arrow-{{ ai_gen_id }} {
    transform: translateX(3px);
  }

  .km-hero-strip-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    right: 0;
    left: 50%;
    display: flex;
    align-items: stretch;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .km-hero-stat-{{ ai_gen_id }} {
    flex: 1;
    padding: 20px 24px;
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  .km-hero-stat-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .km-hero-stat-num-{{ ai_gen_id }} {
    font-size: 22px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 4px;
  }

  .km-hero-stat-label-{{ ai_gen_id }} {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ── MOBILE ───────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .km-hero-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .km-hero-img-{{ ai_gen_id }} {
      min-height: 55vw;
      max-height: 70vw;
    }

    .km-hero-img-{{ ai_gen_id }}::after {
      background: linear-gradient(
        to bottom,
        transparent 50%,
        #0e0e0e 100%
      );
    }

    .km-hero-text-{{ ai_gen_id }} {
      padding: 36px 24px 100px;
    }

    .km-hero-h1-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .km-hero-sub-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .km-hero-strip-{{ ai_gen_id }} {
      left: 0;
    }

    .km-hero-stat-{{ ai_gen_id }} {
      padding: 14px 16px;
    }

    .km-hero-stat-num-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }

{% endstyle %}

<div class="km-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

  <div class="km-hero-img-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 1200 }}"
        srcset="{{ block.settings.background_image | image_url: width: 600 }} 600w,
                {{ block.settings.background_image | image_url: width: 1200 }} 1200w"
        sizes="50vw"
        alt="KIDSMIRE — Premium Kids Fashion"
        loading="eager"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="km-hero-text-{{ ai_gen_id }}">

    <span class="km-hero-tag-{{ ai_gen_id }}">KIDSMIRE — PREMIUM KIDS WEAR</span>

    <h1 class="km-hero-h1-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}{{ block.settings.headline }}{% else %}Dress them well. Feel good about it.{% endif %}
    </h1>

    <p class="km-hero-sub-{{ ai_gen_id }}">
      {% if block.settings.subheadline != blank %}{{ block.settings.subheadline }}{% else %}100% cotton kids' wear — handpicked for comfort, priced for real life. Loved by moms across India.{% endif %}
    </p>

    <div class="km-hero-badges-{{ ai_gen_id }}">
      {% assign badge_texts = block.settings.badge_1_text | append: '||' | append: block.settings.badge_2_text | append: '||' | append: block.settings.badge_3_text | split: '||' %}
      {% for badge in badge_texts %}
        {% if badge != blank %}
        <div class="km-hero-badge-{{ ai_gen_id }}">
          <div class="km-hero-badge-dot-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="#c2a96e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          {{ badge }}
        </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="km-hero-divider-{{ ai_gen_id }}"></div>

    <div class="km-hero-cta-row-{{ ai_gen_id }}">
      <a href="{{ block.settings.cta_boys_link | default: '/collections/boys' }}"
         class="km-hero-btn-{{ ai_gen_id }} km-hero-btn-boys-{{ ai_gen_id }}">
        {{ block.settings.cta_boys_text | default: 'Shop Boys' }}
        <svg class="km-hero-btn-arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="{{ block.settings.cta_girls_link | default: '/collections/girls' }}"
         class="km-hero-btn-{{ ai_gen_id }} km-hero-btn-girls-{{ ai_gen_id }}">
        {{ block.settings.cta_girls_text | default: 'Shop Girls' }}
        <svg class="km-hero-btn-arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>

  <div class="km-hero-strip-{{ ai_gen_id }}">
    <div class="km-hero-stat-{{ ai_gen_id }}">
      <div class="km-hero-stat-num-{{ ai_gen_id }}">87+</div>
      <div class="km-hero-stat-label-{{ ai_gen_id }}">Verified reviews</div>
    </div>
    <div class="km-hero-stat-{{ ai_gen_id }}">
      <div class="km-hero-stat-num-{{ ai_gen_id }}">4.9★</div>
      <div class="km-hero-stat-label-{{ ai_gen_id }}">Avg rating</div>
    </div>
    <div class="km-hero-stat-{{ ai_gen_id }}">
      <div class="km-hero-stat-num-{{ ai_gen_id }}">₹330</div>
      <div class="km-hero-stat-label-{{ ai_gen_id }}">Starting price</div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "KIDSMIRE Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Child photo (left panel)"
    },
    {
      "type": "inline_richtext",
      "id": "headline",
      "label": "Headline",
      "default": "Dress them well. Feel good about it."
    },
    {
      "type": "inline_richtext",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "100% cotton kids' wear — handpicked for comfort, priced for real life. Loved by moms across India."
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1",
      "default": "100% cotton & denim — no synthetics"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2",
      "default": "7-day easy returns · COD available"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3",
      "default": "Delivers in 3–5 days across India"
    },
    {
      "type": "text",
      "id": "cta_boys_text",
      "label": "Boys button text",
      "default": "Shop Boys"
    },
    {
      "type": "url",
      "id": "cta_boys_link",
      "label": "Boys button link"
    },
    {
      "type": "text",
      "id": "cta_girls_text",
      "label": "Girls button text",
      "default": "Shop Girls"
    },
    {
      "type": "url",
      "id": "cta_girls_link",
      "label": "Girls button link"
    }
  ],
  "presets": [
    {
      "name": "KIDSMIRE Hero"
    }
  ]
}
{% endschema %}