{% comment %}
  KIDSMIRE — Hero Section
  Section file: sections/km-hero.liquid
  Place in: /sections/km-hero.liquid
  Add to template via: Customize > Add section > KM Hero
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .km-hero-section *,
  .km-hero-section *::before,
  .km-hero-section *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .km-hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
    background: #1a1a1a;
    font-family: 'Inter', sans-serif;
  }

  /* ── LEFT: IMAGE SIDE ── */
  .km-hero__image-wrap {
    position: relative;
    overflow: hidden;
    min-height: 600px;
  }

  .km-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.8s ease;
  }

  .km-hero__image-wrap:hover .km-hero__image {
    transform: scale(1.03);
  }

  .km-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, #1a1a1a 100%);
    pointer-events: none;
  }

  /* Collection tag on image */
  .km-hero__image-tag {
    position: absolute;
    top: 28px;
    left: 28px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 8px 14px;
    border: 0.5px solid rgba(255, 255, 255, 0.15);
  }

  /* ── RIGHT: CONTENT SIDE ── */
  .km-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px 56px;
    background: #1a1a1a;
  }

  .km-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(12px);
    animation: km-fade-up 0.7s ease 0.1s forwards;
  }

  .km-hero__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 54px;
    font-weight: 300;
    line-height: 1.08;
    color: #f5f2ee;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
    opacity: 0;
    transform: translateY(16px);
    animation: km-fade-up 0.8s ease 0.25s forwards;
  }

  .km-hero__headline em {
    font-style: italic;
    color: #c8b89a;
  }

  .km-hero__subtext {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.42);
    line-height: 1.85;
    margin-bottom: 48px;
    font-weight: 300;
    max-width: 320px;
    opacity: 0;
    transform: translateY(12px);
    animation: km-fade-up 0.8s ease 0.4s forwards;
  }

  /* ── CTAs ── */
  .km-hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: km-fade-up 0.8s ease 0.55s forwards;
  }

  .km-hero__btn {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 15px 36px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .km-hero__btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .km-hero__btn--primary {
    background: #f5f2ee;
    color: #1a1a1a;
  }

  .km-hero__btn--secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    border: 0.5px solid rgba(255, 255, 255, 0.2);
  }

  .km-hero__btn--secondary:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: rgba(255, 255, 255, 0.8);
  }

  /* ── STATS ── */
  .km-hero__stats {
    display: flex;
    gap: 40px;
    margin-top: 52px;
    padding-top: 36px;
    border-top: 0.5px solid rgba(255, 255, 255, 0.1);
    opacity: 0;
    transform: translateY(12px);
    animation: km-fade-up 0.8s ease 0.7s forwards;
  }

  .km-hero__stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 300;
    color: #c8b89a;
    line-height: 1;
  }

  .km-hero__stat-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin-top: 6px;
  }

  /* ── MARQUEE STRIP ── */
  .km-marquee {
    background: #c8b89a;
    padding: 13px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .km-marquee__inner {
    display: inline-block;
    animation: km-scroll 22s linear infinite;
  }

  .km-marquee__text {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #1a1a1a;
    display: inline;
    margin: 0 48px;
  }

  .km-marquee__dot {
    display: inline;
    color: rgba(0, 0, 0, 0.28);
    margin: 0 4px;
  }

  /* ── ANIMATIONS ── */
  @keyframes km-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes km-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .km-hero-section {
      grid-template-columns: 1fr;
    }

    .km-hero__image-wrap {
      min-height: 420px;
    }

    .km-hero__image-overlay {
      background: linear-gradient(to bottom, transparent 50%, #1a1a1a 100%);
    }

    .km-hero__content {
      padding: 40px 24px 48px;
    }

    .km-hero__headline {
      font-size: 38px;
    }

    .km-hero__stats {
      gap: 28px;
    }

    .km-hero__ctas {
      flex-direction: column;
    }

    .km-hero__btn {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .km-hero__headline {
      font-size: 32px;
    }
  }
</style>

{%- comment -%} ── HERO ── {%- endcomment -%}
<section class="km-hero-section" aria-label="{{ section.settings.headline | escape }}">

  {%- comment -%} LEFT: Image {%- endcomment -%}
  <div class="km-hero__image-wrap">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'km-hero__image',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.image.alt | escape
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'km-hero__image' }}
    {% endif %}

    <div class="km-hero__image-overlay" aria-hidden="true"></div>

    {% if section.settings.image_tag != blank %}
      <span class="km-hero__image-tag">{{ section.settings.image_tag }}</span>
    {% endif %}
  </div>

  {%- comment -%} RIGHT: Content {%- endcomment -%}
  <div class="km-hero__content">

    {% if section.settings.eyebrow != blank %}
      <p class="km-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.headline != blank %}
      <h1 class="km-hero__headline">{{ section.settings.headline }}</h1>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="km-hero__subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    <div class="km-hero__ctas">
      {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
        <a href="{{ section.settings.cta_primary_url }}" class="km-hero__btn km-hero__btn--primary">
          {{ section.settings.cta_primary_label }}
        </a>
      {% endif %}
      {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
        <a href="{{ section.settings.cta_secondary_url }}" class="km-hero__btn km-hero__btn--secondary">
          {{ section.settings.cta_secondary_label }}
        </a>
      {% endif %}
    </div>

    <div class="km-hero__stats">
      {% if section.settings.stat_1_num != blank %}
        <div>
          <div class="km-hero__stat-num">{{ section.settings.stat_1_num }}</div>
          <div class="km-hero__stat-label">{{ section.settings.stat_1_label }}</div>
        </div>
      {% endif %}
      {% if section.settings.stat_2_num != blank %}
        <div>
          <div class="km-hero__stat-num">{{ section.settings.stat_2_num }}</div>
          <div class="km-hero__stat-label">{{ section.settings.stat_2_label }}</div>
        </div>
      {% endif %}
      {% if section.settings.stat_3_num != blank %}
        <div>
          <div class="km-hero__stat-num">{{ section.settings.stat_3_num }}</div>
          <div class="km-hero__stat-label">{{ section.settings.stat_3_label }}</div>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{%- comment -%} ── MARQUEE STRIP ── {%- endcomment -%}
{% if section.settings.show_marquee %}
<div class="km-marquee" aria-hidden="true">
  <div class="km-marquee__inner">
    {%- assign marquee_items = section.settings.marquee_text | split: '|' -%}
    {%- for item in marquee_items -%}
      <span class="km-marquee__text">{{ item | strip }}</span>
      <span class="km-marquee__dot">·</span>
    {%- endfor -%}
    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {%- for item in marquee_items -%}
      <span class="km-marquee__text">{{ item | strip }}</span>
      <span class="km-marquee__dot">·</span>
    {%- endfor -%}
  </div>
</div>
{% endif %}


{% schema %}
{
  "name": "KM Hero",
  "tag": "div",
  "class": "km-hero-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Recommended: portrait orientation, min 800×1000px. Use a single child on a dark or neutral background."
    },
    {
      "type": "text",
      "id": "image_tag",
      "label": "Image badge text",
      "default": "New arrivals — Summer 2026",
      "info": "Small label shown in top-left of image (e.g. collection name)"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Dressed to move.<br><em>Built to last.</em></p>",
      "info": "Use <em> tags for italic gold text. Keep under 6 words per line."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium cotton & denim, sized 6 months to 6 years. Designed for the children who never slow down."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop girls"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "Shop boys"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 — number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 — label",
      "default": "87+ reviews"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 — number",
      "default": "₹330"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 — label",
      "default": "Starts from"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 — number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 — label",
      "default": "Cotton & denim"
    },
    {
      "type": "header",
      "content": "Marquee strip"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show marquee strip",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items",
      "default": "Free shipping above ₹999 | COD available pan-India | 7-day easy returns | 100% cotton & denim | Delivers in 3–5 days",
      "info": "Separate items with a pipe character  |"
    }
  ],
  "presets": [
    {
      "name": "KM Hero"
    }
  ]
}
{% endschema %}
