{% comment %} sections/km-hero.liquid {% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .kmh-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: #111;
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  /* Full-bleed background image */
  .kmh-{{ section.id }} .kmh-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .kmh-{{ section.id }} .kmh-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Dark gradient overlay — left side lighter, right side very dark */
  .kmh-{{ section.id }} .kmh-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(10,10,10,0.15) 0%,
      rgba(10,10,10,0.55) 45%,
      rgba(10,10,10,0.92) 65%,
      rgba(10,10,10,0.98) 100%
    );
  }

  /* Content sits on the right half */
  .kmh-{{ section.id }} .kmh-content {
    position: relative;
    z-index: 2;
    margin-left: auto;
    width: 48%;
    padding: 80px 64px 80px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
  }

  .kmh-{{ section.id }} .kmh-line {
    width: 32px;
    height: 1px;
    background: #c8b89a;
    margin-bottom: 32px;
  }

  .kmh-{{ section.id }} .kmh-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    margin-bottom: 24px;
  }

  .kmh-{{ section.id }} .kmh-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 62px;
    font-weight: 300;
    line-height: 1.05;
    color: #f0ece4;
    margin-bottom: 28px;
    letter-spacing: -1px;
  }

  .kmh-{{ section.id }} .kmh-headline em {
    font-style: italic;
    color: #c8b89a;
    font-weight: 300;
  }

  .kmh-{{ section.id }} .kmh-sub {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.38);
    line-height: 1.9;
    max-width: 300px;
    margin-bottom: 52px;
  }

  .kmh-{{ section.id }} .kmh-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 56px;
  }

  .kmh-{{ section.id }} .kmh-btn-p {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 16px 40px;
    background: #f0ece4;
    color: #111;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }

  .kmh-{{ section.id }} .kmh-btn-p:hover { opacity: 0.88; }

  .kmh-{{ section.id }} .kmh-btn-s {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-bottom: 0.5px solid rgba(255,255,255,0.2);
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .kmh-{{ section.id }} .kmh-btn-s:hover { color: rgba(255,255,255,0.75); }

  .kmh-{{ section.id }} .kmh-stats {
    display: flex;
    gap: 0;
    border-top: 0.5px solid rgba(255,255,255,0.08);
    padding-top: 40px;
  }

  .kmh-{{ section.id }} .kmh-stat {
    flex: 1;
    padding-right: 24px;
    border-right: 0.5px solid rgba(255,255,255,0.08);
    margin-right: 24px;
  }

  .kmh-{{ section.id }} .kmh-stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .kmh-{{ section.id }} .kmh-stat-n {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 300;
    color: #c8b89a;
    line-height: 1;
    display: block;
    margin-bottom: 6px;
  }

  .kmh-{{ section.id }} .kmh-stat-l {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.22);
    display: block;
  }

  /* Marquee */
  .kmh-marquee-{{ section.id }} {
    width: 100%;
    background: #c8b89a;
    padding: 12px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .kmh-marquee-{{ section.id }} .kmh-mi {
    display: inline-block;
    animation: kmscroll-{{ section.id }} 24s linear infinite;
  }

  .kmh-marquee-{{ section.id }} .kmh-mt {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: rgba(0,0,0,0.65);
    margin: 0 44px;
  }

  .kmh-marquee-{{ section.id }} .kmh-md {
    color: rgba(0,0,0,0.25);
    font-size: 9px;
  }

  @keyframes kmscroll-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .kmh-{{ section.id }} {
      min-height: auto;
      flex-direction: column;
    }
    .kmh-{{ section.id }} .kmh-overlay {
      background: linear-gradient(
        to bottom,
        rgba(10,10,10,0.1) 0%,
        rgba(10,10,10,0.75) 50%,
        rgba(10,10,10,0.97) 100%
      );
    }
    .kmh-{{ section.id }} .kmh-content {
      width: 100%;
      margin-left: 0;
      padding: 220px 28px 60px;
      min-height: 90vh;
    }
    .kmh-{{ section.id }} .kmh-headline { font-size: 42px; }
    .kmh-{{ section.id }} .kmh-ctas { flex-direction: column; align-items: flex-start; }
    .kmh-{{ section.id }} .kmh-stat-n { font-size: 24px; }
  }
</style>

<div class="kmh-{{ section.id }}">

  {%- comment -%} BACKGROUND IMAGE {%- endcomment -%}
  <div class="kmh-bg">
    {%- if section.settings.image != blank -%}
      {%- liquid
        assign img_src_w = section.settings.image.width | at_most: 1800
        assign img_src_h = section.settings.image.height | times: img_src_w | divided_by: section.settings.image.width
      -%}
      <img
        src="{{ section.settings.image | image_url: width: 1800 }}"
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1500 }} 1500w, {{ section.settings.image | image_url: width: 1800 }} 1800w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: 'KIDSMIRE' | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ img_src_w }}"
        height="{{ img_src_h }}"
      >
    {%- else -%}
      <div style="width:100%;height:100%;background:#1a1a1a;"></div>
    {%- endif -%}
  </div>

  {%- comment -%} OVERLAY {%- endcomment -%}
  <div class="kmh-overlay"></div>

  {%- comment -%} CONTENT {%- endcomment -%}
  <div class="kmh-content">

    <div class="kmh-line"></div>

    {%- if section.settings.eyebrow != blank -%}
      <p class="kmh-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.headline != blank -%}
      <h2 class="kmh-headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="kmh-sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="kmh-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/girls' }}" class="kmh-btn-p">
          {{ section.settings.cta_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '/collections/boys' }}" class="kmh-btn-s">
          {{ section.settings.cta_secondary_label }} &rarr;
        </a>
      {%- endif -%}
    </div>

    <div class="kmh-stats">
      {%- if section.settings.stat_1_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_1_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_2_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_3_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{%- if section.settings.show_marquee -%}
  <div class="kmh-marquee-{{ section.id }}">
    <div class="kmh-mi">
      {%- assign items = section.settings.marquee_text | split: '|' -%}
      {%- for item in items -%}<span class="kmh-mt">{{ item | strip }}</span><span class="kmh-md"> · </span>{%- endfor -%}
      {%- for item in items -%}<span class="kmh-mt">{{ item | strip }}</span><span class="kmh-md"> · </span>{%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "KM Hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Full-bleed background. Portrait or landscape both work. Min 1200px wide."
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Dressed to move.<br><em>Built to last.</em></p>",
      "info": "Wrap italic gold text in <em> tags."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium cotton & denim, sized 6 months to 6 years. Designed for the children who never slow down."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button",
      "default": "Shop girls"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button",
      "default": "Shop boys"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "87+ reviews"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 number",
      "default": "₹330"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Starts from"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Cotton & denim"
    },
    {
      "type": "header",
      "content": "Marquee strip"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show marquee strip",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items (separate with |)",
      "default": "Free shipping above ₹999 | COD available pan-India | 7-day easy returns | 100% cotton & denim | Delivers in 3–5 days"
    }
  ],
  "presets": [
    {
      "name": "KM Hero"
    }
  ]
}
{% endschema %}
