{% doc %}
  @prompt
    Redesign the Hero USP banner for a premium kids' fashion brand called KIDSMIRE. It must match the existing website theme exactly:
    
    THEME SPECS:
    - Font: "Assistant" for both headings and body
    - Colors: Background #ffffff (white), Text #121212 (near-black), Accent/Button #334fb4 (blue), Button text #ffffff
    - Buttons: border-radius 8px, subtle shadow (15% opacity, 4px vertical offset, 5px blur)
    - Max page width: 1200px
    - Clean, minimal, boutique aesthetic
    
    BANNER CONTENT:
    - Full-width hero section with the background image: https://cdn.shopify.com/s/files/1/0757/6528/5029/files/Gemini_Generated_Image_n9e6k8n9e6k8n9e6_1.png
    - Dark overlay (40% opacity) over the image for text readability
    - Main headline (large, bold, Assistant font): "Curated Essentials for Conscious Parents"
    - Subheadline (lighter weight, Assistant font): "Premium Quality Kids' Wear – Loved by Moms Across India"
    - Trust badges row: "✓ Handpicked Styles   ✓ Safe & Tested   ✓ Fast Delivery"
    - Two CTA buttons: "Shop Boys" and "Shop Girls" in #334fb4 blue with white text, border-radius 8px, each with its own link
    - Text centered, vertically centered on the banner
    - Banner height: large (at least 80vh on desktop)
    - Fully responsive on mobile
    
    Make it feel premium, editorial, and consistent with the existing Kidsmire theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-usp-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height_desktop }}vh;
    overflow: hidden;
  }

  .hero {
  position: relative;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35); /* adjust 0.25–0.45 */
}

.hero-text {
  color: #FFFFFF;
  position: relative;
}

  .ai-hero-usp-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-usp-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-usp-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 2;
  }

  .ai-hero-usp-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.min_height_desktop }}vh;
    padding: 60px 20px;
    text-align: center;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-hero-usp-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.headline_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  .ai-hero-usp-subheadline-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.subheadline_size_desktop }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 40px;
    opacity: 0.9;
  }

  .ai-hero-usp-badges-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    justify-content: center;
    align-items: center;
    margin-bottom: 40px;
  }

  .ai-hero-usp-badge-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.badge_size_desktop }}px;
    color: {{ block.settings.text_color }};
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-hero-usp-badge-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-hero-usp-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: 600;
    font-size: {{ block.settings.button_size_desktop }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    box-shadow: 0 {{ block.settings.button_shadow_vertical }}px {{ block.settings.button_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-usp-cta-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 {{ block.settings.button_shadow_vertical | plus: 2 }}px {{ block.settings.button_shadow_blur | plus: 2 }}px rgba(0, 0, 0, {{ block.settings.button_shadow_opacity | divided_by: 100.0 | plus: 0.05 }});
  }

  .ai-hero-usp-cta-row-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-usp-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}vh;
    }

    .ai-hero-usp-content-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}vh;
      padding: 40px 20px;
    }

    .ai-hero-usp-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
      margin-bottom: 16px;
    }

    .ai-hero-usp-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_mobile }}px;
      margin-bottom: 30px;
    }

    .ai-hero-usp-badges-{{ ai_gen_id }} {
      gap: 20px;
      margin-bottom: 30px;
      flex-direction: column;
    }

    .ai-hero-usp-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_size_mobile }}px;
    }

    .ai-hero-usp-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_mobile }}px;
      padding: 14px 32px;
    }
  }
{% endstyle %}

<hero-usp-{{ ai_gen_id }} class="ai-hero-usp-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-usp-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        srcset="{{ block.settings.background_image | image_url: width: 750 }} 750w,
                {{ block.settings.background_image | image_url: width: 1500 }} 1500w,
                {{ block.settings.background_image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-usp-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-usp-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-usp-content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-usp-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-usp-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    {% endif %}

    <div class="ai-hero-usp-badges-{{ ai_gen_id }}">
      {% if block.settings.badge_1_text != blank %}
        <div class="ai-hero-usp-badge-{{ ai_gen_id }}">
          <svg class="ai-hero-usp-badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.text_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{{ block.settings.badge_1_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_2_text != blank %}
        <div class="ai-hero-usp-badge-{{ ai_gen_id }}">
          <svg class="ai-hero-usp-badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.text_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{{ block.settings.badge_2_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.badge_3_text != blank %}
        <div class="ai-hero-usp-badge-{{ ai_gen_id }}">
          <svg class="ai-hero-usp-badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.text_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{{ block.settings.badge_3_text }}</span>
        </div>
      {% endif %}
    </div>

    {% if block.settings.cta_boys_text != blank or block.settings.cta_girls_text != blank %}
      <div class="ai-hero-usp-cta-row-{{ ai_gen_id }}">
        {% if block.settings.cta_boys_text != blank %}
          <a href="{{ block.settings.cta_boys_link }}" class="ai-hero-usp-cta-{{ ai_gen_id }}">
            {{ block.settings.cta_boys_text }}
          </a>
        {% endif %}
        {% if block.settings.cta_girls_text != blank %}
          <a href="{{ block.settings.cta_girls_link }}" class="ai-hero-usp-cta-{{ ai_gen_id }}">
            {{ block.settings.cta_girls_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</hero-usp-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroUSP{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.querySelectorAll('.ai-hero-usp-cta-{{ ai_gen_id }}').forEach((ctaButton) => {
          ctaButton.setAttribute('role', 'button');
        });
      }
    }

    customElements.define('hero-usp-{{ ai_gen_id }}', HeroUSP{{ ai_gen_id }});
  })();
</script>

