{% comment %}
  KIDSMIRE — Hero Section v2
  File: sections/km-hero.liquid
  Fixes: image rendering, schema tag conflict, filter compatibility
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  #km-hero-{{ section.id }} *,
  #km-hero-{{ section.id }} *::before,
  #km-hero-{{ section.id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  #km-hero-{{ section.id }} {
    font-family: 'Inter', sans-serif;
  }

  .km-hero-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
    background: #1a1a1a;
  }

  /* LEFT: IMAGE */
  .km-hero__image-wrap {
    position: relative;
    overflow: hidden;
    min-height: 600px;
    background: #2a2a2a;
  }

  .km-hero__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    position: absolute;
    inset: 0;
    transition: transform 0.8s ease;
  }

  .km-hero__image-wrap:hover img {
    transform: scale(1.03);
  }

  .km-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 55%, rgba(26,26,26,0.6) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .km-hero__image-tag {
    position: absolute;
    top: 28px;
    left: 28px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    background: rgba(0,0,0,0.4);
    padding: 8px 14px;
    border: 0.5px solid rgba(255,255,255,0.15);
    z-index: 2;
  }

  /* RIGHT: CONTENT */
  .km-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px 56px;
    background: #1a1a1a;
  }

  .km-hero__eyebrow {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 28px;
    animation: km-fade-up 0.7s ease 0.1s both;
  }

  .km-hero__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 54px;
    font-weight: 300;
    line-height: 1.08;
    color: #f5f2ee;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
    animation: km-fade-up 0.8s ease 0.25s both;
  }

  .km-hero__headline em {
    font-style: italic;
    color: #c8b89a;
  }

  .km-hero__subtext {
    font-size: 13px;
    color: rgba(255,255,255,0.42);
    line-height: 1.85;
    margin-bottom: 48px;
    font-weight: 300;
    max-width: 320px;
    animation: km-fade-up 0.8s ease 0.4s both;
  }

  .km-hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    animation: km-fade-up 0.8s ease 0.55s both;
  }

  .km-hero__btn {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 15px 36px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s ease, transform 0.2s ease;
    border: none;
  }

  .km-hero__btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .km-hero__btn--primary {
    background: #f5f2ee;
    color: #1a1a1a;
  }

  .km-hero__btn--secondary {
    background: transparent;
    color: rgba(255,255,255,0.55);
    border: 0.5px solid rgba(255,255,255,0.2);
  }

  .km-hero__btn--secondary:hover {
    border-color: rgba(255,255,255,0.4);
    color: rgba(255,255,255,0.8);
  }

  .km-hero__stats {
    display: flex;
    gap: 40px;
    margin-top: 52px;
    padding-top: 36px;
    border-top: 0.5px solid rgba(255,255,255,0.1);
    animation: km-fade-up 0.8s ease 0.7s both;
  }

  .km-hero__stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 300;
    color: #c8b89a;
    line-height: 1;
  }

  .km-hero__stat-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    margin-top: 6px;
  }

  /* MARQUEE */
  .km-marquee {
    background: #c8b89a;
    padding: 13px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .km-marquee__inner {
    display: inline-block;
    animation: km-scroll 22s linear infinite;
  }

  .km-marquee__text {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #1a1a1a;
    display: inline;
    margin: 0 48px;
  }

  .km-marquee__dot {
    display: inline;
    color: rgba(0,0,0,0.28);
    margin: 0 4px;
  }

  @keyframes km-fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes km-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .km-hero-wrap {
      grid-template-columns: 1fr;
    }
    .km-hero__image-wrap {
      min-height: 420px;
    }
    .km-hero__image-overlay {
      background: linear-gradient(to bottom, transparent 50%, rgba(26,26,26,0.85) 100%);
    }
    .km-hero__content {
      padding: 40px 24px 48px;
    }
    .km-hero__headline {
      font-size: 38px;
    }
    .km-hero__stats {
      gap: 28px;
    }
    .km-hero__ctas {
      flex-direction: column;
    }
    .km-hero__btn {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .km-hero__headline { font-size: 32px; }
  }
</style>

<div id="km-hero-{{ section.id }}">

  {%- comment -%} HERO GRID {%- endcomment -%}
  <div class="km-hero-wrap">

    {%- comment -%} LEFT: Image {%- endcomment -%}
    <div class="km-hero__image-wrap">
{%- if section.settings.image != blank -%}
  {%- assign img_width = section.settings.image.width | at_most: 1400 -%}
  {%- assign img_height = section.settings.image.height | times: img_width | divided_by: section.settings.image.width -%}
  <img
    src="{{ section.settings.image | image_url: width: 1400 }}"
    srcset="
      {{ section.settings.image | image_url: width: 600 }} 600w,
      {{ section.settings.image | image_url: width: 900 }} 900w,
      {{ section.settings.image | image_url: width: 1200 }} 1200w,
      {{ section.settings.image | image_url: width: 1400 }} 1400w
    "
    sizes="50vw"
    alt="{{ section.settings.image.alt | default: 'KIDSMIRE hero image' | escape }}"
    loading="eager"
    fetchpriority="high"
    width="{{ img_width }}"
    height="{{ img_height }}"
  >
{%- else -%}
  <img
    src="{{ 'lifestyle-1' | placeholder_svg_tag }}"
    alt="Add a hero image in the theme customizer"
    width="800"
    height="1000"
    style="width:100%;height:100%;object-fit:cover;opacity:0.15;"
  >
{%- endif -%}

      <div class="km-hero__image-overlay"></div>

      {%- if section.settings.image_tag != blank -%}
        <span class="km-hero__image-tag">{{ section.settings.image_tag }}</span>
      {%- endif -%}

    </div>

    {%- comment -%} RIGHT: Content {%- endcomment -%}
    <div class="km-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="km-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h2 class="km-hero__headline">{{ section.settings.headline }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="km-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="km-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url | default: '/collections/girls' }}" class="km-hero__btn km-hero__btn--primary">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url | default: '/collections/boys' }}" class="km-hero__btn km-hero__btn--secondary">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="km-hero__stats">
        {%- if section.settings.stat_1_num != blank -%}
          <div>
            <div class="km-hero__stat-num">{{ section.settings.stat_1_num }}</div>
            <div class="km-hero__stat-label">{{ section.settings.stat_1_label }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_num != blank -%}
          <div>
            <div class="km-hero__stat-num">{{ section.settings.stat_2_num }}</div>
            <div class="km-hero__stat-label">{{ section.settings.stat_2_label }}</div>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_num != blank -%}
          <div>
            <div class="km-hero__stat-num">{{ section.settings.stat_3_num }}</div>
            <div class="km-hero__stat-label">{{ section.settings.stat_3_label }}</div>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- comment -%} MARQUEE STRIP {%- endcomment -%}
  {%- if section.settings.show_marquee -%}
    <div class="km-marquee" aria-hidden="true">
      <div class="km-marquee__inner">
        {%- assign marquee_items = section.settings.marquee_text | split: '|' -%}
        {%- for item in marquee_items -%}
          <span class="km-marquee__text">{{ item | strip }}</span>
          <span class="km-marquee__dot">·</span>
        {%- endfor -%}
        {%- for item in marquee_items -%}
          <span class="km-marquee__text">{{ item | strip }}</span>
          <span class="km-marquee__dot">·</span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "KM Hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Portrait orientation works best. Min 800x1000px."
    },
    {
      "type": "text",
      "id": "image_tag",
      "label": "Image badge text",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Dressed to move.<br><em>Built to last.</em></p>",
      "info": "Wrap italic gold text in <em> tags. Keep short — 5 to 6 words max."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium cotton & denim, sized 6 months to 6 years. Designed for the children who never slow down."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop girls"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "Shop boys"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Stats bar"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 — number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 — label",
      "default": "87+ reviews"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 — number",
      "default": "₹330"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 — label",
      "default": "Starts from"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 — number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 — label",
      "default": "Cotton & denim"
    },
    {
      "type": "header",
      "content": "Marquee strip"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show marquee strip",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items (separate with |)",
      "default": "Free shipping above ₹999 | COD available pan-India | 7-day easy returns | 100% cotton & denim | Delivers in 3–5 days"
    }
  ],
  "presets": [
    {
      "name": "KM Hero"
    }
  ]
}
{% endschema %}
