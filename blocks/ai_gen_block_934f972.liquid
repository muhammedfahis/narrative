{% comment %} sections/km-hero.liquid — v5 {% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  .kmh-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: #111;
    overflow: hidden;
  }

  .kmh-{{ section.id }} .kmh-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .kmh-{{ section.id }} .kmh-bg .responsive-image__wrapper {
    height: 100%;
  }

  .kmh-{{ section.id }} .kmh-bg img,
  .kmh-{{ section.id }} .kmh-bg .responsive-image__image {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .kmh-{{ section.id }} .kmh-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      105deg,
      rgba(10,10,10,0.08) 0%,
      rgba(10,10,10,0.6) 42%,
      rgba(10,10,10,0.96) 65%,
      rgba(10,10,10,1) 100%
    );
  }

  .kmh-{{ section.id }} .kmh-content {
    position: relative;
    z-index: 2;
    margin-left: auto;
    width: 46%;
    min-height: 100vh;
    padding: 0 64px 80px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .kmh-{{ section.id }} .kmh-line {
    width: 28px;
    height: 1px;
    background: #c8b89a;
    margin-bottom: 28px;
  }

  .kmh-{{ section.id }} .kmh-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 20px;
    display: block;
  }

  .kmh-{{ section.id }} .kmh-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: 58px;
    font-weight: 300;
    line-height: 1.05;
    color: #f0ece4;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
  }

  .kmh-{{ section.id }} .kmh-headline em {
    font-style: italic;
    color: #c8b89a;
  }

  .kmh-{{ section.id }} .kmh-sub {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.35);
    line-height: 1.9;
    max-width: 280px;
    margin-bottom: 48px;
    display: block;
  }

  .kmh-{{ section.id }} .kmh-ctas {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 52px;
    flex-wrap: wrap;
  }

  .kmh-{{ section.id }} a.kmh-btn-p {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 16px 40px;
    background: #f0ece4;
    color: #111 !important;
    text-decoration: none !important;
    display: inline-block;
  }

  .kmh-{{ section.id }} a.kmh-btn-s {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4) !important;
    text-decoration: none !important;
    display: inline-block;
    border-bottom: 0.5px solid rgba(255,255,255,0.18);
    padding-bottom: 3px;
  }

  .kmh-{{ section.id }} .kmh-stats {
    display: flex;
    gap: 0;
    border-top: 0.5px solid rgba(255,255,255,0.08);
    padding-top: 36px;
  }

  .kmh-{{ section.id }} .kmh-stat {
    flex: 1;
    padding-right: 20px;
    border-right: 0.5px solid rgba(255,255,255,0.07);
    margin-right: 20px;
  }

  .kmh-{{ section.id }} .kmh-stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .kmh-{{ section.id }} .kmh-stat-n {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: #c8b89a;
    line-height: 1;
    display: block;
    margin-bottom: 6px;
  }

  .kmh-{{ section.id }} .kmh-stat-l {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    display: block;
  }

  /* Marquee */
  .kmh-mq-{{ section.id }} {
    width: 100%;
    background: #c8b89a;
    padding: 12px 0;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    z-index: 3;
  }

  .kmh-mq-{{ section.id }} .mqi {
    display: inline-block;
    animation: mqs-{{ section.id }} 24s linear infinite;
  }

  .kmh-mq-{{ section.id }} .mqt {
    font-family: 'Inter', sans-serif;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(0,0,0,0.6);
    margin: 0 40px;
    display: inline;
  }

  .kmh-mq-{{ section.id }} .mqd {
    color: rgba(0,0,0,0.22);
    display: inline;
  }

  @keyframes mqs-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 767px) {
    .kmh-{{ section.id }} .kmh-overlay {
      background: linear-gradient(to bottom, rgba(10,10,10,0.2) 0%, rgba(10,10,10,0.92) 55%, rgba(10,10,10,1) 100%);
    }
    .kmh-{{ section.id }} .kmh-content {
      width: 100%;
      margin-left: 0;
      padding: 240px 28px 60px;
    }
    .kmh-{{ section.id }} .kmh-headline { font-size: 40px; }
    .kmh-{{ section.id }} .kmh-ctas { flex-direction: column; align-items: flex-start; }
  }
</style>

{%- comment -%}
  DEBUG: uncomment the line below, save, check what prints on screen.
  If blank, the image is not saved in section settings.
  <p style="color:red;position:fixed;top:0;z-index:9999">IMG: {{ section.settings.image }}</p>
{%- endcomment -%}

<div class="kmh-{{ section.id }}">

  <div class="kmh-bg">
    {%- if section.settings.image != blank -%}
      {%- liquid
        assign iw = section.settings.image.width | at_most: 1800
        assign ih = section.settings.image.height | times: iw | divided_by: section.settings.image.width
      -%}
      <img
        src="{{ section.settings.image | image_url: width: 1800 }}"
        srcset="
          {{ section.settings.image | image_url: width: 750 }} 750w,
          {{ section.settings.image | image_url: width: 1100 }} 1100w,
          {{ section.settings.image | image_url: width: 1500 }} 1500w,
          {{ section.settings.image | image_url: width: 1800 }} 1800w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: 'KIDSMIRE hero' | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ iw }}"
        height="{{ ih }}"
      >
    {%- else -%}
      {%- comment -%}
        No image selected. Go to Customize → KM Hero → Image → pick your image.
      {%- endcomment -%}
      <div style="position:absolute;inset:0;background:#1a1a1a;display:flex;align-items:center;justify-content:center;">
        <p style="font-family:sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.15);">Select hero image in customizer</p>
      </div>
    {%- endif -%}
  </div>

  <div class="kmh-overlay"></div>

  <div class="kmh-content">
    <div class="kmh-line"></div>

    {%- if section.settings.eyebrow != blank -%}
      <span class="kmh-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.headline != blank -%}
      <h2 class="kmh-headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <span class="kmh-sub">{{ section.settings.subtext }}</span>
    {%- endif -%}

    <div class="kmh-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/girls' }}" class="kmh-btn-p">{{ section.settings.cta_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '/collections/boys' }}" class="kmh-btn-s">{{ section.settings.cta_secondary_label }} &rarr;</a>
      {%- endif -%}
    </div>

    <div class="kmh-stats">
      {%- if section.settings.stat_1_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_1_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_1_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_2_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_2_label }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3_num != blank -%}
        <div class="kmh-stat">
          <span class="kmh-stat-n">{{ section.settings.stat_3_num }}</span>
          <span class="kmh-stat-l">{{ section.settings.stat_3_label }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>

</div>

{%- if section.settings.show_marquee -%}
  <div class="kmh-mq-{{ section.id }}">
    <div class="mqi">
      {%- assign items = section.settings.marquee_text | split: '|' -%}
      {%- for item in items -%}<span class="mqt">{{ item | strip }}</span><span class="mqd"> · </span>{%- endfor -%}
      {%- for item in items -%}<span class="mqt">{{ item | strip }}</span><span class="mqd"> · </span>{%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "KM Hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Full-bleed background. Min 1200px wide recommended."
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New arrivals — Summer 2026"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Dressed to move.<br><em>Built to last.</em></p>",
      "info": "Use <em> tags for italic gold text."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium cotton & denim, sized 6 months to 6 years. Designed for the children who never slow down."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button",
      "default": "Shop girls"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button",
      "default": "Shop boys"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 number",
      "default": "4.9★"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "87+ reviews"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 number",
      "default": "₹330"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Starts from"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Cotton & denim"
    },
    {
      "type": "header",
      "content": "Marquee strip"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show marquee strip",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items (separate with |)",
      "default": "Free shipping above ₹999 | COD available pan-India | 7-day easy returns | 100% cotton & denim | Delivers in 3–5 days"
    }
  ],
  "presets": [
    {
      "name": "KM Hero"
    }
  ]
}
{% endschema %}
