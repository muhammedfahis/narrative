{% doc %}
  @prompt
    Dynamic size chart block: tag `imported` shows international chart; otherwise Indian/KIDSMIRE chart.
    Columns: Age, size label/CN, Height, Chest, Garment length (shoulder to hem). Inches default with CM toggle.
    Includes a small line-art “how to measure” diagram. Accordion with Size Chart heading.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-chart-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-size-chart-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.padding }}px;
    cursor: pointer;
    background-color: {{ block.settings.header_background_color }};
    transition: background-color 0.3s ease;
  }

  .ai-size-chart-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.header_hover_color }};
  }

  .ai-size-chart-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-size-chart-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    color: {{ block.settings.title_color }};
  }

  .ai-size-chart-{{ ai_gen_id }}.active .ai-size-chart-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-size-chart-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-size-chart-{{ ai_gen_id }}.active .ai-size-chart-content-{{ ai_gen_id }} {
    max-height: 3200px;
  }

  .ai-size-chart-inner-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    font-size: {{ block.settings.table_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    color: {{ block.settings.table_header_text }};
    padding: 12px 8px;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} td {
    padding: 10px 8px;
    border-bottom: 1px solid {{ block.settings.table_border_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.table_row_hover }};
  }

  .ai-size-chart-note-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px;
    background-color: {{ block.settings.note_background }};
    border-left: 3px solid {{ block.settings.note_border }};
    font-size: {{ block.settings.note_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-size-chart-guide-{{ ai_gen_id }} {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-size-chart-guide-title-{{ ai_gen_id }} {
    margin: 0 0 10px;
    font-size: {{ block.settings.table_font_size | plus: 1 }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-size-chart-guide-list-{{ ai_gen_id }} {
    margin: 0 0 14px;
    padding-left: 1.15em;
    font-size: {{ block.settings.table_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.55;
  }

  .ai-size-chart-guide-list-{{ ai_gen_id }} li {
    margin-bottom: 6px;
  }

  .ai-size-chart-diagram-{{ ai_gen_id }} {
    max-width: 220px;
    margin: 0 auto;
    color: {{ block.settings.text_color }};
  }

  .ai-size-chart-diagram-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-size-chart-diagram-caption-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: {{ block.settings.table_font_size | times: 0.92 }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
    line-height: 1.45;
    text-align: center;
  }

  .ai-size-chart-toolbar-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 12px;
    margin-bottom: 12px;
  }

  .ai-size-chart-toolbar-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.table_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-right: 4px;
  }

  .ai-size-chart-unit-toggle-{{ ai_gen_id }} {
    display: inline-flex;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 6px;
    overflow: hidden;
    background: {{ block.settings.background_color }};
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }} {
    margin: 0;
    padding: 8px 14px;
    font-size: {{ block.settings.table_font_size }}px;
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: transparent;
    color: {{ block.settings.text_color }};
    line-height: 1.2;
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }} + .ai-size-chart-unit-btn-{{ ai_gen_id }} {
    border-left: 1px solid {{ block.settings.border_color }};
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }}[aria-pressed="true"] {
    background-color: {{ block.settings.table_header_bg }};
    font-weight: 600;
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid {{ block.settings.note_border }};
    outline-offset: 2px;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }} .ai-size-chart-table-{{ ai_gen_id }} {
    min-width: 480px;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }}[data-unit="in"] .ai-sc-cm-{{ ai_gen_id }},
  .ai-size-chart-table-wrap-{{ ai_gen_id }}[data-unit="cm"] .ai-sc-in-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-size-chart-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-size-chart-table-{{ ai_gen_id }} {
      font-size: {{ block.settings.table_font_size | times: 0.9 }}px;
    }

    .ai-size-chart-table-{{ ai_gen_id }} th,
    .ai-size-chart-table-{{ ai_gen_id }} td {
      padding: 8px 6px;
    }
  }
{% endstyle %}

<size-chart-{{ ai_gen_id }}
