<script>
  (function() {
    class SizeChart{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.header = this.querySelector('.ai-size-chart-header-{{ ai_gen_id }}');
        this.tableWrap = this.querySelector('.ai-size-chart-table-wrap-{{ ai_gen_id }}');
        this.unitBtns = this.querySelectorAll('.ai-size-chart-unit-btn-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.header.addEventListener('click', () => this.toggle());
        this.header.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.toggle();
          }
        });
        this.unitBtns.forEach((btn) => {
          btn.addEventListener('click', () => this.setUnit(btn.dataset.unit));
        });
      }

      setUnit(unit) {
        if (!this.tableWrap || (unit !== 'in' && unit !== 'cm')) return;
        this.tableWrap.setAttribute('data-unit', unit);
        this.unitBtns.forEach((b) => {
          const on = b.dataset.unit === unit;
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }

      toggle() {
        const isActive = this.classList.contains('active');
        this.classList.toggle('active');
        this.header.setAttribute('aria-expanded', !isActive);
      }
    }

    customElements.define('size-chart-{{ ai_gen_id }}', SizeChart{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Size chart",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Size Chart"
    },
    {
      "type": "checkbox",
      "id": "default_open",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Measurement guide"
    },
    {
      "type": "checkbox",
      "id": "show_measurement_guide",
      "label": "Show how to measure (text + diagram)",
      "default": true
    },
    {
      "type": "text",
      "id": "measurement_guide_heading",
      "label": "Guide heading",
      "default": "How to measure"
    },
    {
      "type": "text",
      "id": "units_label",
      "label": "Unit toggle label",
      "default": "Measurements"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
