{% doc %}
  @prompt
    `imported` tag: age bands (0-6 mo … 11-12 yr) + CN size; height-led measurements.
    No `imported`: letter sizes S, M, L, XL, 2XL, 3XL with age column (S = 6 months, etc.).
    Columns include Height, Chest, Garment length; Inches default + CM toggle; optional how-to diagram.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-chart-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.45);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .ai-size-chart-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-size-chart-modal-{{ ai_gen_id }} {
    background: #ffffff;
    border-radius: 14px;
    border: 0.5px solid #D3D1C7;
    width: 100%;
    max-width: 560px;
    max-height: 85vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-size-chart-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    background: #2C2C2A;
    border-radius: 14px 14px 0 0;
    cursor: default;
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .ai-size-chart-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    color: #F1EFE8;
  }

  .ai-size-chart-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: #B4B2A9;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .ai-size-chart-icon-{{ ai_gen_id }}:hover {
    color: #F1EFE8;
  }

  .ai-size-chart-content-{{ ai_gen_id }} {
    max-height: none;
    overflow: visible;
  }

  .ai-size-chart-inner-{{ ai_gen_id }} {
    padding: 1.25rem;
  }

  .ai-size-chart-guide-{{ ai_gen_id }} {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 0.5px solid #D3D1C7;
  }

  .ai-size-chart-guide-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 500;
    color: #2C2C2A;
  }

  .ai-size-chart-guide-list-{{ ai_gen_id }} {
    margin: 0 0 12px;
    padding-left: 1.1em;
    font-size: 12px;
    color: #5F5E5A;
    line-height: 1.6;
  }

  .ai-size-chart-guide-list-{{ ai_gen_id }} li {
    margin-bottom: 4px;
  }

  .ai-size-chart-diagram-{{ ai_gen_id }} {
    max-width: 180px;
    margin: 0 auto;
    color: #5F5E5A;
  }

  .ai-size-chart-diagram-caption-{{ ai_gen_id }} {
    margin-top: 6px;
    font-size: 11px;
    color: #888780;
    text-align: center;
    line-height: 1.4;
  }

  .ai-size-chart-toolbar-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .ai-size-chart-toolbar-label-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 500;
    color: #2C2C2A;
  }

  .ai-size-chart-unit-toggle-{{ ai_gen_id }} {
    display: inline-flex;
    border: 0.5px solid #D3D1C7;
    border-radius: 6px;
    overflow: hidden;
    background: #F1EFE8;
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }} {
    margin: 0;
    padding: 5px 12px;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: transparent;
    color: #5F5E5A;
    line-height: 1.2;
    transition: background 0.15s;
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }} + .ai-size-chart-unit-btn-{{ ai_gen_id }} {
    border-left: 0.5px solid #D3D1C7;
  }

  .ai-size-chart-unit-btn-{{ ai_gen_id }}[aria-pressed="true"] {
    background: #2C2C2A;
    color: #F1EFE8;
    font-weight: 500;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
    border: 0.5px solid #D3D1C7;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }} .ai-size-chart-table-{{ ai_gen_id }} {
    min-width: 420px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    color: #2C2C2A;
  }

  .ai-size-chart-table-{{ ai_gen_id }} th {
    background: #F1EFE8;
    color: #444441;
    padding: 8px 10px;
    text-align: left;
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 0.5px solid #D3D1C7;
  }

  .ai-size-chart-table-{{ ai_gen_id }} td {
    padding: 9px 10px;
    border-bottom: 0.5px solid #F1EFE8;
    color: #2C2C2A;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:hover td {
    background: #F9F7F4;
  }

  .ai-size-chart-note-{{ ai_gen_id }} {
    margin-top: 1rem;
    padding: 10px 12px;
    background: #FAEEDA;
    border-left: 3px solid #EF9F27;
    border-radius: 0 6px 6px 0;
    font-size: 12px;
    color: #633806;
    line-height: 1.55;
  }

  .ai-size-chart-table-wrap-{{ ai_gen_id }}[data-unit="in"] .ai-sc-cm-{{ ai_gen_id }},
  .ai-size-chart-table-wrap-{{ ai_gen_id }}[data-unit="cm"] .ai-sc-in-{{ ai_gen_id }} {
    display: none;
  }

  .kidsmire-size-trigger-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #1D9E75;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    margin-left: 8px;
  }

  .kidsmire-size-trigger-{{ ai_gen_id }}:hover {
    color: #0F6E56;
  }

  @media screen and (max-width: 749px) {
    .ai-size-chart-modal-{{ ai_gen_id }} {
      max-height: 90vh;
    }

    .ai-size-chart-table-{{ ai_gen_id }} th,
    .ai-size-chart-table-{{ ai_gen_id }} td {
      padding: 7px 8px;
      font-size: 11px;
    }
  }
{% endstyle %}

<button class="kidsmire-size-trigger-{{ ai_gen_id }}" id="size-trigger-{{ ai_gen_id }}" type="button" aria-haspopup="dialog">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12h20M12 2v20M7 7l10 10M17 7L7 17"/></svg>
  What size is my child?
</button>

<size-chart-{{ ai_gen_id }}
  class="ai-size-chart-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  role="dialog"
  aria-modal="true"
  aria-label="Size guide"
>
  <div class="ai-size-chart-modal-{{ ai_gen_id }}">
    <div class="ai-size-chart-header-{{ ai_gen_id }}">
      <h3 class="ai-size-chart-title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
      <svg class="ai-size-chart-icon-{{ ai_gen_id }}" id="size-close-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="button" tabindex="0" aria-label="Close size guide">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </div>
    <div class="ai-size-chart-inner-{{ ai_gen_id }}">
      {% if block.settings.show_measurement_guide %}
        <div class="ai-size-chart-guide-{{ ai_gen_id }}">
          <p class="ai-size-chart-guide-title-{{ ai_gen_id }}">{{ block.settings.measurement_guide_heading }}</p>
          <ul class="ai-size-chart-guide-list-{{ ai_gen_id }}">
            <li><strong>Height</strong> — Most reliable for kids: measure barefoot, back straight, from top of head to the floor.</li>
            <li><strong>Chest</strong> — Tape around the fullest part of the chest, under the arms, parallel to the floor.</li>
            <li><strong>Garment length</strong> — On a similar garment, measure from the shoulder seam down to the hem (or use the chart as a guide for tops/dresses).</li>
          </ul>
          <div class="ai-size-chart-diagram-{{ ai_gen_id }}" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 270" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <g font-family="system-ui, sans-serif" font-size="9" fill="currentColor" stroke="none">
                <text x="14" y="138" text-anchor="middle" transform="rotate(-90 14 138)">Height</text>
                <text x="118" y="118" text-anchor="start">Chest</text>
                <text x="152" y="168" text-anchor="start">Length</text>
              </g>
              <line x1="28" y1="20" x2="28" y2="252" stroke-dasharray="4 3"/>
              <line x1="28" y1="20" x2="34" y2="20"/>
              <line x1="28" y1="252" x2="34" y2="252"/>
              <ellipse cx="100" cy="42" rx="20" ry="22"/>
              <path d="M100 64v26M82 118l-10 48M118 118l10 48M90 90h20"/>
              <path d="M90 90c-6 14-12 30-16 46M110 90c6 14 12 30 16 46"/>
              <path d="M94 198v44h-8M106 198v44h8"/>
              <ellipse cx="100" cy="108" rx="26" ry="14"/>
              <line x1="66" y1="108" x2="134" y2="108"/>
              <line x1="66" y1="102" x2="66" y2="114"/>
              <line x1="134" y1="102" x2="134" y2="114"/>
              <path d="M108 78 L108 178"/>
              <line x1="108" y1="78" x2="114" y2="78"/>
              <line x1="108" y1="178" x2="114" y2="178"/>
              <path d="M114 78 L124 84"/>
              <path d="M114 178 L124 172"/>
            </svg>
            <p class="ai-size-chart-diagram-caption-{{ ai_gen_id }}">
              Height (head to floor) · Chest (fullest part) · Length (shoulder seam to hem)
            </p>
          </div>
        </div>
      {% endif %}

      <div class="ai-size-chart-toolbar-{{ ai_gen_id }}">
        <span class="ai-size-chart-toolbar-label-{{ ai_gen_id }}">{{ block.settings.units_label }}</span>
        <div class="ai-size-chart-unit-toggle-{{ ai_gen_id }}" role="group" aria-label="{{ block.settings.units_label }}">
          <button type="button" class="ai-size-chart-unit-btn-{{ ai_gen_id }} ai-size-chart-unit-in-{{ ai_gen_id }}" data-unit="in" aria-pressed="true">Inches</button>
          <button type="button" class="ai-size-chart-unit-btn-{{ ai_gen_id }} ai-size-chart-unit-cm-{{ ai_gen_id }}" data-unit="cm" aria-pressed="false">CM</button>
        </div>
      </div>

      <div class="ai-size-chart-table-wrap-{{ ai_gen_id }}" data-unit="in">
      {% if product.tags contains 'imported' %}
        <table class="ai-size-chart-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>Age</th>
              <th>CN</th>
              <th>Height</th>
              <th>Chest</th>
              <th>Garment length</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>0-6 mo</td>
              <td>66</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">23-27</span><span class="ai-sc-cm-{{ ai_gen_id }}">59-68</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">16-17</span><span class="ai-sc-cm-{{ ai_gen_id }}">40-44</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">11-13</span><span class="ai-sc-cm-{{ ai_gen_id }}">28-32</span></td>
            </tr>
            <tr>
              <td>6-12 mo</td>
              <td>73</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">27-30</span><span class="ai-sc-cm-{{ ai_gen_id }}">68-76</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">17-19</span><span class="ai-sc-cm-{{ ai_gen_id }}">44-47</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">13-14</span><span class="ai-sc-cm-{{ ai_gen_id }}">32-36</span></td>
            </tr>
            <tr>
              <td>1-2 yr</td>
              <td>90</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">31-35</span><span class="ai-sc-cm-{{ ai_gen_id }}">80-90</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">19-21</span><span class="ai-sc-cm-{{ ai_gen_id }}">48-52</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">14-17</span><span class="ai-sc-cm-{{ ai_gen_id }}">36-42</span></td>
            </tr>
            <tr>
              <td>2-3 yr</td>
              <td>100</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">36-39</span><span class="ai-sc-cm-{{ ai_gen_id }}">92-98</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">20-21</span><span class="ai-sc-cm-{{ ai_gen_id }}">52-54</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">17-18</span><span class="ai-sc-cm-{{ ai_gen_id }}">42-46</span></td>
            </tr>
            <tr>
              <td>3-4 yr</td>
              <td>110</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">39-41</span><span class="ai-sc-cm-{{ ai_gen_id }}">98-104</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">21-22</span><span class="ai-sc-cm-{{ ai_gen_id }}">54-56</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">18-20</span><span class="ai-sc-cm-{{ ai_gen_id }}">46-50</span></td>
            </tr>
            <tr>
              <td>4-5 yr</td>
              <td>120</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">41-43</span><span class="ai-sc-cm-{{ ai_gen_id }}">104-110</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">22-23</span><span class="ai-sc-cm-{{ ai_gen_id }}">56-58</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">20-21</span><span class="ai-sc-cm-{{ ai_gen_id }}">50-54</span></td>
            </tr>
            <tr>
              <td>5-6 yr</td>
              <td>130</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">43-46</span><span class="ai-sc-cm-{{ ai_gen_id }}">110-116</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">23-24</span><span class="ai-sc-cm-{{ ai_gen_id }}">58-60</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">21-23</span><span class="ai-sc-cm-{{ ai_gen_id }}">54-58</span></td>
            </tr>
            <tr>
              <td>7-8 yr</td>
              <td>140</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">48-50</span><span class="ai-sc-cm-{{ ai_gen_id }}">122-128</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">24-25</span><span class="ai-sc-cm-{{ ai_gen_id }}">62-64</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">23-24</span><span class="ai-sc-cm-{{ ai_gen_id }}">58-62</span></td>
            </tr>
            <tr>
              <td>9-10 yr</td>
              <td>150</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">53-55</span><span class="ai-sc-cm-{{ ai_gen_id }}">134-140</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">26-27</span><span class="ai-sc-cm-{{ ai_gen_id }}">66-68</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">24-26</span><span class="ai-sc-cm-{{ ai_gen_id }}">62-66</span></td>
            </tr>
            <tr>
              <td>11-12 yr</td>
              <td>160</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">57-60</span><span class="ai-sc-cm-{{ ai_gen_id }}">146-152</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">28-29</span><span class="ai-sc-cm-{{ ai_gen_id }}">70-74</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">26-28</span><span class="ai-sc-cm-{{ ai_gen_id }}">66-70</span></td>
            </tr>
          </tbody>
        </table>
        {% if block.settings.show_note and block.settings.international_note != blank %}
          <div class="ai-size-chart-note-{{ ai_gen_id }}">
            {{ block.settings.international_note }}
          </div>
        {% endif %}
      {% else %}
        <table class="ai-size-chart-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>Size</th>
              <th>Age</th>
              <th>Height</th>
              <th>Chest</th>
              <th>Garment length</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>S</td>
              <td>6 months</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">25-28</span><span class="ai-sc-cm-{{ ai_gen_id }}">64-71</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">17-18</span><span class="ai-sc-cm-{{ ai_gen_id }}">43-45</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">12-13</span><span class="ai-sc-cm-{{ ai_gen_id }}">30-34</span></td>
            </tr>
            <tr>
              <td>M</td>
              <td>12 months</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">28-30</span><span class="ai-sc-cm-{{ ai_gen_id }}">71-77</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">18-19</span><span class="ai-sc-cm-{{ ai_gen_id }}">46-48</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">13-15</span><span class="ai-sc-cm-{{ ai_gen_id }}">34-38</span></td>
            </tr>
            <tr>
              <td>L</td>
              <td>18 months</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">31-33</span><span class="ai-sc-cm-{{ ai_gen_id }}">78-83</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">19-20</span><span class="ai-sc-cm-{{ ai_gen_id }}">49-51</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">15-16</span><span class="ai-sc-cm-{{ ai_gen_id }}">38-40</span></td>
            </tr>
            <tr>
              <td>XL</td>
              <td>2 years</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">34-36</span><span class="ai-sc-cm-{{ ai_gen_id }}">86-92</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">20-21</span><span class="ai-sc-cm-{{ ai_gen_id }}">51-53</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">16-17</span><span class="ai-sc-cm-{{ ai_gen_id }}">40-44</span></td>
            </tr>
            <tr>
              <td>2XL</td>
              <td>3-4 years</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">39-43</span><span class="ai-sc-cm-{{ ai_gen_id }}">98-110</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">21-23</span><span class="ai-sc-cm-{{ ai_gen_id }}">54-58</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">18-20</span><span class="ai-sc-cm-{{ ai_gen_id }}">46-52</span></td>
            </tr>
            <tr>
              <td>3XL</td>
              <td>5-6 years</td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">43-46</span><span class="ai-sc-cm-{{ ai_gen_id }}">110-116</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">23-24</span><span class="ai-sc-cm-{{ ai_gen_id }}">58-60</span></td>
              <td><span class="ai-sc-in-{{ ai_gen_id }}">21-23</span><span class="ai-sc-cm-{{ ai_gen_id }}">54-58</span></td>
            </tr>
          </tbody>
        </table>
        {% if block.settings.show_note and block.settings.standard_note != blank %}
          <div class="ai-size-chart-note-{{ ai_gen_id }}">
            {{ block.settings.standard_note }}
          </div>
        {% endif %}
      {% endif %}
      </div>
    </div>
  </div>
</size-chart-{{ ai_gen_id }}>

<script>
  (function() {
    class SizeChart{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        this.tableWrap = this.querySelector('.ai-size-chart-table-wrap-{{ ai_gen_id }}');
        this.unitBtns = this.querySelectorAll('.ai-size-chart-unit-btn-{{ ai_gen_id }}');
        this.closeBtn = this.querySelector('#size-close-{{ ai_gen_id }}');
        this.trigger = document.querySelector('#size-trigger-{{ ai_gen_id }}');

        if (this.trigger) {
          this.trigger.addEventListener('click', () => this.open());
        }
        if (this.closeBtn) {
          this.closeBtn.addEventListener('click', () => this.close());
          this.closeBtn.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.close(); }
          });
        }
        this.addEventListener('click', (e) => {
          if (e.target === this) this.close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) this.close();
        });
        this.unitBtns.forEach((btn) => {
          btn.addEventListener('click', () => this.setUnit(btn.dataset.unit));
        });
      }

      open() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      close() {
        this.classList.remove('active');
        document.body.style.overflow = '';
      }

      setUnit(unit) {
        if (!this.tableWrap || (unit !== 'in' && unit !== 'cm')) return;
        this.tableWrap.setAttribute('data-unit', unit);
        this.unitBtns.forEach((b) => {
          b.setAttribute('aria-pressed', b.dataset.unit === unit ? 'true' : 'false');
        });
      }

      toggle() {}
    }

    customElements.define('size-chart-{{ ai_gen_id }}', SizeChart{{ ai_gen_id }});
  })();
</script>

