{% doc %}
  @prompt
    Create a "Fabric & Material Details" section for the product page that displays fabric/material composition information. It should include: a section heading (e.g., "Fabric & Care"), an icon or visual indicator, a text block for fabric composition (e.g., "100% Organic Cotton"), and optionally care instructions. The design should match a premium kids' boutique aesthetic — clean, minimal, and parent-friendly. It should be customizable via theme editor settings so the merchant can fill in fabric details per product using metafields or static text.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fabric-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-fabric-details__header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ block.settings.spacing_below_heading }}px;
  }

  .ai-fabric-details__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
  }

  .ai-fabric-details__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-fabric-details__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-fabric-details__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-fabric-details__composition-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
  }

  .ai-fabric-details__composition-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-fabric-details__care-{{ ai_gen_id }} {
    font-size: {{ block.settings.care_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.care_text_color }};
    padding-top: {{ block.settings.care_padding_top }}px;
    border-top: {{ block.settings.care_divider_thickness }}px solid {{ block.settings.care_divider_color }};
  }

  .ai-fabric-details__care-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-fabric-details__care-{{ ai_gen_id }} ul,
  .ai-fabric-details__care-{{ ai_gen_id }} ol {
    margin: 8px 0 0 0;
    padding-left: 20px;
  }

  .ai-fabric-details__care-{{ ai_gen_id }} li {
    margin-bottom: 4px;
  }

  .ai-fabric-details__metafield-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-fabric-details__metafield-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-fabric-details__empty-state-{{ ai_gen_id }} {
    font-size: 14px;
    color: #999;
    font-style: italic;
    padding: 12px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-fabric-details-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-fabric-details__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-fabric-details__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-fabric-details-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_heading %}
    <div class="ai-fabric-details__header-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <div class="ai-fabric-details__icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'fabric' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          {% elsif block.settings.icon_style == 'leaf' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
              <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
            </svg>
          {% elsif block.settings.icon_style == 'tag' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="16" x2="12" y2="12"/>
              <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
          {% endif %}
        </div>
      {% endif %}
      <h3 class="ai-fabric-details__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    </div>
  {% endif %}

  <div class="ai-fabric-details__content-{{ ai_gen_id }}">
    {% if block.settings.use_metafield and product.metafields.custom.fabric_composition != blank %}
      <div class="ai-fabric-details__metafield-{{ ai_gen_id }}">
        {{ product.metafields.custom.fabric_composition }}
      </div>
    {% elsif block.settings.fabric_composition != blank %}
      <div class="ai-fabric-details__composition-{{ ai_gen_id }}">
        {{ block.settings.fabric_composition }}
      </div>
    {% else %}
      <div class="ai-fabric-details__empty-state-{{ ai_gen_id }}">
        Add fabric composition details in the block settings or via product metafields
      </div>
    {% endif %}

    {% if block.settings.show_care_instructions %}
      {% if block.settings.use_metafield and product.metafields.custom.care_instructions != blank %}
        <div class="ai-fabric-details__care-{{ ai_gen_id }}">
          {{ product.metafields.custom.care_instructions }}
        </div>
      {% elsif block.settings.care_instructions != blank %}
        <div class="ai-fabric-details__care-{{ ai_gen_id }}">
          {{ block.settings.care_instructions }}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Fabric & material details",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Fabric & Care"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "spacing_below_heading",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Space below heading",
      "default": 16
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "fabric",
          "label": "Fabric layers"
        },
        {
          "value": "leaf",
          "label": "Leaf (organic)"
        },
        {
          "value": "tag",
          "label": "Tag"
        },
        {
          "value": "info",
          "label": "Info circle"
        }
      ],
      "default": "fabric"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#334fb4"
    },
    {
      "type": "header",
      "content": "Fabric composition"
    },
    {
      "type": "checkbox",
      "id": "use_metafield",
      "label": "Use product metafield",
      "info": "If enabled, will display product.metafields.custom.fabric_composition and product.metafields.custom.care_instructions when available",
      "default": false
    },
    {
      "type": "richtext",
      "id": "fabric_composition",
      "label": "Fabric composition",
      "default": "<p>100% Organic Cotton</p>"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Text font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Space between sections",
      "default": 16
    },
    {
      "type": "header",
      "content": "Care instructions"
    },
    {
      "type": "checkbox",
      "id": "show_care_instructions",
      "label": "Show care instructions",
      "default": true
    },
    {
      "type": "richtext",
      "id": "care_instructions",
      "label": "Care instructions",
      "default": "<p>Machine wash cold. Tumble dry low. Do not bleach.</p>"
    },
    {
      "type": "range",
      "id": "care_text_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Care text size",
      "default": 13
    },
    {
      "type": "color",
      "id": "care_text_color",
      "label": "Care text color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "care_padding_top",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Care section top padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "care_divider_thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Divider thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "care_divider_color",
      "label": "Divider color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Container style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    }
  ],
  "presets": [
    {
      "name": "Fabric & material details"
    }
  ]
}
{% endschema %}
