{% doc %}
  @prompt
    Create a popup banner that appears automatically when a visitor lands on the page. The popup should promote a "Buy 2 @ ₹799" offer. It should appear after a short delay (1-2 seconds), have a visually appealing design matching a premium kids' clothing brand with pastel colors, include a close button, and optionally a CTA button. The popup should only show once per session using sessionStorage so it doesn't appear on every page load., Update the popup headline/text to say something like: "Mix & Match Any 2 from Our Premium Picks @ ₹799" with a sub-line like "Valid on selected styles only", A chic pop-up banner for a premium kids' clothing brand, rendered in soft pastel colors. The banner showcases the offer "Mix & Match Any 2 from Our Premium Picks @ ₹799" with a supporting line "Valid on selected styles only." The design features an elegant close button and a prominent call-to-action button, inviting shoppers to explore the collection. This design emphasizes a sophisticated and gentle aesthetic, perfectly suited for a high-end children's apparel brand., A premium kids' clothing brand popup banner, designed with a sophisticated black and white theme, elegantly showcases the "Mix & Match Any 2 from Our Premium Picks @ ₹799" headline. A subtle sub-line, "Valid on selected styles only," accompanies the offer. The banner, presented in a visually appealing layout, features a discreet close button and a prominent CTA button, hinting at a special offer with a touch of understated luxury.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-luxury-popup-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-luxury-popup-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    backdrop-filter: blur({{ block.settings.overlay_blur }}px);
  }

  .ai-luxury-popup-content-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.popup_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: {{ block.settings.popup_width }}px;
    width: 100%;
    padding: {{ block.settings.padding }}px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4), 0 10px 30px rgba(0, 0, 0, 0.2);
    text-align: center;
    opacity: 0;
    transform: scale(0.9) translateY(40px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    overflow: hidden;
  }

  .ai-luxury-popup-{{ ai_gen_id }}.active .ai-luxury-popup-content-{{ ai_gen_id }} {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .ai-luxury-popup-accent-line-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: {{ block.settings.accent_line_height }}px;
    background: linear-gradient(90deg, {{ block.settings.accent_color_1 }}, {{ block.settings.accent_color_2 }});
  }

  .ai-luxury-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.close_button_position }}px;
    right: {{ block.settings.close_button_position }}px;
    background: transparent;
    border: 2px solid {{ block.settings.close_button_border }};
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: {{ block.settings.close_button_color }};
    z-index: 10;
  }

  .ai-luxury-popup-close-{{ ai_gen_id }}:hover {
    background: {{ block.settings.close_button_hover_bg }};
    border-color: {{ block.settings.close_button_hover_border }};
    transform: rotate(90deg);
  }

  .ai-luxury-popup-close-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-luxury-popup-badge-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 20px;
    border-radius: 2px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    margin-bottom: 28px;
    text-transform: uppercase;
    letter-spacing: 2px;
    border: 1px solid {{ block.settings.badge_border_color }};
  }

  .ai-luxury-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: 300;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
    line-height: 1.3;
    letter-spacing: 0.5px;
  }

  .ai-luxury-popup-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
    margin: 0 0 16px;
    letter-spacing: -0.5px;
  }

  .ai-luxury-popup-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 36px;
    line-height: 1.6;
    font-style: italic;
    font-weight: 300;
  }

  .ai-luxury-popup-cta-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    padding: 16px 44px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 2px solid {{ block.settings.cta_border_color }};
    cursor: pointer;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .ai-luxury-popup-cta-{{ ai_gen_id }}:hover {
    background: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-luxury-popup-divider-{{ ai_gen_id }} {
    width: 80px;
    height: 1px;
    background: {{ block.settings.divider_color }};
    margin: 24px auto;
  }

  .ai-luxury-popup-decorative-corner-{{ ai_gen_id }} {
    position: absolute;
    width: 40px;
    height: 40px;
    border-style: solid;
    border-color: {{ block.settings.corner_accent_color }};
    pointer-events: none;
    opacity: 0.3;
  }

  .ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--top-left {
    top: 20px;
    left: 20px;
    border-width: 2px 0 0 2px;
  }

  .ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--top-right {
    top: 20px;
    right: 20px;
    border-width: 2px 2px 0 0;
  }

  .ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--bottom-left {
    bottom: 20px;
    left: 20px;
    border-width: 0 0 2px 2px;
  }

  .ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--bottom-right {
    bottom: 20px;
    right: 20px;
    border-width: 0 2px 2px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-popup-content-{{ ai_gen_id }} {
      max-width: 90%;
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-luxury-popup-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.7 }}px;
    }

    .ai-luxury-popup-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size | times: 0.75 }}px;
    }

    .ai-luxury-popup-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size | times: 0.9 }}px;
    }

    .ai-luxury-popup-cta-{{ ai_gen_id }} {
      padding: 14px 32px;
      font-size: {{ block.settings.cta_font_size | times: 0.9 }}px;
    }

    .ai-luxury-popup-badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.9 }}px;
      padding: 6px 16px;
    }

    .ai-luxury-popup-decorative-corner-{{ ai_gen_id }} {
      width: 30px;
      height: 30px;
    }
  }
{% endstyle %}

<luxury-popup-{{ ai_gen_id }}
  class="ai-luxury-popup-{{ ai_gen_id }}"
  data-delay="{{ block.settings.popup_delay }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-luxury-popup-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-luxury-popup-content-{{ ai_gen_id }}">
    {% if block.settings.show_accent_line %}
      <div class="ai-luxury-popup-accent-line-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.show_decorative_corners %}
      <div class="ai-luxury-popup-decorative-corner-{{ ai_gen_id }} ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--top-left"></div>
      <div class="ai-luxury-popup-decorative-corner-{{ ai_gen_id }} ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--top-right"></div>
      <div class="ai-luxury-popup-decorative-corner-{{ ai_gen_id }} ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--bottom-left"></div>
      <div class="ai-luxury-popup-decorative-corner-{{ ai_gen_id }} ai-luxury-popup-decorative-corner-{{ ai_gen_id }}--bottom-right"></div>
    {% endif %}

    <button
      class="ai-luxury-popup-close-{{ ai_gen_id }}"
      aria-label="Close popup"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    {% if block.settings.show_badge and block.settings.badge_text != blank %}
      <div class="ai-luxury-popup-badge-{{ ai_gen_id }}">
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-luxury-popup-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-luxury-popup-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.price_text != blank %}
      <div class="ai-luxury-popup-price-{{ ai_gen_id }}">
        {{ block.settings.price_text }}
      </div>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-luxury-popup-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    {% if block.settings.show_cta and block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-luxury-popup-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</luxury-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.sessionKey = 'ai_luxury_popup_shown_{{ ai_gen_id }}';
      }

      connectedCallback() {
        if (this.hasBeenShown()) {
          return;
        }

        const delay = parseInt(this.dataset.delay) || 1500;
        
        setTimeout(() => {
          this.showPopup();
        }, delay);

        this.setupEventListeners();
      }

      hasBeenShown() {
        return sessionStorage.getItem(this.sessionKey) === 'true';
      }

      markAsShown() {
        sessionStorage.setItem(this.sessionKey, 'true');
      }

      showPopup() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      hidePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
        this.markAsShown();
      }

      setupEventListeners() {
        const closeButton = this.querySelector('.ai-luxury-popup-close-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-luxury-popup-overlay-{{ ai_gen_id }}');
        const ctaButton = this.querySelector('.ai-luxury-popup-cta-{{ ai_gen_id }}');

        if (closeButton) {
          closeButton.addEventListener('click', () => {
            this.hidePopup();
          });
        }

        if (overlay) {
          overlay.addEventListener('click', () => {
            this.hidePopup();
          });
        }

        if (ctaButton) {
          ctaButton.addEventListener('click', () => {
            this.markAsShown();
          });
        }

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && this.classList.contains('active')) {
            this.hidePopup();
          }
        });
      }
    }

    customElements.define('luxury-popup-{{ ai_gen_id }}', LuxuryPopup{{ ai_gen_id }});
  })();
</script>

