          {% endif %}
        </div>
      </div>
    </div>
  </div>
</gender-filter-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class GenderFilterBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.genderButtons = this.querySelectorAll('.ai-gender-button-{{ ai_gen_id }}');
        this.bannerItems = this.querySelectorAll('.ai-banner-item-{{ ai_gen_id }}');
        this.ageFilter = this.querySelector('[data-age-filter]');
        this.ageButtons = this.querySelectorAll('[data-age-filter] .ai-age-button-{{ ai_gen_id }}');
        this.hint = this.querySelector('[data-filter-hint]');
        this.selectedGender = null;
        this.selectedAgeTag = null;
      }

      connectedCallback() {
        this.setupGenderToggle();
        this.setupAgeFilters();
        this.restoreFromUrl();
      }

      setupGenderToggle() {
        this.genderButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const gender = button.getAttribute('data-gender');
            this.switchGender(gender);
          });
        });
      }

      switchGender(gender, options = {}) {
        const { suppressApply = false } = options;
        this.selectedGender = gender;
        this.genderButtons.forEach((btn) => {
          const isActive = btn.getAttribute('data-gender') === gender;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', isActive);
        });

        this.bannerItems.forEach((item) => {
          const isActive = item.getAttribute('data-banner') === gender;
          item.classList.toggle('active', isActive);
        });

        this.enableAgeButtons();
        if (!suppressApply) this.applyFilters({ replaceState: true });
      }

      setupAgeFilters() {
        this.ageButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            if (!this.selectedGender) return;
            this.selectedAgeTag = button.getAttribute('data-age-tag');
            this.ageButtons.forEach((btn) => btn.classList.remove('active'));
            button.classList.add('active');
            this.applyFilters({ replaceState: false });
          });
        });
      }

      restoreFromUrl() {
        const url = new URL(window.location.href);
        const path = url.pathname || '';

        const boysHandle = '{{ block.settings.boys_collection_handle }}';
        const girlsHandle = '{{ block.settings.girls_collection_handle }}';
        const isOnBoys = boysHandle && path.indexOf(`/collections/${boysHandle}`) !== -1;
        const isOnGirls = girlsHandle && path.indexOf(`/collections/${girlsHandle}`) !== -1;

        if (isOnGirls) {
          this.switchGender('girls', { suppressApply: true });
        } else {
          // Default visual state
          this.switchGender('boys', { suppressApply: true });
        }

        const tag = url.searchParams.get('filter.p.tag');
        if (tag) {
          const match = Array.from(this.ageButtons).find((btn) => btn.getAttribute('data-age-tag') === tag);
          if (match) {
            this.selectedAgeTag = tag;
            this.ageButtons.forEach((btn) => btn.classList.remove('active'));
            match.classList.add('active');
          }
        }
      }

      disableAgeButtons() {
        this.ageButtons.forEach((btn) => btn.setAttribute('aria-disabled', 'true'));
      }

      enableAgeButtons() {
        this.ageButtons.forEach((btn) => btn.setAttribute('aria-disabled', 'false'));
        this.hint && (this.hint.style.display = 'none');
      }

      getProductGridContainer() {
        return (
          document.querySelector('#ProductGridContainer') ||
          document.querySelector('#product-grid') ||
          document.querySelector('[data-product-grid]') ||
          document.querySelector('.collection .product-grid') ||
          null
        );
      }

      getFacetContainer() {
        return (
          document.querySelector('#FacetFiltersForm') ||
          document.querySelector('[data-facet-filters]') ||
          null
        );
      }

      buildTargetUrl() {
        if (!this.selectedGender) return null;
        const boysUrl = '{{ block.settings.boys_collection_url }}';
        const girlsUrl = '{{ block.settings.girls_collection_url }}';
        const boysHandle = '{{ block.settings.boys_collection_handle }}';
        const girlsHandle = '{{ block.settings.girls_collection_handle }}';
        const fallbackBoys = 'https://kidsmire.co.in/collections/boys-clothing';
        const fallbackGirls = 'https://kidsmire.co.in/collections/girls-clothing';

        const base =
          this.selectedGender === 'boys'
            ? (boysUrl && boysUrl.length ? boysUrl : (boysHandle && boysHandle.length ? `/collections/${boysHandle}` : fallbackBoys))
            : (girlsUrl && girlsUrl.length ? girlsUrl : (girlsHandle && girlsHandle.length ? `/collections/${girlsHandle}` : fallbackGirls));

        const url = new URL(base, window.location.origin);
        if (this.selectedAgeTag) url.searchParams.set('filter.p.tag', this.selectedAgeTag);
        return url;
      }

      async applyFilters({ replaceState }) {
        const targetUrl = this.buildTargetUrl();
        if (!targetUrl) return;

        const nextUrl = targetUrl.pathname + (targetUrl.search || '');
        const currentUrl = window.location.pathname + window.location.search;
        if (replaceState && nextUrl === currentUrl) return;

        if (replaceState) {
          window.history.replaceState({}, '', nextUrl);
        } else {
          window.history.pushState({}, '', nextUrl);
        }

        const productGrid = this.getProductGridContainer();
        if (!productGrid) {
          window.location.assign(nextUrl);
          return;
        }

        productGrid.setAttribute('aria-busy', 'true');
        try {
          const res = await fetch(nextUrl, { credentials: 'same-origin' });
          if (!res.ok) throw new Error('Failed to fetch filtered results');

          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, 'text/html');

          const newGrid =
            doc.querySelector('#ProductGridContainer') ||
            doc.querySelector('#product-grid') ||
            doc.querySelector('[data-product-grid]') ||
            doc.querySelector('.collection .product-grid');

          if (newGrid) {
            productGrid.innerHTML = newGrid.innerHTML;
          } else {
            window.location.assign(nextUrl);
          }

          const facetContainer = this.getFacetContainer();
          if (facetContainer) {
            const newFacet =
              doc.querySelector('#FacetFiltersForm') ||
              doc.querySelector('[data-facet-filters]');
            if (newFacet) facetContainer.innerHTML = newFacet.innerHTML;
          }
        } catch (err) {
          window.location.assign(nextUrl);
        } finally {
          productGrid.removeAttribute('aria-busy');
        }
      }
    }

    customElements.define('gender-filter-banner-{{ ai_gen_id }}', GenderFilterBanner{{ ai_gen_id }});
  })();
</script>

