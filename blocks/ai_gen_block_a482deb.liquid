{% doc %}
  Minimal gender filter banner — KIDSMIRE
  Cream background, editorial typography, no hero image
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap');

  .kmgb-{{ ai_gen_id }} {
    background: #f5f2ee;
    padding: 72px 48px 56px;
    border-bottom: 0.5px solid rgba(0,0,0,0.08);
    width: 100%;
  }

  .kmgb-inner-{{ ai_gen_id }} {
    max-width: 860px;
  }

  /* Eyebrow */
  .kmgb-eyebrow-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .kmgb-eyebrow-line-{{ ai_gen_id }} {
    width: 28px;
    height: 1px;
    background: #c8b89a;
    flex-shrink: 0;
  }

  .kmgb-eyebrow-text-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
  }

  /* Headline */
  .kmgb-headline-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px;
    font-weight: 300;
    line-height: 1.05;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    margin: 0 0 16px;
    transition: opacity 0.3s ease;
  }

  .kmgb-headline-{{ ai_gen_id }} em {
    font-style: italic;
    color: #c8b89a;
  }

  /* Subtext */
  .kmgb-sub-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(0,0,0,0.45);
    line-height: 1.85;
    max-width: 400px;
    margin: 0 0 40px;
    display: block;
    transition: opacity 0.3s ease;
  }

  /* Toggle buttons */
  .kmgb-toggle-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 0;
    border: 0.5px solid rgba(0,0,0,0.15);
    width: fit-content;
  }

  .kmgb-btn-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 13px 36px;
    background: transparent;
    color: rgba(0,0,0,0.35);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    position: relative;
  }

  .kmgb-btn-{{ ai_gen_id }}:first-child {
    border-right: 0.5px solid rgba(0,0,0,0.15);
  }

  .kmgb-btn-{{ ai_gen_id }}.active {
    background: #1a1a1a;
    color: #f5f2ee;
  }

  .kmgb-btn-{{ ai_gen_id }}:not(.active):hover {
    background: rgba(0,0,0,0.04);
    color: rgba(0,0,0,0.7);
  }

  /* Fade animation for content swap */
  .kmgb-headline-{{ ai_gen_id }}.fade,
  .kmgb-sub-{{ ai_gen_id }}.fade {
    opacity: 0;
    transform: translateY(6px);
  }

  .kmgb-headline-{{ ai_gen_id }},
  .kmgb-sub-{{ ai_gen_id }} {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  @media (max-width: 768px) {
    .kmgb-{{ ai_gen_id }} {
      padding: 52px 24px 44px;
    }
    .kmgb-headline-{{ ai_gen_id }} {
      font-size: 38px;
    }
    .kmgb-btn-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: 9px;
      letter-spacing: 2px;
    }
  }

  @media (max-width: 480px) {
    .kmgb-headline-{{ ai_gen_id }} { font-size: 32px; }
    .kmgb-toggle-{{ ai_gen_id }} { width: 100%; }
    .kmgb-btn-{{ ai_gen_id }} { flex: 1; text-align: center; }
  }
{% endstyle %}

<div class="kmgb-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="kmgb-inner-{{ ai_gen_id }}">

    <div class="kmgb-eyebrow-{{ ai_gen_id }}">
      <div class="kmgb-eyebrow-line-{{ ai_gen_id }}"></div>
      <span class="kmgb-eyebrow-text-{{ ai_gen_id }}" id="kmgb-label-{{ ai_gen_id }}">Boys collection</span>
    </div>

    <h1 class="kmgb-headline-{{ ai_gen_id }}" id="kmgb-headline-{{ ai_gen_id }}">
      Dressed to move.<br><em>Built to last.</em>
    </h1>

    <span class="kmgb-sub-{{ ai_gen_id }}" id="kmgb-sub-{{ ai_gen_id }}">
      {{ block.settings.boys_subheading }}
    </span>

    <div class="kmgb-toggle-{{ ai_gen_id }}">
      <button
        class="kmgb-btn-{{ ai_gen_id }} active"
        id="kmgb-boys-btn-{{ ai_gen_id }}"
        data-gender="boys"
        aria-pressed="true"
      >{{ block.settings.boys_button_text | default: 'Boys' }}</button>
      <button
        class="kmgb-btn-{{ ai_gen_id }}"
        id="kmgb-girls-btn-{{ ai_gen_id }}"
        data-gender="girls"
        aria-pressed="false"
      >{{ block.settings.girls_button_text | default: 'Girls' }}</button>
    </div>

  </div>
</div>

<script>
(function() {
  var id = '{{ ai_gen_id }}';

  var content = {
    boys: {
      label: '{{ block.settings.boys_button_text | default: "Boys" }} collection',
      headline: '{{ block.settings.boys_heading | default: "Dressed to move.<br><em>Built to last.</em>" }}',
      sub: '{{ block.settings.boys_subheading | default: "100% cotton styles for boys 6 months to 6 years — tough enough for adventure, sharp enough for every occasion." }}'
    },
    girls: {
      label: '{{ block.settings.girls_button_text | default: "Girls" }} collection',
      headline: '{{ block.settings.girls_heading | default: "Pretty, playful,<br><em>perfectly her.</em>" }}',
      sub: '{{ block.settings.girls_subheading | default: "Handpicked styles for girls 6 months to 6 years — from everyday casuals to birthday-ready looks." }}'
    }
  };

  var boysUrl = '{{ block.settings.boys_collection_url | default: "/collections/boys-clothing" }}';
  var girlsUrl = '{{ block.settings.girls_collection_url | default: "/collections/girls-clothing" }}';

  var headline = document.getElementById('kmgb-headline-' + id);
  var sub = document.getElementById('kmgb-sub-' + id);
  var label = document.getElementById('kmgb-label-' + id);
  var boysBtn = document.getElementById('kmgb-boys-btn-' + id);
  var girlsBtn = document.getElementById('kmgb-girls-btn-' + id);

  function setGender(gender, navigate) {
    var c = content[gender];
    var url = gender === 'boys' ? boysUrl : girlsUrl;

    // Fade out
    headline.style.opacity = '0';
    headline.style.transform = 'translateY(6px)';
    sub.style.opacity = '0';
    sub.style.transform = 'translateY(6px)';

    setTimeout(function() {
      label.textContent = c.label;
      headline.innerHTML = c.headline;
      sub.textContent = c.sub;

      // Fade in
      headline.style.opacity = '1';
      headline.style.transform = 'translateY(0)';
      sub.style.opacity = '1';
      sub.style.transform = 'translateY(0)';
    }, 220);

    // Toggle buttons
    boysBtn.classList.toggle('active', gender === 'boys');
    girlsBtn.classList.toggle('active', gender === 'girls');
    boysBtn.setAttribute('aria-pressed', gender === 'boys');
    girlsBtn.setAttribute('aria-pressed', gender === 'girls');

    // Navigate
    if (navigate && url) {
      var currentPath = window.location.pathname;
      var targetPath = new URL(url, window.location.origin).pathname;
      if (currentPath !== targetPath) {
        window.location.assign(url);
      }
    }
  }

  // Detect current collection from URL on load
  var path = window.location.pathname.toLowerCase();
  var girlsHandle = '{{ block.settings.girls_collection_handle | default: "girls-clothing" }}';
  var isGirls = girlsHandle && path.indexOf(girlsHandle.toLowerCase()) !== -1;
  setGender(isGirls ? 'girls' : 'boys', false);

  boysBtn.addEventListener('click', function() { setGender('boys', true); });
  girlsBtn.addEventListener('click', function() { setGender('girls', true); });

  // Remove section gap
  var wrap = document.querySelector('.kmgb-' + id);
  if (wrap) wrap.closest('.shopify-section').style.cssText = 'margin:0!important;padding:0!important;';
})();
</script>

{% schema %}
{
  "name": "KM Gender Banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Boys"
    },
    {
      "type": "text",
      "id": "boys_button_text",
      "label": "Button label",
      "default": "Boys"
    },
    {
      "type": "text",
      "id": "boys_heading",
      "label": "Heading",
      "default": "Dressed to move.<br><em>Built to last.</em>"
    },
    {
      "type": "textarea",
      "id": "boys_subheading",
      "label": "Subheading",
      "default": "100% cotton styles for boys 6 months to 6 years — tough enough for adventure, sharp enough for every occasion."
    },
    {
      "type": "text",
      "id": "boys_collection_handle",
      "label": "Collection handle",
      "default": "boys-clothing"
    },
    {
      "type": "url",
      "id": "boys_collection_url",
      "label": "Collection URL"
    },
    {
      "type": "header",
      "content": "Girls"
    },
    {
      "type": "text",
      "id": "girls_button_text",
      "label": "Button label",
      "default": "Girls"
    },
    {
      "type": "text",
      "id": "girls_heading",
      "label": "Heading",
      "default": "Pretty, playful,<br><em>perfectly her.</em>"
    },
    {
      "type": "textarea",
      "id": "girls_subheading",
      "label": "Subheading",
      "default": "Handpicked styles for girls 6 months to 6 years — from everyday casuals to birthday-ready looks."
    },
    {
      "type": "text",
      "id": "girls_collection_handle",
      "label": "Collection handle",
      "default": "girls-clothing"
    },
    {
      "type": "url",
      "id": "girls_collection_url",
      "label": "Collection URL"
    }
  ],
  "presets": [
    {
      "name": "KM Gender Banner"
    }
  ]
}
{% endschema %}
