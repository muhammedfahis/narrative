                  Shop Girls
                </button>
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-banner-item-{{ ai_gen_id }} ai-banner-girls-{{ ai_gen_id }}" data-banner="girls">
        <div class="ai-banner-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.girls_banner_image %}
