    display: block;
    width: 100%;
    position: relative;
  }

  .ai-gender-filter-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-gender-toggle-{{ ai_gen_id }} {
    display: flex;
    justify-content: flex-start;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

