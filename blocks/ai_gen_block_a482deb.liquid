{% endstyle %}

<gender-filter-banner-{{ ai_gen_id }}
  class="ai-gender-filter-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-gender-filter-container-{{ ai_gen_id }}">
    <div class="ai-banner-content-{{ ai_gen_id }}">
