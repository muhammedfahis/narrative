                  data-gender="boys"
                  aria-pressed="true"
                >
                  Shop Boys
                </button>
                <button
                  class="ai-gender-button-{{ ai_gen_id }} ai-gender-button-girls-{{ ai_gen_id }}"
                  data-gender="girls"
                  aria-pressed="false"
