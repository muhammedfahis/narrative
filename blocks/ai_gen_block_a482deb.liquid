              data-age-tag="0-6-months"
              aria-disabled="false"
            >
              0-6
            </a>
            <a
              href="{{ block.settings.age_6_12_url | default: 'https://kidsmire.co.in/collections/6-12-months' }}"
              class="ai-age-button-{{ ai_gen_id }}"
              data-age-tag="6-12-months"
              aria-disabled="false"
            >
              6-12
            </a>
            <a
              href="{{ block.settings.age_1_2_url | default: 'https://kidsmire.co.in/collections/1-2-years' }}"
              class="ai-age-button-{{ ai_gen_id }}"
              data-age-tag="1-2-years"
              aria-disabled="false"
            >
              1-2
            </a>
            <a
              href="{{ block.settings.age_2_4_url | default: 'https://kidsmire.co.in/collections/2-4-years' }}"
              class="ai-age-button-{{ ai_gen_id }}"
              data-age-tag="2-4-years"
              aria-disabled="false"
            >
              2-4
            </a>
            <a
              href="{{ block.settings.age_4_plus_url | default: 'https://kidsmire.co.in/collections/4-plus-years' }}"
              class="ai-age-button-{{ ai_gen_id }}"
