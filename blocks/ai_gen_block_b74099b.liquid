{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  .km-ig-{{ ai_gen_id }} {
    background: #ffffff;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    font-family: 'Assistant', sans-serif;
  }

  .km-ig-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .km-ig-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .km-ig-eyebrow-{{ ai_gen_id }} {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #bbbbbb;
    margin: 0 0 6px;
  }

  .km-ig-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 800;
    color: #111111;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .km-ig-profile-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 0.5px solid #e0e0e0;
    border-radius: 99px;
    padding: 6px 14px 6px 6px;
    text-decoration: none;
    flex-shrink: 0;
    transition: border-color 0.2s ease;
  }

  .km-ig-profile-{{ ai_gen_id }}:hover {
    border-color: #111111;
  }

  .km-ig-avatar-{{ ai_gen_id }} {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid #f09433;
    flex-shrink: 0;
    background: #f5f5f5;
  }

  .km-ig-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .km-ig-handle-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 700;
    color: #111111;
    display: block;
  }

  .km-ig-sub-{{ ai_gen_id }} {
    font-size: 10px;
    color: #999999;
    display: block;
    margin-top: 1px;
  }

  .km-ig-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .km-ig-cell-{{ ai_gen_id }} {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: {{ block.settings.cell_radius }}px;
    position: relative;
  }

  .km-ig-cell-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .km-ig-cell-{{ ai_gen_id }}:hover img {
    transform: scale(1.04);
  }

  .km-ig-more-{{ ai_gen_id }} {
    aspect-ratio: 1;
    background: #111111;
    border-radius: {{ block.settings.cell_radius }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    text-decoration: none;
    transition: background 0.2s ease;
    cursor: pointer;
  }

  .km-ig-more-{{ ai_gen_id }}:hover {
    background: #333333;
  }

  .km-ig-more-icon-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 20px;
  }

  .km-ig-more-label-{{ ai_gen_id }} {
    font-size: 9px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .km-ig-footer-{{ ai_gen_id }} {
    margin-top: 14px;
    text-align: center;
    font-size: 11px;
    color: #bbbbbb;
  }

  .km-ig-footer-{{ ai_gen_id }} a {
    color: #111111;
    font-weight: 600;
    text-decoration: none;
  }

  .km-ig-footer-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .km-ig-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
    .km-ig-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 | round }}px;
    }
    .km-ig-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }
  }

{% endstyle %}

<div class="km-ig-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="km-ig-inner-{{ ai_gen_id }}">

    <div class="km-ig-header-{{ ai_gen_id }}">
      <div>
        <p class="km-ig-eyebrow-{{ ai_gen_id }}">Community</p>
        {% if block.settings.heading != blank %}
          <h2 class="km-ig-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
      </div>

      <a href="{{ block.settings.instagram_url }}" class="km-ig-profile-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
        <div class="km-ig-avatar-{{ ai_gen_id }}">
          {% if block.settings.profile_image %}
            <img src="{{ block.settings.profile_image | image_url: width: 80 }}" alt="{{ block.settings.instagram_handle }}" loading="lazy" width="80" height="80">
          {% endif %}
        </div>
        <div>
          <span class="km-ig-handle-{{ ai_gen_id }}">{{ block.settings.instagram_handle }}</span>
          <span class="km-ig-sub-{{ ai_gen_id }}">Follow on Instagram</span>
        </div>
      </a>
    </div>

    <div class="km-ig-grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign photo_key = 'photo_' | append: i %}
        {% if block.settings[photo_key] %}
          <div class="km-ig-cell-{{ ai_gen_id }}">
            <img
              src="{{ block.settings[photo_key] | image_url: width: 400 }}"
              alt="KIDSMIRE community photo {{ i }}"
              loading="lazy"
              width="400"
              height="400"
            >
          </div>
        {% endif %}
      {% endfor %}

      <a href="{{ block.settings.instagram_url }}" class="km-ig-more-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer" aria-label="See more on Instagram">
        <svg class="km-ig-more-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        <span class="km-ig-more-label-{{ ai_gen_id }}">See more</span>
      </a>
    </div>

    <p class="km-ig-footer-{{ ai_gen_id }}">
      {{ block.settings.footer_text }}
      <a href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener noreferrer">{{ block.settings.instagram_handle }}</a>
    </p>

  </div>
</div>

