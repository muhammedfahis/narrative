{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

  .km-ig-{{ ai_gen_id }} {
    background: #0e0e0e;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    font-family: 'Assistant', sans-serif;
  }

  .km-ig-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .km-ig-header-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 24px;
    gap: 20px;
    flex-wrap: wrap;
  }

  .km-ig-eyebrow-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c2a96e;
    margin-bottom: 8px;
  }

  .km-ig-eyebrow-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    width: 24px;
    height: 1.5px;
    background: #c2a96e;
    flex-shrink: 0;
  }

  .km-ig-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 800;
    color: #ffffff;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .km-ig-profile-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: 99px;
    padding: 5px 14px 5px 5px;
    flex-shrink: 0;
    text-decoration: none;
  }

  .km-ig-avatar-wrap-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.profile_pic_size }}px;
    height: {{ block.settings.profile_pic_size }}px;
    flex-shrink: 0;
  }

  .km-ig-avatar-ring-{{ ai_gen_id }} {
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    background: linear-gradient(45deg, {{ block.settings.story_gradient_color_1 }}, {{ block.settings.story_gradient_color_2 }}, {{ block.settings.story_gradient_color_3 }});
  }

  .km-ig-avatar-bg-{{ ai_gen_id }} {
    position: absolute;
    inset: 1px;
    border-radius: 50%;
    background: #0e0e0e;
    z-index: 1;
  }

  .km-ig-avatar-img-{{ ai_gen_id }} {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    overflow: hidden;
    background: #1a1a1a;
    z-index: 2;
  }

  .km-ig-avatar-img-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .km-ig-handle-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
  }

  .km-ig-sub-{{ ai_gen_id }} {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    margin-top: 1px;
  }

  /* ── MAIN GRID: 2 cols ── */
  .km-ig-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  /* Feature — tall portrait */
  .km-ig-feature-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 3/4;
  }

  /* Right col — 2 stacked squares */
  .km-ig-right-{{ ai_gen_id }} {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  .km-ig-cell-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 1;
  }

  .km-ig-feature-{{ ai_gen_id }} img,
  .km-ig-cell-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .km-ig-feature-{{ ai_gen_id }}:hover img,
  .km-ig-cell-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  /* Bottom strip — 3 equal squares */
  .km-ig-strip-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_gap }}px;
  }

  .km-ig-strip-cell-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 1;
  }

  .km-ig-strip-cell-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .km-ig-strip-cell-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  /* username tag */
  .km-ig-tag-{{ ai_gen_id }} {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background: rgba(0,0,0,0.72);
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    padding: 3px 7px;
    border-radius: 3px;
    z-index: 2;
    pointer-events: none;
    letter-spacing: 0.02em;
  }

  /* footer */
  .km-ig-footer-{{ ai_gen_id }} {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
  }

  .km-ig-footer-text-{{ ai_gen_id }} {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
  }

  .km-ig-footer-link-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    color: #c2a96e;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    letter-spacing: 0.02em;
  }

  .km-ig-footer-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .km-ig-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 16px;
    }
    .km-ig-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 | round }}px;
    }
    .km-ig-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
    .km-ig-feature-{{ ai_gen_id }} {
      aspect-ratio: 1;
    }
    .km-ig-strip-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

{% endstyle %}

<div class="km-ig-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="km-ig-inner-{{ ai_gen_id }}">

    <div class="km-ig-header-{{ ai_gen_id }}">
      <div>
        <div class="km-ig-eyebrow-{{ ai_gen_id }}">Community</div>
        {% if block.settings.heading != blank %}
          <h2 class="km-ig-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
      </div>

      <a href="{{ block.settings.footer_link }}" class="km-ig-profile-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
        <div class="km-ig-avatar-wrap-{{ ai_gen_id }}">
          <div class="km-ig-avatar-ring-{{ ai_gen_id }}"></div>
          <div class="km-ig-avatar-bg-{{ ai_gen_id }}"></div>
          <div class="km-ig-avatar-img-{{ ai_gen_id }}">
            {% if block.settings.profile_image %}
              <img src="{{ block.settings.profile_image | image_url: width: 120 }}" alt="{{ block.settings.instagram_handle }}" loading="lazy" width="120" height="120">
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
        </div>
        <div>
          <div class="km-ig-handle-{{ ai_gen_id }}">{{ block.settings.instagram_handle }}</div>
          <div class="km-ig-sub-{{ ai_gen_id }}">{{ block.settings.profile_subtitle }}</div>
        </div>
      </a>
    </div>

    <!-- TOP: feature left + 2 stacked right -->
    <div class="km-ig-grid-{{ ai_gen_id }}">
      <div class="km-ig-feature-{{ ai_gen_id }}">
        {% if block.settings.photo_1 %}
          <img src="{{ block.settings.photo_1 | image_url: width: 900 }}" alt="{{ block.settings.username_1 | default: 'KIDSMIRE' }}" loading="lazy" width="900" height="1200">
        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
        {% if block.settings.username_1 != blank %}<div class="km-ig-tag-{{ ai_gen_id }}">{{ block.settings.username_1 }}</div>{% endif %}
      </div>

      <div class="km-ig-right-{{ ai_gen_id }}">
        {% for i in (2..3) %}
          {% assign photo_key = 'photo_' | append: i %}
          {% assign user_key = 'username_' | append: i %}
          <div class="km-ig-cell-{{ ai_gen_id }}">
            {% if block.settings[photo_key] %}
              <img src="{{ block.settings[photo_key] | image_url: width: 600 }}" alt="{{ block.settings[user_key] | default: 'KIDSMIRE' }}" loading="lazy" width="600" height="600">
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
            {% if block.settings[user_key] != blank %}<div class="km-ig-tag-{{ ai_gen_id }}">{{ block.settings[user_key] }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- BOTTOM: 3 strip -->
    <div class="km-ig-strip-{{ ai_gen_id }}">
      {% for i in (4..6) %}
        {% assign photo_key = 'photo_' | append: i %}
        {% assign user_key = 'username_' | append: i %}
        <div class="km-ig-strip-cell-{{ ai_gen_id }}">
          {% if block.settings[photo_key] %}
            <img src="{{ block.settings[photo_key] | image_url: width: 500 }}" alt="{{ block.settings[user_key] | default: 'KIDSMIRE' }}" loading="lazy" width="500" height="500">
          {% else %}
            {{ 'image' | placeholder_svg_tag }}
          {% endif %}
          {% if block.settings[user_key] != blank %}<div class="km-ig-tag-{{ ai_gen_id }}">{{ block.settings[user_key] }}</div>{% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- FOOTER -->
    <div class="km-ig-footer-{{ ai_gen_id }}">
      <span class="km-ig-footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</span>
      {% if block.settings.footer_link != blank %}
        <a href="{{ block.settings.footer_link }}" class="km-ig-footer-link-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
          {{ block.settings.footer_link_text }}
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
        </a>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "KIDSMIRE Instagram",
  "settings": [
    { "type": "range", "id": "max_width", "min": 800, "max": 1600, "step": 100, "unit": "px", "label": "Max width", "default": 1200 },
    { "type": "range", "id": "section_padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "section_padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real Kids. Real Style." },
    { "type": "range", "id": "heading_size", "min": 24, "max": 60, "step": 2, "unit": "px", "label": "Heading size", "default": 40 },
    { "type": "header", "content": "Profile" },
    { "type": "image_picker", "id": "profile_image", "label": "Profile picture" },
    { "type": "range", "id": "profile_pic_size", "min": 32, "max": 56, "step": 4, "unit": "px", "label": "Picture size", "default": 40 },
    { "type": "color", "id": "story_gradient_color_1", "label": "Ring color 1", "default": "#f09433" },
    { "type": "color", "id": "story_gradient_color_2", "label": "Ring color 2", "default": "#dc2743" },
    { "type": "color", "id": "story_gradient_color_3", "label": "Ring color 3", "default": "#bc1888" },
    { "type": "text", "id": "instagram_handle", "label": "Handle", "default": "@kidsmire.official" },
    { "type": "text", "id": "profile_subtitle", "label": "Subtitle", "default": "Real kids, real moments" },
    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "grid_gap", "min": 2, "max": 12, "step": 2, "unit": "px", "label": "Gap", "default": 4 },
    { "type": "header", "content": "Photo 1 — Feature (large left)" },
    { "type": "image_picker", "id": "photo_1", "label": "Image" },
    { "type": "text", "id": "username_1", "label": "Username tag" },
    { "type": "header", "content": "Photo 2 — Top right" },
    { "type": "image_picker", "id": "photo_2", "label": "Image" },
    { "type": "text", "id": "username_2", "label": "Username tag" },
    { "type": "header", "content": "Photo 3 — Bottom right" },
    { "type": "image_picker", "id": "photo_3", "label": "Image" },
    { "type": "text", "id": "username_3", "label": "Username tag" },
    { "type": "header", "content": "Photo 4 — Strip left" },
    { "type": "image_picker", "id": "photo_4", "label": "Image" },
    { "type": "text", "id": "username_4", "label": "Username tag" },
    { "type": "header", "content": "Photo 5 — Strip center" },
    { "type": "image_picker", "id": "photo_5", "label": "Image" },
    { "type": "text", "id": "username_5", "label": "Username tag" },
    { "type": "header", "content": "Photo 6 — Strip right" },
    { "type": "image_picker", "id": "photo_6", "label": "Image" },
    { "type": "text", "id": "username_6", "label": "Username tag" },
    { "type": "header", "content": "Footer" },
    { "type": "text", "id": "footer_text", "label": "Footer text", "default": "See more at" },
    { "type": "url", "id": "footer_link", "label": "Footer link" },
    { "type": "text", "id": "footer_link_text", "label": "Link text", "default": "@kidsmire.official" }
  ],
  "presets": [{ "name": "KIDSMIRE Instagram" }]
}
{% endschema %}
