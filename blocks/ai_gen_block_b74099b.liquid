    {
      "type": "header",
      "content": "Photo 1"
    },
    {
      "type": "image_picker",
      "id": "photo_1",
      "label": "Photo 1"
    },
    {
      "type": "header",
      "content": "Photo 2"
    },
    {
      "type": "image_picker",
      "id": "photo_2",
      "label": "Photo 2"
    },
    {
      "type": "header",
      "content": "Photo 3"
    },
    {
      "type": "image_picker",
      "id": "photo_3",
      "label": "Photo 3"
    },
    {
      "type": "header",
      "content": "Photo 4"
    },
    {
      "type": "image_picker",
      "id": "photo_4",
      "label": "Photo 4"
    },
    {
      "type": "header",
      "content": "Photo 5"
    },
    {
      "type": "image_picker",
      "id": "photo_5",
      "label": "Photo 5"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
