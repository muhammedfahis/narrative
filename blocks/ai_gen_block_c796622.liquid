{% doc %}
  @prompt
    Scrolling announcement bar at the top of the page: messages move continuously
    from right to left (marquee). Full-width, compact, theme colors.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% capture marquee_segment_inner %}
  {% assign marquee_first = true %}
  {% if block.settings.message_1 != blank %}
    <span class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.message_1 }}</span>
    {% assign marquee_first = false %}
  {% endif %}
  {% if block.settings.message_2 != blank %}
    {% unless marquee_first %}
      <span class="ai-marquee-sep-{{ ai_gen_id }}" aria-hidden="true">·</span>
    {% endunless %}
    <span class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.message_2 }}</span>
    {% assign marquee_first = false %}
  {% endif %}
  {% if block.settings.message_3 != blank %}
    {% unless marquee_first %}
      <span class="ai-marquee-sep-{{ ai_gen_id }}" aria-hidden="true">·</span>
    {% endunless %}
    <span class="ai-marquee-text-{{ ai_gen_id }}">{{ block.settings.message_3 }}</span>
  {% endif %}
{% endcapture %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
  }

  .ai-announcement-bar-wrapper-{{ ai_gen_id }} {
    padding: {{ block.settings.vertical_padding }}px 0;
    position: relative;
    width: 100%;
  }

  .ai-marquee-viewport-{{ ai_gen_id }} {
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    min-height: {{ block.settings.font_size | times: 1.5 }}px;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    flex-shrink: 0;
    width: max-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.marquee_duration }}s linear infinite;
    will-change: transform;
  }

  .ai-marquee-sep-{{ ai_gen_id }} {
    display: inline-block;
    flex-shrink: 0;
    padding: 0 {{ block.settings.message_spacing | default: 36 }}px;
    opacity: 0.65;
    font-weight: 400;
  }

  .ai-marquee-segment-{{ ai_gen_id }} {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding-left: {{ block.settings.segment_gap }}px;
    padding-right: {{ block.settings.segment_gap }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    line-height: {{ block.settings.font_size | times: 1.5 }}px;
    white-space: nowrap;
  }

  .ai-marquee-text-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: underline;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-segment-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      line-height: {{ block.settings.font_size | times: 1.35 }}px;
    }

    .ai-marquee-viewport-{{ ai_gen_id }} {
      min-height: {{ block.settings.font_size | times: 2.35 }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-marquee-track-{{ ai_gen_id }} {
      animation: none;
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      white-space: normal;
    }

    .ai-marquee-segment-{{ ai_gen_id }} {
      white-space: normal;
      justify-content: center;
      text-align: center;
    }

    .ai-marquee-segment-{{ ai_gen_id }}[aria-hidden="true"] {
      display: none;
    }
  }
{% endstyle %}

<div
  class="ai-announcement-bar-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-announcement-bar-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-viewport-{{ ai_gen_id }}">
      <div class="ai-marquee-track-{{ ai_gen_id }}">
        <div class="ai-marquee-segment-{{ ai_gen_id }}">
          {{ marquee_segment_inner }}
        </div>
        <div class="ai-marquee-segment-{{ ai_gen_id }}" aria-hidden="true">
          {{ marquee_segment_inner }}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scrolling announcement",
  "settings": [
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "inline_richtext",
      "id": "message_1",
      "label": "Message 1",
      "default": "Free Shipping on orders above ₹399"
    },
    {
      "type": "inline_richtext",
      "id": "message_2",
      "label": "Message 2",
      "default": "💵 Cash on Delivery Available across India | Order now, pay at your doorstep"
    },
    {
      "type": "inline_richtext",
      "id": "message_3",
      "label": "Message 3",
      "default": "New Arrivals"
    },
    {
      "type": "range",
      "id": "message_spacing",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Space between messages",
      "default": 36
    },
    {
      "type": "header",
      "content": "Motion"
    },
    {
      "type": "range",
      "id": "marquee_duration",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Full scroll cycle time",
      "info": "Higher value = slower movement",
      "default": 30
    },
    {
      "type": "range",
      "id": "segment_gap",
      "min": 24,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Space between message repeats",
      "default": 48
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Scrolling announcement"
    }
  ]
}
{% endschema %}
